---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="설정" noindex>
  <div class="settings-shell" id="settings-shell" style="display:none">
    <h1 class="settings-title">설정</h1>

    <section class="settings-section">
      <h2 class="settings-section__title">카테고리 관리</h2>
      <p class="settings-section__desc">
        상위 카테고리와 하위 카테고리를 관리합니다. 기존 글은 바로 수정되지 않지만, 새 글 작성과 필터에는 즉시 반영됩니다.
      </p>

      <ul class="cat-list" id="cat-list"></ul>

      <form class="cat-add-form" id="cat-add-form">
        <input type="text" id="cat-input" placeholder="새 상위 카테고리 이름" autocomplete="off" />
        <button type="submit" id="cat-add-btn">추가</button>
      </form>

      <p class="settings-status" id="settings-status"></p>
    </section>
  </div>

  <div class="auth-guard" id="auth-guard" style="display:none">
    <p>접근 권한이 없습니다.</p>
    <a href="/">홈으로</a>
  </div>
</BaseLayout>

<script>
  const OWNER = "achieveonepark";
  const REPO = "cording-blog";
  const BRANCH = "main";
  const CATEGORY_FILE_PATH = "src/data/categories.json";
  const SUBCATEGORY_FILE_PATH = "src/data/subcategories.json";

  const settingsShell = document.getElementById("settings-shell") as HTMLElement;
  const authGuard = document.getElementById("auth-guard") as HTMLElement;
  const catList = document.getElementById("cat-list") as HTMLUListElement;
  const catInput = document.getElementById("cat-input") as HTMLInputElement;
  const catAddForm = document.getElementById("cat-add-form") as HTMLFormElement;
  const settingsStatus = document.getElementById("settings-status") as HTMLElement;

  const token = localStorage.getItem("gh_token") ?? "";

  let currentCategories: string[] = [];
  let currentCategorySha = "";
  let currentSubcategorySha = "";
  let currentSubcategories: Record<string, string[]> = {};
  let expandedCategory = "";

  function normalizeSubcategories(raw: unknown) {
    if (!raw || typeof raw !== "object") return {};

    return Object.entries(raw as Record<string, unknown>).reduce<Record<string, string[]>>((acc, entry) => {
      const [category, value] = entry;
      if (!Array.isArray(value)) {
        acc[category] = [];
        return acc;
      }

      acc[category] = value
        .map((item) => (typeof item === "string" ? item.trim() : ""))
        .filter(Boolean);
      return acc;
    }, {});
  }

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  async function fetchRepoJson(path: string) {
    const response = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );

    if (response.status === 404) {
      return { data: null, sha: "" };
    }

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.message ?? "파일을 불러오지 못했습니다.");
    }

    const payload = await response.json();
    const content = JSON.parse(atob(payload.content.replace(/\n/g, "")));
    return { data: content, sha: payload.sha as string };
  }

  async function saveRepoJson(path: string, data: unknown, sha: string, message: string) {
    const content = btoa(unescape(encodeURIComponent(JSON.stringify(data, null, 2) + "\n")));
    const response = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ message, content, sha, branch: BRANCH }),
      }
    );

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.message ?? "저장에 실패했습니다.");
    }

    const updated = await response.json();
    return updated.content.sha as string;
  }

  async function loadTaxonomy() {
    const [categoryFile, subcategoryFile] = await Promise.all([
      fetchRepoJson(CATEGORY_FILE_PATH),
      fetchRepoJson(SUBCATEGORY_FILE_PATH),
    ]);

    currentCategorySha = categoryFile.sha;
    currentSubcategorySha = subcategoryFile.sha;
    currentCategories = Array.isArray(categoryFile.data)
      ? categoryFile.data.filter((item): item is string => typeof item === "string" && item.trim().length > 0)
      : [];
    currentSubcategories = normalizeSubcategories(subcategoryFile.data);
    renderList();
  }

  function renderList() {
    catList.innerHTML = "";
    if (expandedCategory && !currentCategories.includes(expandedCategory)) {
      expandedCategory = "";
    }

    if (currentCategories.length === 0) {
      catList.innerHTML = '<li class="cat-empty">등록된 카테고리가 없습니다.</li>';
      return;
    }

    currentCategories.forEach((category) => {
      const item = document.createElement("li");
      item.className = "cat-item";
      item.dataset.category = category;
      item.dataset.expanded = expandedCategory === category ? "true" : "false";

      const subcategories = currentSubcategories[category] ?? [];
      const isExpanded = expandedCategory === category;
      const subcategoryHtml = subcategories.length > 0
        ? `
          <div class="cat-item__sub-list">
            ${subcategories.map((subcategory) => `
              <div class="subcat-chip">
                <span>${escapeHtml(subcategory)}</span>
                <button
                  type="button"
                  class="subcat-chip__delete"
                  data-subcategory-delete="${escapeHtml(subcategory)}"
                  aria-label="${escapeHtml(subcategory)} 삭제"
                >
                  삭제
                </button>
              </div>
            `).join("")}
          </div>
        `
        : '<p class="cat-item__sub-empty">하위 카테고리가 없습니다.</p>';

      item.innerHTML = `
        <div class="cat-item__header">
          <button
            type="button"
            class="cat-item__toggle"
            data-category-toggle
            aria-expanded="${isExpanded}"
          >
            <span class="cat-item__heading">
              <strong>${escapeHtml(category)}</strong>
              <span>${subcategories.length}개의 하위 카테고리</span>
            </span>
            <span class="cat-item__toggle-icon" aria-hidden="true">▾</span>
          </button>
          <button
            type="button"
            class="cat-del-btn"
            data-category-delete
            aria-label="${escapeHtml(category)} 삭제"
          >
            삭제
          </button>
        </div>
        <div class="cat-item__body" aria-hidden="${String(!isExpanded)}">
          ${subcategoryHtml}
          <form class="subcat-add-form" data-subcategory-form>
            <input
              type="text"
              name="subcategory"
              placeholder="새 하위 카테고리 이름"
              autocomplete="off"
            />
            <button type="submit">추가</button>
          </form>
        </div>
      `;

      catList.appendChild(item);
    });
  }

  function setStatus(message: string) {
    settingsStatus.textContent = message;
    if (message && !message.includes("중")) {
      window.setTimeout(() => {
        if (settingsStatus.textContent === message) {
          settingsStatus.textContent = "";
        }
      }, 2500);
    }
  }

  async function removeCategory(category: string) {
    if (!confirm(`"${category}" 카테고리를 삭제할까요?`)) return;

    const previousCategories = currentCategories.slice();
    if (expandedCategory === category) expandedCategory = "";
    currentCategories = currentCategories.filter((item) => item !== category);
    renderList();
    setStatus("저장 중...");

    try {
      currentCategorySha = await saveRepoJson(
        CATEGORY_FILE_PATH,
        currentCategories,
        currentCategorySha,
        `chore: remove category - ${category}`
      );
      setStatus("카테고리를 삭제했습니다.");
    } catch (error) {
      currentCategories = previousCategories;
      renderList();
      setStatus(`오류: ${error instanceof Error ? error.message : String(error)}`);
    }
  }

  async function addCategory(name: string) {
    if (currentCategories.includes(name)) {
      setStatus("이미 존재하는 카테고리입니다.");
      return;
    }

    const previousCategories = currentCategories.slice();
    currentCategories = [...currentCategories, name];
    expandedCategory = name;
    renderList();
    setStatus("저장 중...");

    try {
      currentCategorySha = await saveRepoJson(
        CATEGORY_FILE_PATH,
        currentCategories,
        currentCategorySha,
        `chore: add category - ${name}`
      );
      setStatus("카테고리를 추가했습니다.");
    } catch (error) {
      currentCategories = previousCategories;
      renderList();
      setStatus(`오류: ${error instanceof Error ? error.message : String(error)}`);
    }
  }

  async function addSubcategory(category: string, subcategory: string) {
    const currentValues = currentSubcategories[category] ?? [];
    if (currentValues.includes(subcategory)) {
      setStatus("이미 존재하는 하위 카테고리입니다.");
      return;
    }

    const previousSubcategories = JSON.parse(JSON.stringify(currentSubcategories)) as Record<string, string[]>;
    expandedCategory = category;
    currentSubcategories = {
      ...currentSubcategories,
      [category]: [...currentValues, subcategory],
    };
    renderList();
    setStatus("저장 중...");

    try {
      currentSubcategorySha = await saveRepoJson(
        SUBCATEGORY_FILE_PATH,
        currentSubcategories,
        currentSubcategorySha,
        `chore: add subcategory - ${category} / ${subcategory}`
      );
      setStatus("하위 카테고리를 추가했습니다.");
    } catch (error) {
      currentSubcategories = previousSubcategories;
      renderList();
      setStatus(`오류: ${error instanceof Error ? error.message : String(error)}`);
    }
  }

  async function removeSubcategory(category: string, subcategory: string) {
    if (!confirm(`"${category} / ${subcategory}" 하위 카테고리를 삭제할까요?`)) return;

    const previousSubcategories = JSON.parse(JSON.stringify(currentSubcategories)) as Record<string, string[]>;
    expandedCategory = category;
    currentSubcategories = {
      ...currentSubcategories,
      [category]: (currentSubcategories[category] ?? []).filter((item) => item !== subcategory),
    };
    renderList();
    setStatus("저장 중...");

    try {
      currentSubcategorySha = await saveRepoJson(
        SUBCATEGORY_FILE_PATH,
        currentSubcategories,
        currentSubcategorySha,
        `chore: remove subcategory - ${category} / ${subcategory}`
      );
      setStatus("하위 카테고리를 삭제했습니다.");
    } catch (error) {
      currentSubcategories = previousSubcategories;
      renderList();
      setStatus(`오류: ${error instanceof Error ? error.message : String(error)}`);
    }
  }

  catAddForm.addEventListener("submit", async (event) => {
    event.preventDefault();
    const name = catInput.value.trim();
    if (!name) return;
    catInput.value = "";
    await addCategory(name);
  });

  catList.addEventListener("click", async (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const categoryItem = target.closest(".cat-item");
    const category = categoryItem instanceof HTMLElement ? categoryItem.dataset.category ?? "" : "";
    if (!category) return;

    const categoryToggleButton = target.closest("[data-category-toggle]");
    if (categoryToggleButton instanceof HTMLButtonElement) {
      expandedCategory = expandedCategory === category ? "" : category;
      renderList();
      return;
    }

    const categoryDeleteButton = target.closest("[data-category-delete]");
    if (categoryDeleteButton instanceof HTMLButtonElement) {
      await removeCategory(category);
      return;
    }

    const subcategoryDeleteButton = target.closest("[data-subcategory-delete]");
    if (subcategoryDeleteButton instanceof HTMLButtonElement) {
      const subcategory = subcategoryDeleteButton.dataset.subcategoryDelete ?? "";
      if (!subcategory) return;
      await removeSubcategory(category, subcategory);
    }
  });

  catList.addEventListener("submit", async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLFormElement) || !target.matches("[data-subcategory-form]")) return;

    event.preventDefault();

    const categoryItem = target.closest(".cat-item");
    const category = categoryItem instanceof HTMLElement ? categoryItem.dataset.category ?? "" : "";
    const input = target.elements.namedItem("subcategory");
    if (!category || !(input instanceof HTMLInputElement)) return;

    const value = input.value.trim();
    if (!value) return;

    input.value = "";
    await addSubcategory(category, value);
  });

  (async () => {
    if (!token) {
      authGuard.style.display = "";
      return;
    }

    const userResponse = await fetch("https://api.github.com/user", {
      headers: { Authorization: `Bearer ${token}` },
    });
    const user = await userResponse.json();
    if (user.login !== OWNER) {
      localStorage.removeItem("gh_token");
      authGuard.style.display = "";
      return;
    }

    settingsShell.style.display = "";
    await loadTaxonomy();
  })();
</script>

<style>
  .settings-shell,
  .auth-guard {
    max-width: 760px;
    margin: 2.5rem auto;
    padding: 0 1rem;
  }

  .settings-title {
    font-size: clamp(1.5rem, 1.2rem + 1vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin: 0 0 2rem;
  }

  .settings-section {
    border: 1px solid rgba(124, 255, 122, 0.1);
    border-radius: 16px;
    background: rgba(18, 23, 29, 0.88);
    padding: 1.5rem;
  }

  .settings-section__title {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0 0 0.35rem;
    color: rgba(124, 255, 122, 0.85);
  }

  .settings-section__desc {
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .cat-list {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .cat-item {
    display: grid;
    gap: 0.55rem;
    padding: 0.9rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(124, 255, 122, 0.1);
    background: rgba(10, 14, 18, 0.68);
  }

  .cat-item__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: start;
  }

  .cat-item__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    color: inherit;
    text-align: left;
    cursor: pointer;
  }

  .cat-item__heading {
    display: grid;
    gap: 0.18rem;
    min-width: 0;
  }

  .cat-item__heading strong {
    font-size: 1rem;
    color: rgba(214, 255, 214, 0.88);
  }

  .cat-item__heading span {
    font-size: 0.74rem;
    color: rgba(124, 255, 122, 0.48);
  }

  .cat-item__body {
    display: grid;
    gap: 0.75rem;
    max-height: 0;
    overflow: clip;
    opacity: 0;
    transform: translateY(-0.25rem);
    pointer-events: none;
    transition:
      max-height 260ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .cat-item[data-expanded="true"] .cat-item__body {
    max-height: 20rem;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .cat-item__toggle-icon {
    flex: none;
    color: rgba(124, 255, 122, 0.45);
    transition: transform 180ms ease, color 180ms ease;
  }

  .cat-item[data-expanded="true"] .cat-item__toggle-icon {
    transform: rotate(180deg);
    color: #7cff7a;
  }

  .cat-item__sub-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cat-item__sub-empty {
    margin: 0;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .subcat-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.38rem 0.68rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.14);
    background: rgba(12, 18, 24, 0.86);
    color: rgba(214, 255, 214, 0.76);
    font-size: 0.78rem;
  }

  .subcat-chip__delete,
  .cat-del-btn {
    background: transparent;
    border: 1px solid rgba(255, 80, 80, 0.2);
    color: rgba(255, 120, 120, 0.6);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    font-size: 0.72rem;
    cursor: pointer;
    transition: border-color 150ms, background 150ms, color 150ms;
  }

  .subcat-chip__delete:hover,
  .cat-del-btn:hover {
    border-color: rgba(255, 80, 80, 0.5);
    background: rgba(255, 80, 80, 0.08);
    color: #ff7070;
  }

  .subcat-add-form,
  .cat-add-form {
    display: flex;
    gap: 0.6rem;
  }

  .subcat-add-form input,
  .cat-add-form input {
    flex: 1;
    background: rgba(0, 0, 0, 0.5);
    color: #d6ffd6;
    border: 1px solid rgba(124, 255, 122, 0.2);
    border-radius: 8px;
    padding: 0.58rem 0.8rem;
    font-size: 0.9rem;
  }

  .subcat-add-form input:focus,
  .cat-add-form input:focus {
    outline: none;
    border-color: rgba(124, 255, 122, 0.5);
  }

  .subcat-add-form button,
  .cat-add-form button {
    background: rgba(124, 255, 122, 0.12);
    color: #7cff7a;
    border: 1px solid rgba(124, 255, 122, 0.3);
    border-radius: 8px;
    padding: 0.5rem 1.1rem;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 150ms;
    white-space: nowrap;
  }

  .subcat-add-form button:hover,
  .cat-add-form button:hover {
    background: rgba(124, 255, 122, 0.22);
  }

  .cat-empty {
    font-size: 0.85rem;
    color: var(--muted);
    padding: 0.5rem 0;
  }

  .settings-status {
    margin-top: 0.75rem;
    font-size: 0.82rem;
    color: rgba(124, 255, 122, 0.65);
    min-height: 1.2em;
  }

  .auth-guard {
    text-align: center;
    color: rgba(124, 255, 122, 0.6);
    padding-top: 6rem;
  }

  @media (max-width: 640px) {
    .cat-item__header,
    .subcat-add-form,
    .cat-add-form {
      flex-direction: column;
      align-items: stretch;
    }

    .cat-del-btn {
      align-self: flex-start;
    }
  }
</style>
