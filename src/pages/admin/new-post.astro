---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="글쓰기">
  <div class="editor-shell" id="editor-shell" style="display:none">
    <form class="post-form" id="post-form">
      <div class="meta-row">
        <div class="form-row">
          <label for="post-title">제목</label>
          <input type="text" id="post-title" name="title" required placeholder="포스트 제목" />
        </div>

        <div class="form-row">
          <label for="post-description">설명</label>
          <input type="text" id="post-description" name="description" required placeholder="한 줄 설명" />
        </div>

        <div class="meta-cols">
          <div class="form-row">
            <label for="post-category">카테고리</label>
            <select id="post-category" name="category">
              <option value="">없음</option>
            </select>
          </div>

          <div class="form-row">
            <label for="post-tags">태그</label>
            <input type="text" id="post-tags" name="tags" placeholder="쉼표로 구분 (예: iOS, Swift, Tips)" />
          </div>
        </div>

        <div class="form-row">
          <label for="post-thumbnail">썸네일 URL</label>
          <div class="thumbnail-row">
            <input type="text" id="post-thumbnail" name="thumbnail" placeholder="https://... 또는 아래에서 이미지 선택" />
            <button type="button" id="pick-thumb-btn" class="pick-btn">이미지에서 선택</button>
          </div>
          <div id="thumb-picker" class="thumb-picker" style="display:none"></div>
        </div>
      </div>

      <div class="form-row form-row--full">
        <label>내용</label>
        <div id="toast-editor"></div>
      </div>

      <div class="form-actions">
        <span id="submit-status"></span>
        <button type="submit" id="submit-btn">커밋 & 발행</button>
      </div>

      <input type="hidden" id="edit-slug" value="" />
    </form>
  </div>

  <div class="auth-guard" id="auth-guard" style="display:none">
    <p>접근 권한이 없습니다.</p>
    <a href="/">홈으로</a>
  </div>
</BaseLayout>

<script>
  import Editor from "@toast-ui/editor";
  import "@toast-ui/editor/dist/toastui-editor.css";
  import "@toast-ui/editor/dist/theme/toastui-editor-dark.css";

  const OWNER = "achieveonepark";
  const REPO = "cording-blog";
  const BRANCH = "main";

  const editorShell = document.getElementById("editor-shell") as HTMLElement;
  const authGuard = document.getElementById("auth-guard") as HTMLElement;
  const form = document.getElementById("post-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitStatus = document.getElementById("submit-status") as HTMLElement;

  // --- GitHub API ---
  async function getExistingSha(path: string, token: string): Promise<string | null> {
    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );
    if (res.status === 404) return null;
    return (await res.json()).sha ?? null;
  }

  async function uploadImage(blob: Blob, token: string): Promise<string> {
    const ext = blob.type.split("/")[1] ?? "png";
    const filename = `${Date.now()}.${ext}`;
    const path = `public/images/${filename}`;

    const base64 = await new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve((reader.result as string).split(",")[1]);
      reader.onerror = reject;
      reader.readAsDataURL(blob);
    });

    const sha = await getExistingSha(path, token);
    const body: Record<string, unknown> = {
      message: `chore: upload image - ${filename}`,
      content: base64,
      branch: BRANCH,
    };
    if (sha) body.sha = sha;

    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      }
    );
    if (!res.ok) throw new Error((await res.json()).message ?? "이미지 업로드 실패");
    return `/images/${filename}`;
  }

  async function commitPost(token: string, filename: string, content: string): Promise<void> {
    const path = `src/content/blog/${filename}`;
    const sha = await getExistingSha(path, token);
    const body: Record<string, unknown> = {
      message: `feat: add post - ${filename.replace(".md", "")}`,
      content: btoa(unescape(encodeURIComponent(content))),
      branch: BRANCH,
    };
    if (sha) body.sha = sha;

    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      }
    );
    if (!res.ok) throw new Error((await res.json()).message ?? "GitHub API 오류");
  }

  // --- 유틸 ---
  function toSlug(title: string): string {
    return title.toLowerCase().trim()
      .replace(/[^a-z0-9가-힣\s-]/g, "")
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-");
  }

  function buildFrontmatter(title: string, description: string, tags: string[], category: string, thumbnail: string): string {
    const today = new Date().toISOString().split("T")[0];
    const tagLines = tags.length > 0
      ? "tags:\n" + tags.map((t) => `  - ${t.trim()}`).join("\n")
      : "tags: []";
    const catLine = category ? `\ncategory: ${category}` : "";
    const thumbLine = thumbnail ? `\nthumbnail: ${thumbnail}` : "";
    return `---\ntitle: "${title}"\ndescription: "${description}"\npubDate: ${today}\n${tagLines}${catLine}${thumbLine}\n---\n\n`;
  }

  async function loadCategories(token: string) {
    const select = document.getElementById("post-category") as HTMLSelectElement;
    try {
      const res = await fetch(
        `https://api.github.com/repos/${OWNER}/${REPO}/contents/src/data/categories.json?ref=${BRANCH}`,
        { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
      );
      if (!res.ok) return;
      const data = await res.json();
      const cats: string[] = JSON.parse(atob(data.content.replace(/\n/g, "")));
      cats.forEach((cat) => {
        const opt = document.createElement("option");
        opt.value = cat; opt.textContent = cat;
        select.appendChild(opt);
      });
    } catch {}
  }

  async function loadEditContent(slug: string, token: string, editor: Editor) {
    const path = `src/content/blog/${slug}.md`;
    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );
    if (!res.ok) return;
    const data = await res.json();
    const raw = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));

    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n\n?([\s\S]*)$/);
    if (!fmMatch) return;
    const fm = fmMatch[1];
    const body = fmMatch[2];

    const titleMatch = fm.match(/^title:\s*"?(.+?)"?\s*$/m);
    const descMatch = fm.match(/^description:\s*"?(.+?)"?\s*$/m);
    const categoryMatch = fm.match(/^category:\s*(.+)\s*$/m);
    const thumbMatch = fm.match(/^thumbnail:\s*(.+)\s*$/m);
    const tagsMatch = [...fm.matchAll(/^\s*-\s*(.+)\s*$/gm)].map((m) => m[1]);

    (document.getElementById("post-title") as HTMLInputElement).value = titleMatch?.[1] ?? "";
    (document.getElementById("post-description") as HTMLInputElement).value = descMatch?.[1] ?? "";
    (document.getElementById("post-tags") as HTMLInputElement).value = tagsMatch.join(", ");
    (document.getElementById("post-thumbnail") as HTMLInputElement).value = thumbMatch?.[1]?.trim() ?? "";
    editor.setMarkdown(body);

    const catVal = categoryMatch?.[1]?.trim() ?? "";
    const select = document.getElementById("post-category") as HTMLSelectElement;
    if (catVal) {
      if (![...select.options].some((o) => o.value === catVal)) {
        const opt = document.createElement("option");
        opt.value = catVal; opt.textContent = catVal;
        select.appendChild(opt);
      }
      select.value = catVal;
    }
    (document.getElementById("edit-slug") as HTMLInputElement).value = slug;
    (document.getElementById("submit-btn") as HTMLButtonElement).textContent = "수정 & 발행";
    document.title = "글 수정";
  }

  // --- 진입점 ---
  (async () => {
    const token = localStorage.getItem("gh_token");
    if (!token) { authGuard.style.display = ""; return; }

    const userRes = await fetch("https://api.github.com/user", {
      headers: { Authorization: `Bearer ${token}` },
    });
    const user = await userRes.json();
    if (user.login !== OWNER) {
      localStorage.removeItem("gh_token");
      authGuard.style.display = "";
      return;
    }

    editorShell.style.display = "";

    // Toast UI Editor 초기화
    const editor = new Editor({
      el: document.getElementById("toast-editor") as HTMLElement,
      height: "600px",
      initialEditType: "wysiwyg",
      previewStyle: "vertical",
      theme: "dark",
      placeholder: "내용을 입력하세요...",
      hooks: {
        addImageBlobHook: async (blob, callback) => {
          try {
            const url = await uploadImage(blob, token);
            callback(url, "image");
          } catch (err) {
            alert(`이미지 업로드 실패: ${err instanceof Error ? err.message : String(err)}`);
          }
        },
      },
    });

    await loadCategories(token);

    const editSlug = new URLSearchParams(window.location.search).get("edit");
    if (editSlug) await loadEditContent(editSlug, token, editor);

    // ── 대표 사진 선택 ────────────────────────────────────────
    const pickBtn = document.getElementById("pick-thumb-btn") as HTMLButtonElement;
    const thumbPicker = document.getElementById("thumb-picker") as HTMLDivElement;
    const thumbInput = document.getElementById("post-thumbnail") as HTMLInputElement;

    pickBtn.addEventListener("click", () => {
      const md = editor.getMarkdown();
      const matches = [...md.matchAll(/!\[.*?\]\(([^)]+)\)/g)].map(m => m[1]);
      const unique = [...new Set(matches)];

      if (!unique.length) {
        thumbPicker.style.display = "none";
        alert("에디터에 이미지가 없습니다. 이미지를 먼저 추가해주세요.");
        return;
      }

      const isOpen = thumbPicker.style.display !== "none";
      if (isOpen) { thumbPicker.style.display = "none"; return; }

      thumbPicker.innerHTML = unique.map(url => `
        <button type="button" class="thumb-option ${thumbInput.value === url ? "thumb-option--selected" : ""}" data-url="${url}">
          <img src="${url}" alt="" loading="lazy" />
        </button>
      `).join("");

      thumbPicker.querySelectorAll(".thumb-option").forEach(btn => {
        btn.addEventListener("click", () => {
          const url = (btn as HTMLElement).dataset.url ?? "";
          thumbInput.value = url;
          thumbPicker.querySelectorAll(".thumb-option").forEach(b => b.classList.remove("thumb-option--selected"));
          btn.classList.add("thumb-option--selected");
        });
      });

      thumbPicker.style.display = "grid";
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const title = (document.getElementById("post-title") as HTMLInputElement).value.trim();
      const description = (document.getElementById("post-description") as HTMLInputElement).value.trim();
      const tagsRaw = (document.getElementById("post-tags") as HTMLInputElement).value;
      const tags = tagsRaw ? tagsRaw.split(",").map((t) => t.trim()).filter(Boolean) : [];
      const category = (document.getElementById("post-category") as HTMLSelectElement).value;
      const thumbnail = (document.getElementById("post-thumbnail") as HTMLInputElement).value.trim();
      const editSlug = (document.getElementById("edit-slug") as HTMLInputElement).value;
      const slug = editSlug || toSlug(title);
      const markdown = editor.getMarkdown();
      const fileContent = buildFrontmatter(title, description, tags, category, thumbnail) + markdown;

      submitBtn.disabled = true;
      submitStatus.textContent = "커밋 중...";

      try {
        await commitPost(token, `${slug}.md`, fileContent);
        submitStatus.textContent = editSlug ? "수정 완료! 배포 중..." : "발행 완료! 배포 중...";
        submitBtn.disabled = false;
      } catch (err) {
        submitStatus.textContent = `오류: ${err instanceof Error ? err.message : String(err)}`;
        submitBtn.disabled = false;
      }
    });
  })();
</script>

<!-- Toast UI Editor 다크 테마 커스터마이징 -->
<style is:global>
  .toastui-editor-defaultUI {
    border: 1px solid rgba(124, 255, 122, 0.2) !important;
    border-radius: 6px !important;
    background: rgba(0, 0, 0, 0.5) !important;
  }

  .toastui-editor-toolbar {
    background: rgba(10, 15, 20, 0.95) !important;
    border-bottom: 1px solid rgba(124, 255, 122, 0.15) !important;
  }

  .toastui-editor-toolbar-icons {
    border: none !important;
  }

  .toastui-editor-toolbar-icons:hover,
  .toastui-editor-toolbar-icons.active {
    background: rgba(124, 255, 122, 0.12) !important;
  }

  .toastui-editor-ww-container,
  .toastui-editor-md-container {
    background: transparent !important;
  }

  .ProseMirror,
  .toastui-editor-contents,
  .toastui-editor-md-container .toastui-editor {
    color: #c8d8c8 !important;
    caret-color: #7cff7a !important;
  }

  .toastui-editor-contents p,
  .toastui-editor-contents li {
    color: #c8d8c8;
  }

  .toastui-editor-contents h1,
  .toastui-editor-contents h2,
  .toastui-editor-contents h3,
  .toastui-editor-contents h4 {
    color: #e8f8e8;
    border-color: rgba(124, 255, 122, 0.2);
  }

  .toastui-editor-contents a { color: #7cff7a; }

  .toastui-editor-contents code {
    background: rgba(124, 255, 122, 0.08) !important;
    color: #a8f0a8 !important;
  }

  .toastui-editor-contents pre {
    background: rgba(0, 0, 0, 0.6) !important;
    border: 1px solid rgba(124, 255, 122, 0.15) !important;
  }

  .toastui-editor-contents blockquote {
    border-left-color: rgba(124, 255, 122, 0.4) !important;
    color: rgba(200, 240, 200, 0.7) !important;
  }

  .toastui-editor-mode-switch {
    background: rgba(10, 15, 20, 0.95) !important;
    border-top: 1px solid rgba(124, 255, 122, 0.15) !important;
  }

  .toastui-editor-mode-switch .tab-item {
    color: rgba(124, 255, 122, 0.5) !important;
  }

  .toastui-editor-mode-switch .tab-item.active {
    color: #7cff7a !important;
    background: rgba(124, 255, 122, 0.1) !important;
  }

  .toastui-editor-popup {
    background: #0a0f14 !important;
    border: 1px solid rgba(124, 255, 122, 0.25) !important;
  }

  .toastui-editor-popup input {
    background: rgba(0, 0, 0, 0.6) !important;
    color: #d6ffd6 !important;
    border: 1px solid rgba(124, 255, 122, 0.25) !important;
  }
</style>

<style>
  .editor-shell,
  .auth-guard {
    max-width: 860px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .post-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .meta-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(124, 255, 122, 0.6);
    text-transform: uppercase;
  }

  .thumbnail-row {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }

  .thumbnail-row input {
    flex: 1;
  }

  .pick-btn {
    flex: none;
    padding: 0.5rem 0.85rem;
    background: rgba(124, 255, 122, 0.08);
    color: rgba(124, 255, 122, 0.7);
    border: 1px solid rgba(124, 255, 122, 0.2);
    border-radius: 4px;
    font-size: 0.8rem;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 150ms, color 150ms;
  }

  .pick-btn:hover {
    background: rgba(124, 255, 122, 0.16);
    color: #7cff7a;
  }

  .thumb-picker {
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.5rem;
    margin-top: 0.5rem;
    max-height: 260px;
    overflow-y: auto;
    padding: 0.5rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(124, 255, 122, 0.15);
    border-radius: 6px;
  }

  .thumb-option {
    padding: 0;
    border: 2px solid transparent;
    border-radius: 4px;
    background: transparent;
    cursor: pointer;
    overflow: hidden;
    aspect-ratio: 16/9;
    transition: border-color 150ms;
  }

  .thumb-option img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-option:hover {
    border-color: rgba(124, 255, 122, 0.4);
  }

  .thumb-option--selected {
    border-color: #7cff7a !important;
  }

  select, input[type="text"] {
    background: rgba(0, 0, 0, 0.55);
    color: #d6ffd6;
    border: 1px solid rgba(124, 255, 122, 0.25);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    font-size: 0.95rem;
    width: 100%;
  }

  select { cursor: pointer; }
  select option { background: #0a0f14; }
  select:focus, input[type="text"]:focus { outline: none; border-color: rgba(124, 255, 122, 0.6); }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: flex-end;
  }

  #submit-status { font-size: 0.85rem; color: rgba(124, 255, 122, 0.7); }

  button[type="submit"] {
    background: rgba(124, 255, 122, 0.15);
    color: #7cff7a;
    border: 1px solid rgba(124, 255, 122, 0.4);
    border-radius: 4px;
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type="submit"]:hover:not(:disabled) { background: rgba(124, 255, 122, 0.28); }
  button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }

  .auth-guard {
    text-align: center;
    color: rgba(124, 255, 122, 0.6);
    padding-top: 6rem;
  }

  @media (max-width: 640px) {
    .meta-cols { grid-template-columns: 1fr; }
  }
</style>
