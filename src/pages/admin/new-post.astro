---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="글쓰기" noindex>
  <div class="editor-shell" id="editor-shell" style="display:none">
    <form class="post-form" id="post-form">
      <div class="meta-row">
        <div class="form-row">
          <label for="post-title">제목</label>
          <input type="text" id="post-title" name="title" required placeholder="포스트 제목" />
        </div>

        <div class="form-row">
          <label for="post-description">설명</label>
          <input type="text" id="post-description" name="description" required placeholder="한 줄 설명" />
        </div>

        <div class="meta-cols">
          <div class="form-row">
            <label for="post-category">카테고리</label>
            <select id="post-category" name="category">
              <option value="">없음</option>
            </select>
          </div>

          <div class="form-row">
            <label for="post-subcategory">하위 카테고리</label>
            <select id="post-subcategory" name="subcategory" disabled>
              <option value="">카테고리를 먼저 선택</option>
            </select>
            <p class="field-hint" id="post-subcategory-hint">상위 카테고리만 쓰려면 비워두면 됩니다.</p>
          </div>

          <div class="form-row">
            <label for="post-tags">태그</label>
            <input type="text" id="post-tags" name="tags" placeholder="쉼표로 구분 (예: iOS, Swift, Tips)" />
          </div>
        </div>

        <div class="form-row">
          <label for="post-thumbnail">썸네일 URL</label>
          <div class="thumbnail-row">
            <input type="text" id="post-thumbnail" name="thumbnail" placeholder="https://... 또는 아래에서 이미지 선택" />
            <button type="button" id="pick-thumb-btn" class="pick-btn">이미지에서 선택</button>
          </div>
          <div id="thumb-picker" class="thumb-picker" style="display:none"></div>
        </div>
      </div>

      <div class="form-row form-row--full">
        <label>내용</label>
        <div id="toast-editor"></div>
      </div>

      <div class="form-actions">
        <span id="submit-status"></span>
        <button type="button" id="preview-btn">미리보기</button>
        <button type="submit" id="submit-btn">커밋 & 발행</button>
      </div>

      <div id="actions-progress" style="display:none">
        <div id="actions-bar">
          <div id="actions-bar-fill"></div>
        </div>
        <a id="actions-link" href="https://github.com/achieveonepark/cording-blog/actions" target="_blank" rel="noreferrer">
          Actions 탭 열기 ↗
        </a>
      </div>

      <input type="hidden" id="edit-slug" value="" />
      <input type="hidden" id="edit-pubdate" value="" />
    </form>
  </div>

  <div class="auth-guard" id="auth-guard" style="display:none">
    <p>접근 권한이 없습니다.</p>
    <a href="/">홈으로</a>
  </div>
</BaseLayout>

<script>
  import Editor from "@toast-ui/editor";
  import "@toast-ui/editor/dist/toastui-editor.css";
  import "@toast-ui/editor/dist/theme/toastui-editor-dark.css";

  const OWNER = "achieveonepark";
  const REPO = "cording-blog";
  const BRANCH = "main";
  const CATEGORY_FILE_PATH = "src/data/categories.json";
  const SUBCATEGORY_FILE_PATH = "src/data/subcategories.json";

  const editorShell = document.getElementById("editor-shell") as HTMLElement;
  const authGuard = document.getElementById("auth-guard") as HTMLElement;
  const form = document.getElementById("post-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitStatus = document.getElementById("submit-status") as HTMLElement;

  let taxonomySubcategories: Record<string, string[]> = {};

  // --- GitHub API ---
  async function getExistingSha(path: string, token: string): Promise<string | null> {
    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );
    if (res.status === 404) return null;
    return (await res.json()).sha ?? null;
  }

  async function uploadImage(blob: Blob, token: string): Promise<string> {
    const ext = blob.type.split("/")[1] ?? "png";
    const filename = `${Date.now()}.${ext}`;
    const path = `public/images/${filename}`;

    const base64 = await new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve((reader.result as string).split(",")[1]);
      reader.onerror = reject;
      reader.readAsDataURL(blob);
    });

    const sha = await getExistingSha(path, token);
    const body: Record<string, unknown> = {
      message: `chore: upload image - ${filename}`,
      content: base64,
      branch: BRANCH,
    };
    if (sha) body.sha = sha;

    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      }
    );
    if (!res.ok) throw new Error((await res.json()).message ?? "이미지 업로드 실패");
    return `/images/${filename}`;
  }

  async function watchActions(token: string, slug: string, since: string): Promise<void> {
    const statusEl = document.getElementById("submit-status");
    const progressEl = document.getElementById("actions-progress");
    if (progressEl) progressEl.style.display = "flex";

    const labels: Record<string, string> = {
      queued: "빌드 대기 중...",
      in_progress: "빌드 중...",
      completed: "배포 완료!",
    };

    let runId: number | null = null;

    for (let i = 0; i < 60; i++) {
      await new Promise((r) => setTimeout(r, 5000));

      try {
        const res = await fetch(
          `https://api.github.com/repos/${OWNER}/${REPO}/actions/runs?branch=${BRANCH}&per_page=5`,
          { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
        );
        const data = await res.json();
        const runs: any[] = data.workflow_runs ?? [];

        // since 시점 이후 트리거된 run 찾기
        const run = runs.find((r: any) => new Date(r.created_at) >= new Date(since));
        if (!run) continue;

        runId = run.id;
        const status: string = run.status;
        const conclusion: string | null = run.conclusion;

        if (statusEl) statusEl.textContent = labels[status] ?? status;
        updateProgressBar(status, conclusion);

        if (status === "completed") {
          if (progressEl) progressEl.style.display = "none";
          if (conclusion === "success") {
            if (statusEl) statusEl.textContent = "배포 완료! 글 페이지로 이동합니다...";
            setTimeout(() => { window.location.href = `/posts/${slug}`; }, 1500);
          } else {
            if (statusEl) statusEl.textContent = `빌드 ${conclusion ?? "실패"}. Actions 탭을 확인해주세요.`;
          }
          return;
        }
      } catch { /* 무시하고 재시도 */ }
    }

    if (statusEl) statusEl.textContent = "배포 확인 시간 초과. GitHub Actions 탭을 직접 확인해주세요.";
    if (progressEl) progressEl.style.display = "none";
  }

  function updateProgressBar(status: string, conclusion: string | null) {
    const bar = document.getElementById("actions-bar-fill");
    if (!bar) return;
    if (status === "queued") bar.style.width = "20%";
    else if (status === "in_progress") bar.style.width = "65%";
    else if (status === "completed") bar.style.width = "100%";
    bar.dataset.conclusion = conclusion ?? "";
  }

  async function commitPost(token: string, filename: string, content: string): Promise<void> {
    const path = `src/content/blog/${filename}`;
    const sha = await getExistingSha(path, token);
    const body: Record<string, unknown> = {
      message: `feat: add post - ${filename.replace(".md", "")}`,
      content: btoa(unescape(encodeURIComponent(content))),
      branch: BRANCH,
    };
    if (sha) body.sha = sha;

    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      }
    );
    if (!res.ok) throw new Error((await res.json()).message ?? "GitHub API 오류");
  }

  // --- 유틸 ---
  function toSlug(title: string): string {
    return title.toLowerCase().trim()
      .replace(/[^a-z0-9가-힣\s-]/g, "")
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-");
  }

  function normalizeSubcategories(raw: unknown): Record<string, string[]> {
    if (!raw || typeof raw !== "object") return {};

    return Object.entries(raw as Record<string, unknown>).reduce<Record<string, string[]>>((acc, [category, value]) => {
      acc[category] = Array.isArray(value)
        ? value.map((item) => (typeof item === "string" ? item.trim() : "")).filter(Boolean)
        : [];
      return acc;
    }, {});
  }

  function normalizeFrontmatterValue(value?: string | null) {
    const trimmed = value?.trim() ?? "";
    if (!trimmed || trimmed === '""' || trimmed === "''") return "";

    const doubleQuotedMatch = trimmed.match(/^"(.*)"$/);
    if (doubleQuotedMatch) return doubleQuotedMatch[1];

    const singleQuotedMatch = trimmed.match(/^'(.*)'$/);
    if (singleQuotedMatch) return singleQuotedMatch[1];

    return trimmed;
  }

  function renderSubcategoryOptions(category: string, preferredSubcategory = "") {
    const select = document.getElementById("post-subcategory") as HTMLSelectElement;
    const hint = document.getElementById("post-subcategory-hint") as HTMLElement | null;
    const availableSubcategories = category ? (taxonomySubcategories[category] ?? []) : [];

    if (!category) {
      select.innerHTML = '<option value="">카테고리를 먼저 선택</option>';
      select.disabled = true;
      if (hint) hint.textContent = "상위 카테고리만 쓰려면 카테고리만 고르고 그대로 두면 됩니다.";
      return;
    }

    select.innerHTML = availableSubcategories.length === 0
      ? '<option value="">하위 카테고리 없음 - 상위 카테고리만 사용</option>'
      : '<option value="">상위 카테고리만 사용</option>';
    select.disabled = availableSubcategories.length === 0 && !preferredSubcategory;
    if (hint) {
      hint.textContent = availableSubcategories.length === 0
        ? "이 카테고리는 상위 카테고리만 사용됩니다."
        : "하위 카테고리가 필요할 때만 골라주세요. 비워두면 상위 카테고리만 저장됩니다.";
    }

    availableSubcategories.forEach((subcategory) => {
      const option = document.createElement("option");
      option.value = subcategory;
      option.textContent = subcategory;
      select.appendChild(option);
    });

    if (preferredSubcategory && !availableSubcategories.includes(preferredSubcategory)) {
      const option = document.createElement("option");
      option.value = preferredSubcategory;
      option.textContent = preferredSubcategory;
      select.appendChild(option);
    }

    select.value = preferredSubcategory && [...select.options].some((option) => option.value === preferredSubcategory)
      ? preferredSubcategory
      : "";
  }

  function buildFrontmatter(
    title: string,
    description: string,
    tags: string[],
    category: string,
    subcategory: string,
    thumbnail: string,
    pubDate?: string
  ): string {
    const date = pubDate ?? new Date().toISOString().split("T")[0];
    const tagLines = tags.length > 0
      ? "tags:\n" + tags.map((t) => `  - ${t.trim()}`).join("\n")
      : "tags: []";
    const catLine = category ? `\ncategory: ${category}` : "";
    const subcategoryLine = category ? `\nsubcategory: ${subcategory ? subcategory : '""'}` : "";
    const thumbLine = thumbnail ? `\nthumbnail: ${thumbnail}` : "";
    return `---\ntitle: "${title}"\ndescription: "${description}"\npubDate: ${date}\n${tagLines}${catLine}${subcategoryLine}${thumbLine}\n---\n\n`;
  }

  async function loadCategories(token: string) {
    const select = document.getElementById("post-category") as HTMLSelectElement;
    try {
      const [categoryResponse, subcategoryResponse] = await Promise.all([
        fetch(
          `https://api.github.com/repos/${OWNER}/${REPO}/contents/${CATEGORY_FILE_PATH}?ref=${BRANCH}`,
          { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
        ),
        fetch(
          `https://api.github.com/repos/${OWNER}/${REPO}/contents/${SUBCATEGORY_FILE_PATH}?ref=${BRANCH}`,
          { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
        ),
      ]);

      if (!categoryResponse.ok) return;

      const categoryData = await categoryResponse.json();
      const cats: string[] = JSON.parse(atob(categoryData.content.replace(/\n/g, "")));
      cats.forEach((cat) => {
        const opt = document.createElement("option");
        opt.value = cat; opt.textContent = cat;
        select.appendChild(opt);
      });

      if (subcategoryResponse.ok) {
        const subcategoryData = await subcategoryResponse.json();
        taxonomySubcategories = normalizeSubcategories(JSON.parse(atob(subcategoryData.content.replace(/\n/g, ""))));
      }
    } catch {}

    renderSubcategoryOptions(select.value);
  }

  async function loadEditContent(slug: string, token: string, editor: Editor) {
    const path = `src/content/blog/${slug}.md`;
    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );
    if (!res.ok) return;
    const data = await res.json();
    const raw = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));

    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n\n?([\s\S]*)$/);
    if (!fmMatch) return;
    const fm = fmMatch[1];
    const body = fmMatch[2];

    const titleMatch = fm.match(/^title:\s*"?(.+?)"?\s*$/m);
    const descMatch = fm.match(/^description:\s*"?(.+?)"?\s*$/m);
    const categoryMatch = fm.match(/^category:\s*(.+)\s*$/m);
    const subcategoryMatch = fm.match(/^subcategory:\s*(.+)\s*$/m);
    const thumbMatch = fm.match(/^thumbnail:\s*(.+)\s*$/m);
    const pubDateMatch = fm.match(/^pubDate:\s*(.+)\s*$/m);
    const tagsMatch = [...fm.matchAll(/^\s*-\s*(.+)\s*$/gm)].map((m) => m[1]);

    (document.getElementById("post-title") as HTMLInputElement).value = titleMatch?.[1] ?? "";
    (document.getElementById("post-description") as HTMLInputElement).value = descMatch?.[1] ?? "";
    (document.getElementById("post-tags") as HTMLInputElement).value = tagsMatch.join(", ");
    (document.getElementById("post-thumbnail") as HTMLInputElement).value = thumbMatch?.[1]?.trim() ?? "";
    editor.setMarkdown(body);

    const catVal = normalizeFrontmatterValue(categoryMatch?.[1]);
    const subcategoryVal = normalizeFrontmatterValue(subcategoryMatch?.[1]);
    const select = document.getElementById("post-category") as HTMLSelectElement;
    if (catVal) {
      if (![...select.options].some((o) => o.value === catVal)) {
        const opt = document.createElement("option");
        opt.value = catVal; opt.textContent = catVal;
        select.appendChild(opt);
      }
      select.value = catVal;
    }
    renderSubcategoryOptions(catVal, subcategoryVal);
    (document.getElementById("edit-slug") as HTMLInputElement).value = slug;
    (document.getElementById("edit-pubdate") as HTMLInputElement).value = pubDateMatch?.[1]?.trim() ?? "";
    (document.getElementById("submit-btn") as HTMLButtonElement).textContent = "수정 & 발행";
    document.title = "글 수정";
  }

  // --- 진입점 ---
  (async () => {
    const token = localStorage.getItem("gh_token");
    if (!token) { authGuard.style.display = ""; return; }

    const userRes = await fetch("https://api.github.com/user", {
      headers: { Authorization: `Bearer ${token}` },
    });
    const user = await userRes.json();
    if (user.login !== OWNER) {
      localStorage.removeItem("gh_token");
      authGuard.style.display = "";
      return;
    }

    editorShell.style.display = "";

    // Toast UI Editor 초기화
    const editor = new Editor({
      el: document.getElementById("toast-editor") as HTMLElement,
      height: "600px",
      initialEditType: "wysiwyg",
      previewStyle: "vertical",
      theme: "dark",
      placeholder: "내용을 입력하세요...",
      hooks: {
        addImageBlobHook: async (blob, callback) => {
          try {
            const url = await uploadImage(blob, token);
            callback(url, "image");
          } catch (err) {
            alert(`이미지 업로드 실패: ${err instanceof Error ? err.message : String(err)}`);
          }
        },
      },
    });

    await loadCategories(token);

    const editSlug = new URLSearchParams(window.location.search).get("edit");
    if (editSlug) await loadEditContent(editSlug, token, editor);

    // ── 자동 저장 ──────────────────────────────────────────
    const DRAFT_KEY = editSlug ? `admin-draft:${editSlug}` : "admin-draft:new";

    function collectDraft() {
      return {
        title:       (document.getElementById("post-title") as HTMLInputElement).value,
        description: (document.getElementById("post-description") as HTMLInputElement).value,
        tags:        (document.getElementById("post-tags") as HTMLInputElement).value,
        category:    (document.getElementById("post-category") as HTMLSelectElement).value,
        subcategory: (document.getElementById("post-subcategory") as HTMLSelectElement).value,
        thumbnail:   (document.getElementById("post-thumbnail") as HTMLInputElement).value,
        markdown:    editor.getMarkdown(),
        savedAt:     new Date().toISOString(),
      };
    }

    function restoreDraft(data: ReturnType<typeof collectDraft>) {
      (document.getElementById("post-title") as HTMLInputElement).value       = data.title       ?? "";
      (document.getElementById("post-description") as HTMLInputElement).value = data.description ?? "";
      (document.getElementById("post-tags") as HTMLInputElement).value        = data.tags        ?? "";
      (document.getElementById("post-thumbnail") as HTMLInputElement).value   = data.thumbnail   ?? "";
      editor.setMarkdown(data.markdown ?? "");
      const catSel = document.getElementById("post-category") as HTMLSelectElement;
      if (data.category) catSel.value = data.category;
      renderSubcategoryOptions(catSel.value, data.subcategory ?? "");
    }

    // 저장된 초안 복원 제안 (새 글 작성 시에만)
    if (!editSlug) {
      const saved = localStorage.getItem(DRAFT_KEY);
      if (saved) {
        try {
          const data = JSON.parse(saved) as ReturnType<typeof collectDraft>;
          const when = new Date(data.savedAt).toLocaleString("ko-KR");
          if (data.title && confirm(`"${data.title}" 초안이 있습니다 (${when}).\n복원할까요?`)) {
            restoreDraft(data);
          } else {
            localStorage.removeItem(DRAFT_KEY);
          }
        } catch { localStorage.removeItem(DRAFT_KEY); }
      }
    }

    // 자동 저장 (3초 디바운스)
    let autoSaveTimer: ReturnType<typeof setTimeout>;
    const autoSaveIndicator = submitStatus;

    function scheduleSave() {
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(() => {
        localStorage.setItem(DRAFT_KEY, JSON.stringify(collectDraft()));
        const prev = autoSaveIndicator.textContent;
        autoSaveIndicator.textContent = "자동 저장됨";
        setTimeout(() => { if (autoSaveIndicator.textContent === "자동 저장됨") autoSaveIndicator.textContent = prev ?? ""; }, 2000);
      }, 3000);
    }

    ["post-title","post-description","post-tags","post-thumbnail"].forEach(id => {
      document.getElementById(id)?.addEventListener("input", scheduleSave);
    });
    document.getElementById("post-category")?.addEventListener("change", () => {
      const category = (document.getElementById("post-category") as HTMLSelectElement).value;
      renderSubcategoryOptions(category);
      scheduleSave();
    });
    document.getElementById("post-subcategory")?.addEventListener("change", scheduleSave);
    editor.on("change", scheduleSave);

    // 발행 성공 시 초안 제거
    form.addEventListener("submit", () => {
      localStorage.removeItem(DRAFT_KEY);
    }, { capture: true });

    // ── 대표 사진 선택 ────────────────────────────────────────
    const pickBtn = document.getElementById("pick-thumb-btn") as HTMLButtonElement;
    const thumbPicker = document.getElementById("thumb-picker") as HTMLDivElement;
    const thumbInput = document.getElementById("post-thumbnail") as HTMLInputElement;

    pickBtn.addEventListener("click", () => {
      const md = editor.getMarkdown();
      const matches = [...md.matchAll(/!\[.*?\]\(([^)]+)\)/g)].map(m => m[1]);
      const unique = [...new Set(matches)];

      if (!unique.length) {
        thumbPicker.style.display = "none";
        alert("에디터에 이미지가 없습니다. 이미지를 먼저 추가해주세요.");
        return;
      }

      const isOpen = thumbPicker.style.display !== "none";
      if (isOpen) { thumbPicker.style.display = "none"; return; }

      thumbPicker.innerHTML = unique.map(url => `
        <button type="button" class="thumb-option ${thumbInput.value === url ? "thumb-option--selected" : ""}" data-url="${url}">
          <img src="${url}" alt="" loading="lazy" />
        </button>
      `).join("");

      thumbPicker.querySelectorAll(".thumb-option").forEach(btn => {
        btn.addEventListener("click", () => {
          const url = (btn as HTMLElement).dataset.url ?? "";
          thumbInput.value = url;
          thumbPicker.querySelectorAll(".thumb-option").forEach(b => b.classList.remove("thumb-option--selected"));
          btn.classList.add("thumb-option--selected");
        });
      });

      thumbPicker.style.display = "grid";
    });

    // 미리보기 버튼
    document.getElementById("preview-btn")?.addEventListener("click", () => {
      const slug = (document.getElementById("edit-slug") as HTMLInputElement).value;
      if (slug) {
        window.open(`/admin/preview?slug=${encodeURIComponent(slug)}`, "_blank");
      } else {
        alert("미리보기는 커밋 후 slug가 생긴 글에서만 사용할 수 있습니다.\n한 번 커밋하고 수정 모드로 다시 열어보세요.");
      }
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const title = (document.getElementById("post-title") as HTMLInputElement).value.trim();
      const description = (document.getElementById("post-description") as HTMLInputElement).value.trim();
      const tagsRaw = (document.getElementById("post-tags") as HTMLInputElement).value;
      const tags = tagsRaw ? tagsRaw.split(",").map((t) => t.trim()).filter(Boolean) : [];
      const category = (document.getElementById("post-category") as HTMLSelectElement).value;
      const subcategory = category
        ? (document.getElementById("post-subcategory") as HTMLSelectElement).value
        : "";
      const thumbnail = (document.getElementById("post-thumbnail") as HTMLInputElement).value.trim();
      const editSlug = (document.getElementById("edit-slug") as HTMLInputElement).value;
      const editPubDate = (document.getElementById("edit-pubdate") as HTMLInputElement).value;
      const slug = editSlug || toSlug(title);
      const markdown = editor.getMarkdown();
      const fileContent = buildFrontmatter(
        title,
        description,
        tags,
        category,
        subcategory,
        thumbnail,
        editPubDate || undefined
      ) + markdown;

      submitBtn.disabled = true;
      submitStatus.textContent = "커밋 중...";

      try {
        const commitTime = new Date().toISOString();
        await commitPost(token, `${slug}.md`, fileContent);
        submitStatus.textContent = "커밋 완료! Actions 대기 중...";
        submitBtn.disabled = false;
        await watchActions(token, slug, commitTime);
      } catch (err) {
        submitStatus.textContent = `오류: ${err instanceof Error ? err.message : String(err)}`;
        submitBtn.disabled = false;
      }
    });
  })();
</script>

