---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="글쓰기">
  <div class="editor-shell" id="editor-shell" style="display:none">
    <form class="post-form" id="post-form">
      <div class="meta-row">
        <div class="form-row">
          <label for="post-title">제목</label>
          <input type="text" id="post-title" name="title" required placeholder="포스트 제목" />
        </div>

        <div class="form-row">
          <label for="post-description">설명</label>
          <input type="text" id="post-description" name="description" required placeholder="한 줄 설명" />
        </div>

        <div class="meta-cols">
          <div class="form-row">
            <label for="post-category">카테고리</label>
            <select id="post-category" name="category">
              <option value="">없음</option>
            </select>
          </div>

          <div class="form-row">
            <label for="post-tags">태그</label>
            <input type="text" id="post-tags" name="tags" placeholder="쉼표로 구분 (예: iOS, Swift, Tips)" />
          </div>
        </div>
      </div>

      <div class="form-row form-row--full">
        <div class="content-toolbar">
          <div class="toolbar-left">
            <button type="button" id="img-upload-btn" class="toolbar-btn" title="이미지 업로드">
              <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.8"/>
                <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/>
                <path d="M21 15l-5-5L5 21" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
              </svg>
              이미지
            </button>
            <input type="file" id="img-file-input" accept="image/*" style="display:none" />
            <span id="img-status" class="img-status"></span>
          </div>
          <div class="view-tabs">
            <button type="button" class="view-tab view-tab--active" data-tab="write">편집</button>
            <button type="button" class="view-tab" data-tab="preview">미리보기</button>
          </div>
        </div>

        <div class="content-area">
          <div id="write-pane" class="write-pane">
            <div class="textarea-wrap" id="textarea-wrap">
              <textarea id="post-content" name="content" rows="30" placeholder="마크다운으로 작성하세요... 이미지는 드래그&드롭도 가능해요."></textarea>
              <div class="drop-overlay" id="drop-overlay">이미지를 여기에 놓으세요</div>
            </div>
          </div>
          <div id="preview-pane" class="preview-pane" style="display:none">
            <div id="preview-body"></div>
          </div>
        </div>
      </div>

      <div class="form-actions">
        <span id="submit-status"></span>
        <button type="submit" id="submit-btn">커밋 & 발행</button>
      </div>

      <input type="hidden" id="edit-slug" value="" />
    </form>
  </div>

  <div class="auth-guard" id="auth-guard" style="display:none">
    <p>접근 권한이 없습니다.</p>
    <a href="/">홈으로</a>
  </div>
</BaseLayout>

<script>
  import { marked } from "marked";

  const OWNER = "achieveonepark";
  const REPO = "cording-blog";
  const BRANCH = "main";

  const editorShell = document.getElementById("editor-shell") as HTMLElement;
  const authGuard = document.getElementById("auth-guard") as HTMLElement;
  const form = document.getElementById("post-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const submitStatus = document.getElementById("submit-status") as HTMLElement;
  const textarea = document.getElementById("post-content") as HTMLTextAreaElement;
  const previewBody = document.getElementById("preview-body") as HTMLElement;
  const writePane = document.getElementById("write-pane") as HTMLElement;
  const previewPane = document.getElementById("preview-pane") as HTMLElement;

  // 탭 전환
  document.querySelectorAll<HTMLButtonElement>(".view-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".view-tab").forEach((t) => t.classList.remove("view-tab--active"));
      tab.classList.add("view-tab--active");

      if (tab.dataset.tab === "preview") {
        previewBody.innerHTML = marked.parse(textarea.value || "_내용 없음_") as string;
        writePane.style.display = "none";
        previewPane.style.display = "";
      } else {
        writePane.style.display = "";
        previewPane.style.display = "none";
      }
    });
  });

  // --- 유틸 ---
  function toSlug(title: string): string {
    return title
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9가-힣\s-]/g, "")
      .replace(/\s+/g, "-")
      .replace(/-+/g, "-");
  }

  function buildFrontmatter(title: string, description: string, tags: string[], category: string): string {
    const today = new Date().toISOString().split("T")[0];
    const tagLines = tags.length > 0
      ? "tags:\n" + tags.map((t) => `  - ${t.trim()}`).join("\n")
      : "tags: []";
    const catLine = category ? `\ncategory: ${category}` : "";
    return `---\ntitle: "${title}"\ndescription: "${description}"\npubDate: ${today}\n${tagLines}${catLine}\n---\n\n`;
  }

  async function getExistingSha(path: string, token: string): Promise<string | null> {
    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );
    if (res.status === 404) return null;
    const data = await res.json();
    return data.sha ?? null;
  }

  async function commitPost(token: string, filename: string, content: string): Promise<void> {
    const path = `src/content/blog/${filename}`;
    const sha = await getExistingSha(path, token);

    const body: Record<string, unknown> = {
      message: `feat: add post - ${filename.replace(".md", "")}`,
      content: btoa(unescape(encodeURIComponent(content))),
      branch: BRANCH,
    };
    if (sha) body.sha = sha;

    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      }
    );

    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.message ?? "GitHub API 오류");
    }
  }

  async function uploadImage(file: File, token: string): Promise<string> {
    const ext = file.name.split(".").pop()?.toLowerCase() ?? "png";
    const safeName = file.name.replace(/\.[^.]+$/, "").replace(/[^a-z0-9가-힣-]/gi, "-").toLowerCase();
    const filename = `${Date.now()}-${safeName}.${ext}`;
    const path = `public/images/${filename}`;

    const base64 = await new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve((reader.result as string).split(",")[1]);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });

    const sha = await getExistingSha(path, token);
    const body: Record<string, unknown> = {
      message: `chore: upload image - ${filename}`,
      content: base64,
      branch: BRANCH,
    };
    if (sha) body.sha = sha;

    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(body),
      }
    );
    if (!res.ok) {
      const err = await res.json();
      throw new Error(err.message ?? "이미지 업로드 실패");
    }
    return `/images/${filename}`;
  }

  function insertAtCursor(el: HTMLTextAreaElement, text: string) {
    const s = el.selectionStart;
    const e = el.selectionEnd;
    el.value = el.value.slice(0, s) + text + el.value.slice(e);
    el.selectionStart = el.selectionEnd = s + text.length;
    el.focus();
  }

  function setupImageUpload() {
    const token = localStorage.getItem("gh_token");
    const fileInput = document.getElementById("img-file-input") as HTMLInputElement;
    const uploadBtn = document.getElementById("img-upload-btn") as HTMLButtonElement;
    const imgStatus = document.getElementById("img-status") as HTMLElement;
    const dropOverlay = document.getElementById("drop-overlay") as HTMLElement;
    const textareaWrap = document.getElementById("textarea-wrap") as HTMLElement;

    async function handleFile(file: File) {
      if (!token) return;
      if (!file.type.startsWith("image/")) { imgStatus.textContent = "이미지 파일만 가능합니다."; return; }
      uploadBtn.disabled = true;
      imgStatus.textContent = "업로드 중...";
      try {
        const url = await uploadImage(file, token);
        insertAtCursor(textarea, `![${file.name.replace(/\.[^.]+$/, "")}](${url})`);
        imgStatus.textContent = "업로드 완료!";
        setTimeout(() => { imgStatus.textContent = ""; }, 2000);
      } catch (err) {
        imgStatus.textContent = `오류: ${err instanceof Error ? err.message : String(err)}`;
      } finally {
        uploadBtn.disabled = false;
        fileInput.value = "";
      }
    }

    uploadBtn.addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", () => { if (fileInput.files?.[0]) handleFile(fileInput.files[0]); });

    textareaWrap.addEventListener("dragover", (e) => { e.preventDefault(); dropOverlay.classList.add("visible"); });
    textareaWrap.addEventListener("dragleave", (e) => {
      if (!textareaWrap.contains(e.relatedTarget as Node)) dropOverlay.classList.remove("visible");
    });
    textareaWrap.addEventListener("drop", (e) => {
      e.preventDefault();
      dropOverlay.classList.remove("visible");
      const file = e.dataTransfer?.files[0];
      if (file) handleFile(file);
    });
  }

  async function loadCategories(token: string) {
    const select = document.getElementById("post-category") as HTMLSelectElement;
    try {
      const res = await fetch(
        `https://api.github.com/repos/${OWNER}/${REPO}/contents/src/data/categories.json?ref=${BRANCH}`,
        { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
      );
      if (!res.ok) return;
      const data = await res.json();
      const cats: string[] = JSON.parse(atob(data.content.replace(/\n/g, "")));
      cats.forEach((cat) => {
        const opt = document.createElement("option");
        opt.value = cat; opt.textContent = cat;
        select.appendChild(opt);
      });
    } catch {}
  }

  async function loadEditContent(slug: string, token: string) {
    const path = `src/content/blog/${slug}.md`;
    const res = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
      { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
    );
    if (!res.ok) return;
    const data = await res.json();
    const raw = decodeURIComponent(escape(atob(data.content.replace(/\n/g, ""))));

    const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n\n?([\s\S]*)$/);
    if (!fmMatch) return;
    const fm = fmMatch[1];
    const body = fmMatch[2];

    const titleMatch = fm.match(/^title:\s*"?(.+?)"?\s*$/m);
    const descMatch = fm.match(/^description:\s*"?(.+?)"?\s*$/m);
    const categoryMatch = fm.match(/^category:\s*(.+)\s*$/m);
    const tagsMatch = [...fm.matchAll(/^\s*-\s*(.+)\s*$/gm)].map((m) => m[1]);

    (document.getElementById("post-title") as HTMLInputElement).value = titleMatch?.[1] ?? "";
    (document.getElementById("post-description") as HTMLInputElement).value = descMatch?.[1] ?? "";
    (document.getElementById("post-tags") as HTMLInputElement).value = tagsMatch.join(", ");
    textarea.value = body;

    const catVal = categoryMatch?.[1]?.trim() ?? "";
    const select = document.getElementById("post-category") as HTMLSelectElement;
    if (catVal) {
      if (![...select.options].some((o) => o.value === catVal)) {
        const opt = document.createElement("option");
        opt.value = catVal; opt.textContent = catVal;
        select.appendChild(opt);
      }
      select.value = catVal;
    }
    (document.getElementById("edit-slug") as HTMLInputElement).value = slug;
    (document.getElementById("submit-btn") as HTMLButtonElement).textContent = "수정 & 발행";
    document.title = "글 수정";
  }

  (async () => {
    const token = localStorage.getItem("gh_token");
    if (!token) { authGuard.style.display = ""; return; }

    const userRes = await fetch("https://api.github.com/user", {
      headers: { Authorization: `Bearer ${token}` },
    });
    const user = await userRes.json();

    if (user.login !== OWNER) {
      localStorage.removeItem("gh_token");
      authGuard.style.display = "";
      return;
    }

    editorShell.style.display = "";
    setupImageUpload();
    await loadCategories(token);

    const editSlug = new URLSearchParams(window.location.search).get("edit");
    if (editSlug) await loadEditContent(editSlug, token);
  })();

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const token = localStorage.getItem("gh_token");
    if (!token) return;

    const title = (document.getElementById("post-title") as HTMLInputElement).value.trim();
    const description = (document.getElementById("post-description") as HTMLInputElement).value.trim();
    const tagsRaw = (document.getElementById("post-tags") as HTMLInputElement).value;
    const body = textarea.value;
    const tags = tagsRaw ? tagsRaw.split(",").map((t) => t.trim()).filter(Boolean) : [];
    const category = (document.getElementById("post-category") as HTMLSelectElement).value;
    const editSlug = (document.getElementById("edit-slug") as HTMLInputElement).value;
    const slug = editSlug || toSlug(title);
    const fileContent = buildFrontmatter(title, description, tags, category) + body;

    submitBtn.disabled = true;
    submitStatus.textContent = "커밋 중...";

    try {
      await commitPost(token, `${slug}.md`, fileContent);
      submitStatus.textContent = editSlug ? "수정 완료! 배포 중..." : "발행 완료! 배포 중...";
      submitBtn.disabled = false;
    } catch (err) {
      submitStatus.textContent = `오류: ${err instanceof Error ? err.message : String(err)}`;
      submitBtn.disabled = false;
    }
  });
</script>

<!-- 미리보기 prose 스타일 (동적 innerHTML에 적용되므로 is:global 필요) -->
<style is:global>
  #preview-body {
    color: var(--text, #c8d8c8);
    font-size: 1rem;
    line-height: 1.78;
  }

  #preview-body h1,
  #preview-body h2,
  #preview-body h3,
  #preview-body h4 {
    color: #e8f8e8;
    font-weight: 700;
    line-height: 1.3;
    margin: 1.5em 0 0.5em;
  }

  #preview-body h1 { font-size: 1.75rem; }
  #preview-body h2 { font-size: 1.35rem; border-bottom: 1px solid rgba(124,255,122,0.15); padding-bottom: 0.3em; }
  #preview-body h3 { font-size: 1.1rem; }
  #preview-body h4 { font-size: 0.95rem; }

  #preview-body p { margin: 0.85em 0; }

  #preview-body a { color: #7cff7a; text-decoration: underline; text-decoration-color: rgba(124,255,122,0.35); }
  #preview-body strong { color: #e8f8e8; font-weight: 700; }
  #preview-body em { color: #c0e8c0; font-style: italic; }

  #preview-body code {
    font-family: monospace;
    font-size: 0.85em;
    background: rgba(124, 255, 122, 0.08);
    border: 1px solid rgba(124, 255, 122, 0.18);
    border-radius: 3px;
    padding: 0.15em 0.4em;
    color: #a8f0a8;
  }

  #preview-body pre {
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(124, 255, 122, 0.18);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1em 0;
  }

  #preview-body pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: #c8f0c8;
  }

  #preview-body blockquote {
    border-left: 3px solid rgba(124, 255, 122, 0.4);
    padding-left: 1em;
    margin: 1em 0;
    color: rgba(200, 240, 200, 0.7);
    font-style: italic;
  }

  #preview-body ul, #preview-body ol { padding-left: 1.5em; margin: 0.75em 0; }
  #preview-body li { margin: 0.3em 0; }

  #preview-body hr { border: none; border-top: 1px solid rgba(124, 255, 122, 0.18); margin: 1.5em 0; }
  #preview-body img { max-width: 100%; border-radius: 6px; margin: 0.75em 0; }

  #preview-body table { width: 100%; border-collapse: collapse; margin: 1em 0; font-size: 0.9em; }
  #preview-body th, #preview-body td { border: 1px solid rgba(124, 255, 122, 0.2); padding: 0.5em 0.75em; text-align: left; }
  #preview-body th { background: rgba(124, 255, 122, 0.07); color: #e8f8e8; }
</style>

<style>
  .editor-shell,
  .auth-guard {
    max-width: 860px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .post-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .meta-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .meta-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .content-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    gap: 0.75rem;
  }

  .toolbar-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .view-tabs {
    display: flex;
    border: 1px solid rgba(124, 255, 122, 0.2);
    border-radius: 6px;
    overflow: hidden;
  }

  .view-tab {
    padding: 0.3rem 0.85rem;
    background: transparent;
    border: none;
    color: rgba(124, 255, 122, 0.45);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 150ms, color 150ms;
  }

  .view-tab + .view-tab {
    border-left: 1px solid rgba(124, 255, 122, 0.2);
  }

  .view-tab--active {
    background: rgba(124, 255, 122, 0.12);
    color: #7cff7a;
  }

  .content-area {
    width: 100%;
  }

  .write-pane {
    width: 100%;
  }

  .textarea-wrap {
    position: relative;
  }

  .write-pane textarea {
    width: 100%;
    resize: vertical;
    font-family: var(--font-mono, monospace);
    font-size: 0.875rem;
    background: rgba(0, 0, 0, 0.55);
    color: #d6ffd6;
    border: 1px solid rgba(124, 255, 122, 0.25);
    border-radius: 6px;
    padding: 0.75rem;
    line-height: 1.6;
  }

  .write-pane textarea:focus {
    outline: none;
    border-color: rgba(124, 255, 122, 0.6);
  }

  .drop-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    border: 2px dashed rgba(124, 255, 122, 0.5);
    background: rgba(5, 10, 14, 0.88);
    color: #7cff7a;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    opacity: 0;
    pointer-events: none;
    transition: opacity 150ms;
  }

  .drop-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .preview-pane {
    min-height: 400px;
    border: 1px solid rgba(124, 255, 122, 0.18);
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.3);
    padding: 1.25rem 1.5rem;
  }

  .toolbar-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.2);
    background: transparent;
    color: rgba(124, 255, 122, 0.6);
    font-size: 0.75rem;
    cursor: pointer;
    transition: border-color 150ms, background 150ms, color 150ms;
  }

  .toolbar-btn:hover:not(:disabled) {
    border-color: rgba(124, 255, 122, 0.45);
    background: rgba(124, 255, 122, 0.07);
    color: #7cff7a;
  }

  .toolbar-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  .img-status { font-size: 0.78rem; color: rgba(124, 255, 122, 0.6); }

  label {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: rgba(124, 255, 122, 0.6);
    text-transform: uppercase;
  }

  select, input[type="text"] {
    background: rgba(0, 0, 0, 0.55);
    color: #d6ffd6;
    border: 1px solid rgba(124, 255, 122, 0.25);
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
    font-size: 0.95rem;
    width: 100%;
  }

  select { cursor: pointer; }
  select option { background: #0a0f14; }
  select:focus, input[type="text"]:focus { outline: none; border-color: rgba(124, 255, 122, 0.6); }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: flex-end;
  }

  #submit-status { font-size: 0.85rem; color: rgba(124, 255, 122, 0.7); }

  button[type="submit"] {
    background: rgba(124, 255, 122, 0.15);
    color: #7cff7a;
    border: 1px solid rgba(124, 255, 122, 0.4);
    border-radius: 4px;
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type="submit"]:hover:not(:disabled) { background: rgba(124, 255, 122, 0.28); }
  button[type="submit"]:disabled { opacity: 0.5; cursor: not-allowed; }

  .auth-guard {
    text-align: center;
    color: rgba(124, 255, 122, 0.6);
    padding-top: 6rem;
  }

  @media (max-width: 640px) {
    .meta-cols { grid-template-columns: 1fr; }
    .content-toolbar { flex-wrap: wrap; }
  }
</style>
