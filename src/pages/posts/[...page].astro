---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  BLOG_LANGS,
  type BlogLang,
  filterPostsByLang,
  getPublishedPosts
} from "../../lib/blog";
import categories from "../../data/categories.json";

function getPostsPageUrl(pageNumber: number) {
  return pageNumber <= 1 ? "/posts/" : `/posts/${pageNumber}/`;
}

function buildPageData<T>(posts: T[], pageNumber: number, pageSize: number) {
  const lastPage = Math.max(1, Math.ceil(posts.length / pageSize));
  const hasPage = pageNumber <= lastPage;
  const start = (pageNumber - 1) * pageSize;

  return {
    data: hasPage ? posts.slice(start, start + pageSize) : [],
    currentPage: pageNumber,
    lastPage,
    hasPage,
    url: {
      prev: pageNumber > 1 ? getPostsPageUrl(Math.min(pageNumber - 1, lastPage)) : null,
      next: pageNumber < lastPage ? getPostsPageUrl(pageNumber + 1) : null
    }
  };
}

export async function getStaticPaths() {
  const pageSize = 10;
  const allPosts = await getPublishedPosts();
  const postsByLang = {
    ko: filterPostsByLang(allPosts, "ko"),
    en: filterPostsByLang(allPosts, "en")
  };

  const maxPages = Math.max(
    ...BLOG_LANGS.map((lang) => Math.max(1, Math.ceil(postsByLang[lang].length / pageSize)))
  );

  const categoryCountsByLang = BLOG_LANGS.reduce((acc, lang) => {
    acc[lang] = categories.reduce<Record<string, number>>((counts, category) => {
      counts[category] = postsByLang[lang].filter((post) => post.data.category === category).length;
      return counts;
    }, {});
    return acc;
  }, {} as Record<BlogLang, Record<string, number>>);

  return Array.from({ length: maxPages }, (_, index) => {
    const pageNumber = index + 1;

    return {
      params: { page: pageNumber === 1 ? undefined : String(pageNumber) },
      props: {
        pageNumber,
        pages: {
          ko: buildPageData(postsByLang.ko, pageNumber, pageSize),
          en: buildPageData(postsByLang.en, pageNumber, pageSize)
        },
        postsByLang,
        categoryCountsByLang
      }
    };
  });
}

type PublishedPost = Awaited<ReturnType<typeof getPublishedPosts>>[number];
type PaginatedPosts = {
  data: PublishedPost[];
  currentPage: number;
  lastPage: number;
  hasPage: boolean;
  url: {
    prev: string | null;
    next: string | null;
  };
};

const { pageNumber, pages, postsByLang, categoryCountsByLang } = Astro.props as {
  pageNumber: number;
  pages: Record<BlogLang, PaginatedPosts>;
  postsByLang: Record<BlogLang, Awaited<ReturnType<typeof getPublishedPosts>>>;
  categoryCountsByLang: Record<BlogLang, Record<string, number>>;
};
---

<BaseLayout title="Posts" description="A complete list of Somiri blog posts.">
  <Header />

  <main class="shell app-shell">
    <section class="app-panel">
      {BLOG_LANGS.map((lang) => {
        const page = pages[lang];
        const currentPosts = page.data;
        const allPosts = postsByLang[lang];

        return (
          <div data-ui-lang={lang} data-posts-page>
            <div class="section-heading">
              <p class="eyebrow">{lang === "en" ? "Posts" : "글"}</p>
              <h1>{lang === "en" ? "All Posts" : "모든 글"}</h1>
              <p>
                {lang === "en"
                  ? "A chronological stream of every published entry."
                  : "저장된 글을 시간순으로 훑을 수 있는 전체 스트림입니다."}
              </p>
            </div>

            <div class="category-filter" data-category-filter role="group" aria-label={lang === "en" ? "Category filter" : "카테고리 필터"}>
              <button class="cat-btn cat-btn--active" data-cat="">
                {lang === "en" ? "All" : "전체"} <span class="cat-count">{allPosts.length}</span>
              </button>
              {categories.map((category) => (
                <button class="cat-btn" data-cat={category}>
                  {category}
                  {categoryCountsByLang[lang][category] > 0 && (
                    <span class="cat-count">{categoryCountsByLang[lang][category]}</span>
                  )}
                </button>
              ))}
            </div>

            {page.hasPage ? (
              <div class="post-stack" data-post-stack>
                {currentPosts.map((post) => <PostCard post={post} />)}
              </div>
            ) : (
              <p class="empty">
                {lang === "en" ? "No posts are available on this page." : "이 페이지에는 표시할 글이 없습니다."}
              </p>
            )}

            {page.lastPage > 1 && (
              <nav class="pagination" aria-label={lang === "en" ? "Pagination" : "페이지 네비게이션"}>
                {page.url.prev ? (
                  <a href={page.url.prev} class="pagination__btn">{lang === "en" ? "← Prev" : "← 이전"}</a>
                ) : (
                  <span class="pagination__btn pagination__btn--disabled">{lang === "en" ? "← Prev" : "← 이전"}</span>
                )}

                <div class="pagination__pages">
                  {Array.from({ length: page.lastPage }, (_, index) => index + 1).map((num) => (
                    <a
                      href={getPostsPageUrl(num)}
                      class:list={["pagination__page", { "pagination__page--current": num === pageNumber }]}
                      aria-current={num === pageNumber ? "page" : undefined}
                    >
                      {num}
                    </a>
                  ))}
                </div>

                {page.url.next ? (
                  <a href={page.url.next} class="pagination__btn">{lang === "en" ? "Next →" : "다음 →"}</a>
                ) : (
                  <span class="pagination__btn pagination__btn--disabled">{lang === "en" ? "Next →" : "다음 →"}</span>
                )}
              </nav>
            )}
          </div>
        );
      })}
    </section>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  if (!window.__catFilterInit) {
    window.__catFilterInit = true;
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.cat-btn');
      if (!btn) return;

      var pageSection = btn.closest('[data-posts-page]');
      if (!pageSection) return;

      var group = pageSection.querySelector('[data-category-filter]');
      var stack = pageSection.querySelector('[data-post-stack]');
      if (!group || !stack) return;

      var btns = group.querySelectorAll('.cat-btn');
      var cards = stack.querySelectorAll('.post-card');

      btns.forEach(function(b) { b.classList.remove('cat-btn--active'); });
      btn.classList.add('cat-btn--active');

      var cat = btn.dataset.cat || '';
      cards.forEach(function(card) {
        var match = !cat || card.dataset.category === cat;
        card.style.display = match ? '' : 'none';
      });
    });
  }
</script>

<style>
  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .cat-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: border-color 150ms, background 150ms, color 150ms;
  }

  .cat-btn:hover {
    border-color: var(--accent);
    color: var(--text);
  }

  .cat-btn--active {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent);
  }

  .cat-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.2rem;
    height: 1.2rem;
    padding: 0 0.3rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
  }

  .cat-btn--active .cat-count {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .empty {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .pagination__btn {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--panel-soft);
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 150ms, color 150ms;
  }

  .pagination__btn:not(.pagination__btn--disabled):hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pagination__btn--disabled {
    opacity: 0.35;
    cursor: default;
  }

  .pagination__pages {
    display: flex;
    gap: 0.35rem;
  }

  .pagination__page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--panel-soft);
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 150ms, background 150ms, color 150ms;
  }

  .pagination__page:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .pagination__page--current {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent);
  }
</style>
