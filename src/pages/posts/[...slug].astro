---
import { render, type CollectionEntry } from "astro:content";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TOC from "../../components/TOC.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import Giscus from "../../components/Giscus.astro";
import ReadingProgress from "../../components/ReadingProgress.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import PostNav from "../../components/PostNav.astro";
import AdSlot from "../../components/AdSlot.astro";
import MermaidRenderer from "../../components/MermaidRenderer.astro";
import categories from "../../data/categories.json";
import subcategories from "../../data/subcategories.json";
import {
  findTranslation,
  formatDate,
  getPostCategoryTrail,
  getPostSourceStem,
  getPostSubcategory,
  getPublishedPosts,
  getReadingTime,
  getPostLang
} from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts }
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const currentLang = getPostLang(post);
const translation = await findTranslation(post);
const currentCategory = post.data.category?.trim() ?? "";
const currentSubcategory = getPostSubcategory(post);
const postSourceStem = getPostSourceStem(post);
const translationSourceStem = translation ? getPostSourceStem(translation) : "";
const adminCategories = [...new Set([...(categories as string[]), currentCategory].filter(Boolean))];
const adminSubcategoryMap = subcategories as Record<string, string[]>;
const adminSubcategories = currentCategory ? [...(adminSubcategoryMap[currentCategory] ?? [])] : [];
if (currentSubcategory && !adminSubcategories.includes(currentSubcategory)) {
  adminSubcategories.push(currentSubcategory);
}
const adminSubcategoryPayload = encodeURIComponent(JSON.stringify(adminSubcategoryMap));
const articleEyebrow = getPostCategoryTrail(post) || (currentLang === "en" ? "Post" : "글");
const postTopAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_POST_TOP ?? "";
const postBottomAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_POST_BOTTOM ?? "";
const hasMermaid = (post.body ?? "").includes("```mermaid");

const postUrl = `${Astro.site?.toString().replace(/\/$/, "") ?? "https://blog.somiri.dev"}/posts/${post.id}/`;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://blog.somiri.dev";
const ogImage = post.data.thumbnail
  ? (post.data.thumbnail.startsWith("http") ? post.data.thumbnail : `${siteUrl}${post.data.thumbnail}`)
  : `${siteUrl}/og-default.png`;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": ogImage,
  "datePublished": post.data.pubDate.toISOString(),
  ...(post.data.updatedDate ? { "dateModified": post.data.updatedDate.toISOString() } : {}),
  "author": {
    "@type": "Person",
    "name": "Somiri",
    "url": siteUrl
  },
  "publisher": {
    "@type": "Person",
    "name": "Somiri",
    "url": siteUrl
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": postUrl
  },
  "url": postUrl,
  "inLanguage": currentLang === "en" ? "en" : "ko",
  ...(post.data.tags.length > 0 ? { "keywords": post.data.tags.join(", ") } : {}),
  ...(articleEyebrow ? { "articleSection": articleEyebrow } : {})
});
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.thumbnail}>
  <script type="application/ld+json" set:html={jsonLd} />
  <ReadingProgress />
  <CodeCopy />
  {hasMermaid && <MermaidRenderer />}
  <Header />

  <main class="shell">
    <div class="post-wrap">

      <!-- 왼쪽: 뒤로가기 버튼 -->
      <aside class="back-col">
        <div class="back-sticky">
          <a href="/" class="back-btn" aria-label={currentLang === "en" ? "Back to all posts" : "모든 글로 돌아가기"} data-pagefind-ignore>
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
              <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </aside>

      <!-- 사이드바: 목차 -->
      {headings.length > 0 && (
        <aside class="toc-col">
          <div class="toc-sticky">
            <div class="toc-header">
              <p class="toc-post-title">{post.data.title}</p>
              <button class="toc-toggle" aria-label={currentLang === "en" ? "Toggle table of contents" : "목차 접기/펼치기"}>
                <svg class="toc-toggle__icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 18l-6-6 6-6"/>
                </svg>
              </button>
            </div>
            <div class="toc-content">
              <TOC headings={headings} lang={currentLang} />
            </div>
          </div>
        </aside>
      )}

      <!-- 본문 -->
      <article class="app-panel article" data-pagefind-body data-pagefind-meta={`title:${post.data.title}`} data-pagefind-filter={`lang:${currentLang}`} data-post-slug={post.id} data-post-lang={currentLang} data-worker-base={import.meta.env.PUBLIC_OAUTH_WORKER_URL ?? ""}>

        <header class="article__header">
          <div class="panel-heading" data-pagefind-ignore>
            <p class="eyebrow article__eyebrow">{articleEyebrow}</p>
          </div>
          <h1>{post.data.title}</h1>
          <p data-pagefind-meta="description">{post.data.description}</p>

          <div class="article__meta" data-pagefind-ignore>
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, currentLang)}</time>
            {post.data.updatedDate && (
              <span class="updated-date">
                {currentLang === "en" ? "Updated" : "수정"} {formatDate(post.data.updatedDate, currentLang)}
              </span>
            )}
            <span>{getReadingTime(post, currentLang)}</span>
            {translation && (
              <a
                href={`/posts/${translation.id}/`}
                class="lang-switch-link"
                data-target-lang={currentLang === "ko" ? "en" : "ko"}
              >
                {currentLang === "ko" ? "영어로 읽기" : "Read in Korean"}
              </a>
            )}
          </div>

          {post.data.tags.length > 0 && (
            <ul class="tag-list" aria-label={currentLang === "en" ? "Post tags" : "글 태그"} data-pagefind-ignore>
              {post.data.tags.map((tag: string) => <li>{tag}</li>)}
            </ul>
          )}

          {post.data.thumbnail && (
            <img class="article__thumb" src={post.data.thumbnail} alt="" loading="lazy" />
          )}
        </header>

        <AdSlot slot={postTopAdSlot} minHeight="180px" className="article__ad article__ad--top" />

        <!-- 모바일용 목차 (인라인) -->
        {headings.length > 0 && (
          <details class="toc-mobile" data-pagefind-ignore>
            <summary>{currentLang === "en" ? "Contents" : "목차"}</summary>
            <TOC headings={headings} lang={currentLang} />
          </details>
        )}

        <div class="prose article__body">
          <Content />
        </div>

        <!-- 공유 버튼 -->
        <div data-pagefind-ignore>
          <ShareButtons title={post.data.title} url={postUrl} image={post.data.thumbnail ?? ""} lang={currentLang} />
        </div>

        <AdSlot slot={postBottomAdSlot} minHeight="220px" className="article__ad article__ad--bottom" />

        <!-- 이전글/다음글 -->
        <div data-pagefind-ignore>
          <PostNav currentPost={post} allPosts={allPosts} />
        </div>

        <!-- 댓글 -->
        <div data-pagefind-ignore>
          <Giscus lang={currentLang} />
        </div>

        <!-- 어드민 바 -->
        <div
          id="post-admin-bar"
          style="display:none"
          data-pagefind-ignore
          data-subcategories={adminSubcategoryPayload}
          data-current-category={currentCategory}
          data-current-subcategory={currentSubcategory}
          data-post-source-stem={postSourceStem}
          data-translation-source-stem={translationSourceStem}
        >
          <div class="post-admin-taxonomy">
            <label class="post-admin-field">
              <span>{currentLang === "en" ? "Category" : "\uce74\ud14c\uace0\ub9ac"}</span>
              <select id="post-admin-category" class="post-admin-select">
                <option value="" selected={!currentCategory}>{currentLang === "en" ? "No category" : "\uce74\ud14c\uace0\ub9ac \uc5c6\uc74c"}</option>
                {adminCategories.map((category) => (
                  <option value={category} selected={currentCategory === category}>{category}</option>
                ))}
              </select>
            </label>

            <label class="post-admin-field">
              <span>{currentLang === "en" ? "Subcategory" : "\ud558\uc704 \uce74\ud14c\uace0\ub9ac"}</span>
              <select id="post-admin-subcategory" class="post-admin-select" disabled={!currentCategory}>
                {!currentCategory ? (
                  <option value="" selected>{currentLang === "en" ? "Select category first" : "\uce74\ud14c\uace0\ub9ac\ub97c \uba3c\uc800 \uc120\ud0dd"}</option>
                ) : (
                  <option value="" selected={!currentSubcategory}>
                    {adminSubcategories.length > 0
                      ? (currentLang === "en" ? "Use parent category only" : "\uc0c1\uc704 \uce74\ud14c\uace0\ub9ac\ub9cc \uc0ac\uc6a9")
                      : (currentLang === "en" ? "No subcategories" : "\ud558\uc704 \uce74\ud14c\uace0\ub9ac \uc5c6\uc74c")}
                  </option>
                )}
                {adminSubcategories.map((subcategory) => (
                  <option value={subcategory} selected={currentSubcategory === subcategory}>{subcategory}</option>
                ))}
              </select>
            </label>

            <button id="post-taxonomy-save-btn" type="button" class="post-admin-btn">
              {currentLang === "en" ? "Save taxonomy" : "\uce74\ud14c\uace0\ub9ac \uc800\uc7a5"}
            </button>
            <span id="post-taxonomy-status" class="post-admin-status" aria-live="polite"></span>
          </div>
          <a href={`/admin/new-post?edit=${post.id}`} class="post-admin-btn">{currentLang === "en" ? "Edit" : "수정"}</a>
          <button id="post-delete-btn" class="post-admin-btn post-admin-btn--danger">{currentLang === "en" ? "Delete" : "삭제"}</button>
        </div>
      </article>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const OWNER  = "achieveonepark";
  const REPO   = "cording-blog";
  const BRANCH = "main";

  let lastSlug = "";

  function encodeRepoPath(path: string) {
    return path
      .split("/")
      .map((segment) => encodeURIComponent(segment))
      .join("/");
  }

  function decodeBase64Utf8(value: string) {
    return decodeURIComponent(escape(atob(value.replace(/\n/g, ""))));
  }

  function encodeBase64Utf8(value: string) {
    return btoa(unescape(encodeURIComponent(value)));
  }

  function parseSubcategoryMap(value: string | undefined) {
    if (!value) return {} as Record<string, string[]>;

    try {
      const parsed = JSON.parse(decodeURIComponent(value)) as Record<string, unknown>;
      return Object.entries(parsed).reduce<Record<string, string[]>>((acc, [category, subcategoryList]) => {
        acc[category] = Array.isArray(subcategoryList)
          ? subcategoryList.map((entry) => (typeof entry === "string" ? entry.trim() : "")).filter(Boolean)
          : [];
        return acc;
      }, {});
    } catch {
      return {};
    }
  }

  function renderAdminSubcategoryOptions(
    select: HTMLSelectElement,
    subcategoryMap: Record<string, string[]>,
    category: string,
    preferredSubcategory: string,
    lang: "ko" | "en"
  ) {
    const availableSubcategories = category ? (subcategoryMap[category] ?? []) : [];

    if (!category) {
      select.innerHTML = `<option value="">${lang === "en" ? "Select category first" : "카테고리를 먼저 선택"}</option>`;
      select.disabled = true;
      return;
    }

    const defaultLabel = availableSubcategories.length > 0
      ? (lang === "en" ? "Use parent category only" : "상위 카테고리만 사용")
      : (lang === "en" ? "No subcategories" : "하위 카테고리 없음");

    select.innerHTML = `<option value="">${defaultLabel}</option>`;

    availableSubcategories.forEach((subcategory) => {
      const option = document.createElement("option");
      option.value = subcategory;
      option.textContent = subcategory;
      select.appendChild(option);
    });

    if (preferredSubcategory && !availableSubcategories.includes(preferredSubcategory)) {
      const option = document.createElement("option");
      option.value = preferredSubcategory;
      option.textContent = preferredSubcategory;
      select.appendChild(option);
    }

    select.disabled = availableSubcategories.length === 0 && !preferredSubcategory;
    select.value = preferredSubcategory && [...select.options].some((option) => option.value === preferredSubcategory)
      ? preferredSubcategory
      : "";
  }

  async function fetchRepoFile(path: string, token: string) {
    const response = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${encodeRepoPath(path)}?ref=${BRANCH}`,
      {
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json"
        }
      }
    );

    if (!response.ok) {
      throw new Error(`Failed to load ${path}`);
    }

    const data = await response.json();
    return {
      sha: data.sha as string,
      content: decodeBase64Utf8(data.content as string)
    };
  }

  async function saveRepoFile(path: string, content: string, sha: string, token: string, message: string) {
    const response = await fetch(
      `https://api.github.com/repos/${OWNER}/${REPO}/contents/${encodeRepoPath(path)}`,
      {
        method: "PUT",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          message,
          content: encodeBase64Utf8(content),
          sha,
          branch: BRANCH
        })
      }
    );

    if (!response.ok) {
      const error = await response.json().catch(() => ({}));
      throw new Error((error as { message?: string }).message ?? `Failed to save ${path}`);
    }
  }

  function updateFrontmatterTaxonomy(raw: string, category: string, subcategory: string) {
    const lineEnding = raw.includes("\r\n") ? "\r\n" : "\n";
    const match = raw.match(/^---\r?\n([\s\S]*?)\r?\n---([\s\S]*)$/);
    if (!match) {
      throw new Error("Frontmatter not found");
    }

    const frontmatterLines = match[1]
      .split(/\r?\n/)
      .filter((line) => !/^(category|subcategory):\s*/.test(line));

    if (category) {
      frontmatterLines.push(`category: ${category}`);
      frontmatterLines.push(`subcategory: ${subcategory ? subcategory : '""'}`);
    }

    return `---${lineEnding}${frontmatterLines.join(lineEnding).trimEnd()}${lineEnding}---${match[2]}`;
  }

  function initPost() {
    const article = document.querySelector("article[data-post-slug]") as HTMLElement | null;
    if (!article) { lastSlug = ""; return; }

    const postSlug   = article.dataset.postSlug   ?? "";
    const postLang   = article.dataset.postLang === "en" ? "en" : "ko";
    const workerBase = (article.dataset.workerBase ?? "").replace(/\/$/, "");

    // 같은 페이지 중복 실행 방지
    if (postSlug && postSlug === lastSlug) return;
    lastSlug = postSlug;

    // 방문 카운트 (모든 방문자 — IP 기반 하루 1회 중복 방지)
    if (workerBase && postSlug) {
      fetch(`${workerBase}/visit`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ post: postSlug }),
      }).catch(() => {});
    }

    const token = localStorage.getItem("gh_token");
    const translationLink = document.querySelector(".lang-switch-link") as HTMLAnchorElement | null;

    translationLink?.addEventListener("click", () => {
      const targetLang = translationLink.dataset.targetLang;
      if (targetLang === "ko" || targetLang === "en") {
        localStorage.setItem("blog_lang", targetLang);
        document.documentElement.dataset.blogLang = targetLang;
      }
    });

    // --- 어드민 바 ---
    const adminBar = document.getElementById("post-admin-bar") as HTMLElement | null;
    const deleteBtn = document.getElementById("post-delete-btn") as HTMLButtonElement | null;
    const taxonomyCategory = document.getElementById("post-admin-category") as HTMLSelectElement | null;
    const taxonomySubcategory = document.getElementById("post-admin-subcategory") as HTMLSelectElement | null;
    const taxonomySaveBtn = document.getElementById("post-taxonomy-save-btn") as HTMLButtonElement | null;
    const taxonomyStatus = document.getElementById("post-taxonomy-status") as HTMLElement | null;
    const taxonomyMap = parseSubcategoryMap(adminBar?.dataset.subcategories);
    const postSourceStem = adminBar?.dataset.postSourceStem ?? "";
    const translationSourceStem = adminBar?.dataset.translationSourceStem ?? "";

    taxonomyCategory?.addEventListener("change", () => {
      if (!taxonomySubcategory) return;
      renderAdminSubcategoryOptions(taxonomySubcategory, taxonomyMap, taxonomyCategory.value, "", postLang);
      if (taxonomyStatus) taxonomyStatus.textContent = "";
    });

    if (token && adminBar) {
      fetch("https://api.github.com/user", {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then((r) => r.json())
        .then((u) => {
          if (u.login !== OWNER) return;
          adminBar.style.display = "flex";
        })
        .catch(() => {});
    }

    taxonomySaveBtn?.addEventListener("click", async () => {
      if (!token || !adminBar || !taxonomyCategory || !taxonomySubcategory || !taxonomyStatus || !postSourceStem) return;

      const nextCategory = taxonomyCategory.value.trim();
      const nextSubcategory = nextCategory ? taxonomySubcategory.value.trim() : "";
      const targetStems = [...new Set([postSourceStem, translationSourceStem].filter(Boolean))];

      taxonomyCategory.disabled = true;
      taxonomySubcategory.disabled = true;
      taxonomySaveBtn.disabled = true;
      taxonomyStatus.textContent = postLang === "en" ? "Saving..." : "저장 중...";

      try {
        for (const stem of targetStems) {
          const path = `src/content/blog/${stem}.md`;
          const file = await fetchRepoFile(path, token);
          const updatedContent = updateFrontmatterTaxonomy(file.content, nextCategory, nextSubcategory);
          await saveRepoFile(path, updatedContent, file.sha, token, `chore: update taxonomy - ${postSlug}`);
        }

        const eyebrow = article.querySelector(".article__eyebrow") as HTMLElement | null;
        if (eyebrow) {
          eyebrow.textContent = [nextCategory, nextSubcategory].filter(Boolean).join(" / ") || (postLang === "en" ? "Post" : "글");
        }

        adminBar.dataset.currentCategory = nextCategory;
        adminBar.dataset.currentSubcategory = nextSubcategory;
        renderAdminSubcategoryOptions(taxonomySubcategory, taxonomyMap, nextCategory, nextSubcategory, postLang);
        taxonomyStatus.textContent = postLang === "en"
          ? "Saved. Rebuild will publish the change."
          : "저장했습니다. 빌드 후 반영됩니다.";
      } catch (error) {
        taxonomyStatus.textContent = error instanceof Error
          ? error.message
          : (postLang === "en" ? "Failed to update taxonomy." : "카테고리 변경에 실패했습니다.");
      } finally {
        taxonomyCategory.disabled = false;
        renderAdminSubcategoryOptions(
          taxonomySubcategory,
          taxonomyMap,
          taxonomyCategory.value.trim(),
          taxonomySubcategory.value.trim(),
          postLang
        );
        taxonomySaveBtn.disabled = false;
      }
    });

    deleteBtn?.addEventListener("click", async () => {
      if (!token || !postSourceStem) return;

      const deleteMessage = postLang === "en"
        ? `Delete "${postSlug}"? This cannot be undone.`
        : `"${postSlug}" 포스트를 삭제할까요? 되돌릴 수 없어요.`;
      if (!confirm(deleteMessage)) return;
      const path = `src/content/blog/${postSourceStem}.md`;
      const file = await fetchRepoFile(path, token);
      await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${encodeRepoPath(path)}`, {
        method: "DELETE",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ message: `chore: delete post - ${postSlug}`, sha: file.sha, branch: BRANCH }),
      });
      window.location.href = "/";
    });
  }

  // --- TOC 토글 ---
  function initTocToggle() {
    const tocCol = document.querySelector(".toc-col");
    const toggleBtn = document.querySelector(".toc-toggle");
    if (!tocCol || !toggleBtn) return;

    if (localStorage.getItem("toc-collapsed") === "true") {
      tocCol.classList.add("collapsed");
    }

    toggleBtn.addEventListener("click", () => {
      tocCol.classList.toggle("collapsed");
      localStorage.setItem("toc-collapsed", tocCol.classList.contains("collapsed").toString());
    });
  }

  document.addEventListener("astro:after-swap", initPost);
  document.addEventListener("astro:page-load", () => { initPost(); initTocToggle(); });
</script>

<style>
  /* ── 레이아웃 ─────────────────────────────── */
  .post-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: grid;
    grid-template-columns: 40px 1fr 240px;
    grid-template-areas: "back article toc";
    gap: 1.2rem 1.5rem;
    align-items: start;
  }

  .back-col {
    grid-area: back;
    align-self: stretch;
    z-index: 5;
  }

  .back-sticky {
    position: sticky;
    top: 5rem;
  }

  .back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1.5px solid rgba(124, 255, 122, 0.35);
    background: rgba(10, 15, 19, 0.95);
    color: rgba(124, 255, 122, 0.8);
    text-decoration: none;
    transition: color 150ms, background 150ms, border-color 150ms;
    box-shadow: 0 0 8px rgba(124, 255, 122, 0.08);
  }

  .back-btn:hover {
    color: #7cff7a;
    background: rgba(124, 255, 122, 0.12);
    border-color: rgba(124, 255, 122, 0.55);
    box-shadow: 0 0 12px rgba(124, 255, 122, 0.15);
  }

  .article { grid-area: article; }

  .toc-col {
    grid-area: toc;
    align-self: stretch;
  }

  .toc-sticky {
    position: sticky;
    top: 2rem;
  }

  .toc-header {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.65rem;
    border-bottom: 1px solid rgba(124, 255, 122, 0.1);
  }

  .toc-post-title {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .toc-toggle {
    flex: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(124, 255, 122, 0.25);
    background: transparent;
