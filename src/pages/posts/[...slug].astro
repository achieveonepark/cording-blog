---
import { render, type CollectionEntry } from "astro:content";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TOC from "../../components/TOC.astro";
import ShareButtons from "../../components/ShareButtons.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import Giscus from "../../components/Giscus.astro";
import ReadingProgress from "../../components/ReadingProgress.astro";
import CodeCopy from "../../components/CodeCopy.astro";
import { formatDate, getPublishedPosts, getReadingTime } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts }
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);

const workerBase = import.meta.env.PUBLIC_OAUTH_WORKER_URL?.replace(/\/$/, "") ?? "";
const postUrl = `${Astro.site?.toString().replace(/\/$/, "") ?? "https://somiri.dev"}/posts/${post.id}/`;
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.thumbnail}>
  <ReadingProgress />
  <CodeCopy />
  <Header />

  <main class="shell">
    <div class="post-wrap">

      <!-- 사이드바: 목차 -->
      {headings.length > 0 && (
        <aside class="toc-col">
          <div class="toc-sticky">
            <TOC headings={headings} />
          </div>
        </aside>
      )}

      <!-- 본문 -->
      <article class="app-panel article" data-pagefind-body data-pagefind-meta={`title:${post.data.title}`} data-post-slug={post.id} data-worker-base={workerBase}>
        <a class="back-link" href="/posts" data-pagefind-ignore>모든 글로 돌아가기</a>

        <header class="article__header">
          <div class="panel-heading" data-pagefind-ignore>
            <p class="eyebrow">Post</p>
          </div>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>

          <div class="article__meta" data-pagefind-ignore>
            <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
            <span>{getReadingTime(post)}</span>
            {post.data.category && <span class="article-category">{post.data.category}</span>}
            {workerBase && (
              <span class="visit-count" id="visit-count" title="조회수" aria-label="조회수">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <span id="visit-num">–</span>
              </span>
            )}
          </div>

          {post.data.tags.length > 0 && (
            <ul class="tag-list" aria-label="Post tags" data-pagefind-ignore>
              {post.data.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          )}

          {post.data.thumbnail && (
            <img class="article__thumb" src={post.data.thumbnail} alt="" loading="lazy" />
          )}
        </header>

        <!-- 모바일용 목차 (인라인) -->
        {headings.length > 0 && (
          <details class="toc-mobile" data-pagefind-ignore>
            <summary>목차</summary>
            <TOC headings={headings} />
          </details>
        )}

        <div class="prose article__body">
          <Content />
        </div>

        <!-- 공유 버튼 -->
        <div data-pagefind-ignore>
          <ShareButtons title={post.data.title} url={postUrl} image={post.data.thumbnail ?? ""} />
        </div>

        <!-- 좋아요 버튼 -->
        {workerBase && (
          <div class="like-wrap" data-pagefind-ignore>
            <button class="like-btn" id="like-btn" aria-label="좋아요">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              <span id="like-num">–</span>
            </button>
          </div>
        )}

        <!-- 관련 글 -->
        <div data-pagefind-ignore>
          <RelatedPosts currentPost={post} allPosts={allPosts} />
        </div>

        <!-- 댓글 -->
        <div data-pagefind-ignore>
          <Giscus />
        </div>

        <!-- 어드민 바 -->
        <div id="post-admin-bar" style="display:none" data-pagefind-ignore>
          <a href={`/admin/new-post?edit=${post.id}`} class="post-admin-btn">수정</a>
          <button id="post-delete-btn" class="post-admin-btn post-admin-btn--danger">삭제</button>
        </div>
      </article>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const OWNER  = "achieveonepark";
  const REPO   = "cording-blog";
  const BRANCH = "main";

  let lastSlug = "";

  function initPost() {
    const article = document.querySelector("article[data-post-slug]") as HTMLElement | null;
    if (!article) { lastSlug = ""; return; }

    const postSlug   = article.dataset.postSlug   ?? "";
    const workerBase = (article.dataset.workerBase ?? "").replace(/\/$/, "");

    // 같은 페이지 중복 실행 방지
    if (postSlug && postSlug === lastSlug) return;
    lastSlug = postSlug;

    const token = localStorage.getItem("gh_token");

    // --- 어드민 바 ---
    const adminBar  = document.getElementById("post-admin-bar");
    const deleteBtn = document.getElementById("post-delete-btn");

    if (token && adminBar) {
      fetch("https://api.github.com/user", {
        headers: { Authorization: `Bearer ${token}` },
      })
        .then((r) => r.json())
        .then((u) => { if (u.login === OWNER) adminBar.style.display = "flex"; })
        .catch(() => {});
    }

    deleteBtn?.addEventListener("click", async () => {
      if (!confirm(`"${postSlug}" 포스트를 삭제할까요? 되돌릴 수 없어요.`)) return;
      const path = `src/content/blog/${postSlug}.md`;
      const fileRes = await fetch(
        `https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}?ref=${BRANCH}`,
        { headers: { Authorization: `Bearer ${token}`, Accept: "application/vnd.github+json" } }
      );
      const file = await fileRes.json();
      await fetch(`https://api.github.com/repos/${OWNER}/${REPO}/contents/${path}`, {
        method: "DELETE",
        headers: {
          Authorization: `Bearer ${token}`,
          Accept: "application/vnd.github+json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ message: `chore: delete post - ${postSlug}`, sha: file.sha, branch: BRANCH }),
      });
      window.location.href = "/posts";
    });

    // --- 방문자 수 + 좋아요 ---
    if (!workerBase) return;

    const visitNumEl = document.getElementById("visit-num");
    const likeNumEl  = document.getElementById("like-num");
    const likeBtn    = document.getElementById("like-btn");
    const LIKED_KEY  = `liked:${postSlug}`;

    fetch(`${workerBase}/stats?post=${encodeURIComponent(postSlug)}`)
      .then((r) => r.json())
      .then((data) => {
        if (visitNumEl) visitNumEl.textContent = String(data.visits ?? 0);
        if (likeNumEl)  likeNumEl.textContent  = String(data.likes   ?? 0);
        if (likeBtn && localStorage.getItem(LIKED_KEY)) likeBtn.classList.add("like-btn--liked");
      })
      .catch(() => {
        if (visitNumEl) visitNumEl.textContent = "–";
        if (likeNumEl)  likeNumEl.textContent  = "–";
      });

    const VISIT_KEY = `visited:${postSlug}`;
    if (!sessionStorage.getItem(VISIT_KEY)) {
      sessionStorage.setItem(VISIT_KEY, "1");
      fetch(`${workerBase}/visit`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ post: postSlug }),
      }).catch(() => {});
    }

    likeBtn?.addEventListener("click", () => {
      if (localStorage.getItem(LIKED_KEY)) return;
      localStorage.setItem(LIKED_KEY, "1");
      likeBtn.classList.add("like-btn--liked");
      fetch(`${workerBase}/like`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ post: postSlug }),
      })
        .then((r) => r.json())
        .then((data) => { if (likeNumEl) likeNumEl.textContent = String(data.likes ?? "–"); })
        .catch(() => {});
    });
  }

  document.addEventListener("astro:after-swap", initPost);
  document.addEventListener("astro:page-load",  initPost);
</script>

<style>
  /* ── 레이아웃 ─────────────────────────────── */
  .post-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: grid;
    grid-template-columns: 1fr 240px;
    grid-template-areas: "article toc";
    gap: 2rem;
    align-items: start;
  }

  .article { grid-area: article; }
  .toc-col { grid-area: toc; }

  .toc-sticky {
    position: sticky;
    top: 2rem;
  }

  /* ── 모바일 목차 (인라인) ─────────────────── */
  .toc-mobile {
    margin: 0 0 1.5rem;
    border: 1px solid rgba(124, 255, 122, 0.12);
    border-radius: 8px;
    overflow: hidden;
  }

  .toc-mobile summary {
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(124, 255, 122, 0.6);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .toc-mobile summary::-webkit-details-marker { display: none; }
  .toc-mobile summary::before { content: "▸ "; }
  .toc-mobile[open] summary::before { content: "▾ "; }

  .toc-mobile :global(.toc) {
    border: none;
    border-radius: 0;
    border-top: 1px solid rgba(124, 255, 122, 0.08);
  }

  /* 데스크탑에선 인라인 목차 숨김 */
  @media (min-width: 921px) {
    .toc-mobile { display: none; }
  }

  /* 모바일에선 사이드바 목차 숨김 */
  @media (max-width: 920px) {
    .post-wrap {
      grid-template-columns: 1fr;
      grid-template-areas: "article";
      padding: 1rem;
    }
    .toc-col { display: none; }
  }

  /* ── 썸네일 ─────────────────────────────── */
  .article__thumb {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: 8px;
    margin-top: 1rem;
    border: 1px solid rgba(124, 255, 122, 0.1);
  }

  /* ── 방문자 수 ────────────────────────────── */
  .visit-count {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: rgba(150, 180, 150, 0.5);
    font-size: 0.8rem;
  }

  /* ── 좋아요 버튼 ─────────────────────────── */
  .like-wrap {
    display: flex;
    justify-content: center;
    margin: 2rem 0;
  }

  .like-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 120, 140, 0.25);
    background: transparent;
    color: rgba(255, 150, 170, 0.6);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 150ms, background 150ms, color 150ms, transform 100ms;
    font-family: inherit;
  }

  .like-btn:hover {
    border-color: rgba(255, 120, 140, 0.5);
    background: rgba(255, 120, 140, 0.07);
    color: rgba(255, 150, 170, 0.9);
  }

  .like-btn--liked {
    border-color: rgba(255, 120, 140, 0.6);
    background: rgba(255, 120, 140, 0.1);
    color: #ff8ca0;
  }

  .like-btn--liked svg {
    fill: #ff8ca0;
    stroke: #ff8ca0;
  }

  .like-btn:active { transform: scale(0.95); }

  /* ── 어드민 바 ────────────────────────────── */
  #post-admin-bar {
    display: none;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(124, 255, 122, 0.1);
  }

  .post-admin-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.25);
    background: transparent;
    color: rgba(124, 255, 122, 0.7);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
  }

  .post-admin-btn:hover {
    border-color: rgba(124, 255, 122, 0.5);
    background: rgba(124, 255, 122, 0.08);
    color: #7cff7a;
  }

  .article-category {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: rgba(124, 255, 122, 0.1);
    border: 1px solid rgba(124, 255, 122, 0.2);
    color: #7cff7a;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .post-admin-btn--danger {
    border-color: rgba(255, 80, 80, 0.25);
    color: rgba(255, 120, 120, 0.7);
  }

  .post-admin-btn--danger:hover {
    border-color: rgba(255, 80, 80, 0.5);
    background: rgba(255, 80, 80, 0.08);
    color: #ff7070;
  }
</style>
