---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — 페이지를 찾을 수 없습니다" description="요청하신 페이지를 찾을 수 없습니다.">
  <Header />

  <main class="shell app-shell">
    <section class="app-panel not-found">
      <div class="not-found__glitch" aria-hidden="true">404</div>
      <div class="section-heading">
        <p class="eyebrow">Error</p>
        <h1>페이지를 찾을 수 없습니다</h1>
        <p>요청하신 경로가 존재하지 않거나 이동되었습니다.</p>
      </div>

      <nav class="not-found__nav" aria-label="추천 링크">
        <a href="/">홈으로</a>
        <a href="/posts/">모든 글</a>
        <a href="/tags/">태그</a>
        <a href="/about/">About</a>
      </nav>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 2rem;
  }

  .not-found__glitch {
    font-size: clamp(5rem, 18vw, 10rem);
    font-weight: 900;
    font-family: var(--font-code);
    color: var(--accent);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: -1rem;
    letter-spacing: -0.05em;
    user-select: none;
  }

  .not-found .section-heading {
    margin-bottom: 2.5rem;
  }

  .not-found__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .not-found__nav a {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 150ms, transform 150ms;
  }

  .not-found__nav a:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
</style>
