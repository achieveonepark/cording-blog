---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HomeCategorySidebar from "../components/HomeCategorySidebar.astro";
import PostCard from "../components/PostCard.astro";
import AdSlot from "../components/AdSlot.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { BLOG_LANGS, getPostSubcategory, groupPostsByLang, getPublishedPosts } from "../lib/blog";
import categories from "../data/categories.json";
import subcategories from "../data/subcategories.json";

const posts = await getPublishedPosts();
const homeTopAdSlot = import.meta.env.PUBLIC_ADSENSE_SLOT_HOME_TOP ?? "";
const postsByLang = groupPostsByLang(posts);
const categoryCountsByLang = BLOG_LANGS.reduce((acc, lang) => {
  acc[lang] = categories.reduce<Record<string, number>>((counts, category) => {
    counts[category] = postsByLang[lang].filter((post) => post.data.category === category).length;
    return counts;
  }, {});
  return acc;
}, {} as Record<(typeof BLOG_LANGS)[number], Record<string, number>>);

const subcategoryCountsByLang = BLOG_LANGS.reduce((acc, lang) => {
  acc[lang] = categories.reduce<Record<string, Record<string, number>>>((counts, category) => {
    const items = subcategories[category] ?? [];
    counts[category] = items.reduce<Record<string, number>>((subcategoryCounts, subcategory) => {
      subcategoryCounts[subcategory] = postsByLang[lang].filter((post) => {
        return post.data.category === category && getPostSubcategory(post) === subcategory;
      }).length;
      return subcategoryCounts;
    }, {});
    return counts;
  }, {});
  return acc;
}, {} as Record<(typeof BLOG_LANGS)[number], Record<string, Record<string, number>>>);

const totalPostsByLang = BLOG_LANGS.reduce((acc, lang) => {
  acc[lang] = postsByLang[lang].length;
  return acc;
}, {} as Record<(typeof BLOG_LANGS)[number], number>);
---

<BaseLayout title="Somblog" description="Unity, Android, iOS, CI/CD, ASP.NET. 그리고 그 외 신기능이 궁금해서 경험을 기록하기 위한 블로그!">
  <Header />

  <main class="shell app-shell">
    <HomeCategorySidebar
      categories={categories}
      subcategories={subcategories}
      categoryCountsByLang={categoryCountsByLang}
      subcategoryCountsByLang={subcategoryCountsByLang}
      totalPostsByLang={totalPostsByLang}
    >
      <AdSlot slot={homeTopAdSlot} minHeight="140px" className="home-feed__ad" />

      {BLOG_LANGS.map((lang) => {
        const langPosts = postsByLang[lang];
        return langPosts.length > 0 ? (
          <section class="app-panel" data-ui-lang={lang} data-home-section>
            <div class="post-stack" data-home-post-stack>
              {langPosts.map((post) => <PostCard post={post} />)}
            </div>
            <p
              class="home-feed__empty"
              data-ui-lang={lang}
              data-home-empty-filter
              data-home-empty-visible="false"
              aria-hidden="true"
            >
              {lang === "en"
                ? "No posts match this category in the current language."
                : "현재 언어에서 이 카테고리에 해당하는 글이 없어요."}
            </p>
            <nav
              class="home-feed__pagination"
              data-home-pagination
              data-ui-lang={lang}
              aria-label={lang === "en" ? "Post pages" : "포스트 페이지"}
              hidden
            >
              <button type="button" class="home-feed__pagination-btn" data-home-page-action="prev">
                {lang === "en" ? "Prev" : "이전"}
              </button>
              <div class="home-feed__pagination-pages" data-home-pagination-pages></div>
              <button type="button" class="home-feed__pagination-btn" data-home-page-action="next">
                {lang === "en" ? "Next" : "다음"}
              </button>
            </nav>
          </section>
        ) : null;
      })}
    </HomeCategorySidebar>
  </main>

  <Footer />
</BaseLayout>

<style>
  .home-feed__empty {
    margin: 0;
    padding: 0 1rem;
    border-radius: var(--radius-md);
    border: 0 dashed rgba(124, 255, 122, 0.16);
    background: rgba(11, 15, 20, 0.48);
    color: var(--muted);
    font-size: 0.84rem;
    max-height: 0;
    opacity: 0;
    overflow: clip;
    transform: translateY(-0.4rem);
    transition:
      max-height 380ms cubic-bezier(0.22, 1, 0.36, 1),
      margin-top 380ms cubic-bezier(0.22, 1, 0.36, 1),
      padding 380ms cubic-bezier(0.22, 1, 0.36, 1),
      border-width 220ms ease,
      opacity 220ms ease,
      transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .home-feed__empty[data-home-empty-visible="true"] {
    margin-top: 1rem;
    padding: 0.95rem 1rem;
    border-width: 1px;
    max-height: 6rem;
    opacity: 1;
    transform: translateY(0);
  }

  .home-feed__ad {
    margin-bottom: 1rem;
  }

  .home-feed__pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(124, 255, 122, 0.08);
  }

  .home-feed__pagination[hidden] {
    display: none;
  }

  .home-feed__pagination-btn,
  .home-feed__pagination-pages :global(.home-feed__pagination-page) {
    appearance: none;
    -webkit-appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.2rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.12);
    background:
      linear-gradient(180deg, rgba(17, 22, 28, 0.96), rgba(9, 13, 18, 0.92));
    box-shadow:
      inset 0 1px 0 rgba(214, 255, 214, 0.03),
      0 10px 24px rgba(0, 0, 0, 0.22);
    color: rgba(124, 255, 122, 0.72);
    font-size: 0.74rem;
    font-weight: 700;
    font-family: var(--font-ui);
    cursor: pointer;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    user-select: none;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .home-feed__pagination-btn {
    min-width: 5rem;
    padding: 0.55rem 1rem;
  }

  .home-feed__pagination-pages :global(.home-feed__pagination-page) {
    width: 2.25rem;
    padding: 0;
    border-radius: 0.78rem;
    border-color: rgba(124, 255, 122, 0.1);
    color: rgba(214, 255, 214, 0.68);
    font-family: var(--font-code);
    font-size: 0.8rem;
    box-shadow:
      inset 0 1px 0 rgba(214, 255, 214, 0.03),
      0 8px 18px rgba(0, 0, 0, 0.18);
  }

  .home-feed__pagination-btn:hover:not(:disabled),
  .home-feed__pagination-pages :global(.home-feed__pagination-page:hover:not(:disabled)) {
    border-color: rgba(124, 255, 122, 0.28);
    background:
      linear-gradient(180deg, rgba(24, 31, 38, 0.96), rgba(11, 17, 23, 0.94));
    color: var(--accent);
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(214, 255, 214, 0.05),
      0 12px 24px rgba(0, 0, 0, 0.22);
  }

  .home-feed__pagination-btn:disabled,
  .home-feed__pagination-pages :global(.home-feed__pagination-page:disabled) {
    opacity: 0.32;
    cursor: default;
    transform: none;
    box-shadow: none;
  }

  .home-feed__pagination-pages {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.32rem 0.42rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.08);
    background: rgba(7, 11, 15, 0.58);
    box-shadow: inset 0 1px 0 rgba(214, 255, 214, 0.02);
  }

  .home-feed__pagination-pages :global(.home-feed__pagination-page--current) {
    border-color: rgba(124, 255, 122, 0.34);
    background:
      linear-gradient(180deg, rgba(124, 255, 122, 0.18), rgba(124, 255, 122, 0.06)),
      rgba(14, 21, 17, 0.92);
    color: var(--accent-strong);
    text-shadow: 0 0 12px rgba(124, 255, 122, 0.2);
    box-shadow:
      inset 0 1px 0 rgba(214, 255, 214, 0.08),
      0 0 0 1px rgba(124, 255, 122, 0.06),
      0 10px 22px rgba(0, 0, 0, 0.24),
      0 0 20px rgba(124, 255, 122, 0.08);
  }

  .home-feed__pagination-btn:focus-visible,
  .home-feed__pagination-pages :global(.home-feed__pagination-page:focus-visible) {
    outline: 2px solid rgba(124, 255, 122, 0.42);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-feed__empty {
      transition: none;
    }
  }
</style>
