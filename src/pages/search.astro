---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Search" description="Search blog posts.">
  <Header />

  <main class="shell app-shell">
    <section class="app-panel">
      <div class="section-heading">
        <p class="eyebrow">
          <span data-ui-lang="ko">검색</span>
          <span data-ui-lang="en">Search</span>
        </p>
        <h1>
          <span data-ui-lang="ko">검색</span>
          <span data-ui-lang="en">Search</span>
        </h1>
        <p>
          <span data-ui-lang="ko">제목, 내용, 태그로 글을 검색할 수 있어요.</span>
          <span data-ui-lang="en">Search posts by title, content, and tags.</span>
        </p>
      </div>

      <div id="search" class="search-wrap"></div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  var searchPageCopy = {
    ko: {
      buildRequired: '검색은 빌드 후 사용할 수 있어요. (<code>npm run build</code>)',
      placeholder: '검색어를 입력하세요...',
      zeroResults: '검색 결과가 없어요.'
    },
    en: {
      buildRequired: 'Search is available after running a build. (<code>npm run build</code>)',
      placeholder: 'Type a search term...',
      zeroResults: 'No search results found.'
    }
  };

  function initSearchPage() {
    var mount = document.getElementById("search");
    if (!mount) return;

    var lang = document.documentElement.dataset.blogLang === "en" ? "en" : "ko";
    var copy = searchPageCopy[lang];

    if (typeof PagefindUI === "undefined") {
      mount.innerHTML =
        '<p style="color:rgba(150,180,150,0.6);font-size:0.85rem;">' + copy.buildRequired + '</p>';
      return;
    }

    mount.innerHTML = "";
    new PagefindUI({
      element: "#search",
      showImages: false,
      showEmptyFilters: false,
      resetStyles: false,
      filters: {
        lang: [lang]
      },
      translations: {
        placeholder: copy.placeholder,
        zero_results: copy.zeroResults,
      },
    });
  }

  initSearchPage();
  document.addEventListener("astro:page-load", initSearchPage);
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #7cff7a;
    --pagefind-ui-text: #d0e8d0;
    --pagefind-ui-background: rgba(0, 0, 0, 0.5);
    --pagefind-ui-border: rgba(124, 255, 122, 0.2);
    --pagefind-ui-tag: rgba(124, 255, 122, 0.1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: "SFMono-Regular", Consolas, monospace;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background: rgba(0, 0, 0, 0.55) !important;
    color: #d6ffd6 !important;
    border: 1px solid rgba(124, 255, 122, 0.25) !important;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    outline: none !important;
    border-color: rgba(124, 255, 122, 0.6) !important;
  }

  .pagefind-ui .pagefind-ui__result {
    border-color: rgba(124, 255, 122, 0.12) !important;
    border-radius: 6px !important;
    padding: 1rem !important;
    background: rgba(124, 255, 122, 0.02) !important;
  }

  .pagefind-ui .pagefind-ui__result:hover {
    border-color: rgba(124, 255, 122, 0.3) !important;
    background: rgba(124, 255, 122, 0.05) !important;
  }

  .pagefind-ui .pagefind-ui__result-title a {
    color: #c8e8c8 !important;
    text-decoration: none !important;
  }

  .pagefind-ui .pagefind-ui__result-title a:hover {
    color: #7cff7a !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: rgba(160, 200, 160, 0.7) !important;
    font-size: 0.85rem !important;
  }

  .pagefind-ui mark {
    background: rgba(124, 255, 122, 0.2) !important;
    color: #7cff7a !important;
    border-radius: 2px !important;
  }

  .pagefind-ui .pagefind-ui__button {
    background: rgba(124, 255, 122, 0.1) !important;
    border: 1px solid rgba(124, 255, 122, 0.25) !important;
    color: rgba(124, 255, 122, 0.8) !important;
    border-radius: 6px !important;
    cursor: pointer !important;
  }

  .pagefind-ui .pagefind-ui__button:hover {
    background: rgba(124, 255, 122, 0.18) !important;
    color: #7cff7a !important;
  }

  .pagefind-ui .pagefind-ui__message {
    color: rgba(150, 180, 150, 0.6) !important;
    font-size: 0.85rem !important;
  }
</style>

<style>
  .search-wrap {
    margin-top: 0.5rem;
  }
</style>
