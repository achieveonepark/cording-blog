---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BackButton from "../components/BackButton.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  BLOG_LANGS,
  type BlogLang,
  filterPostsByLang,
  formatDate,
  getPublishedPosts
} from "../lib/blog";

const posts = await getPublishedPosts();

function buildArchive(postsByLang: Awaited<ReturnType<typeof getPublishedPosts>>) {
  const archiveMap = new Map<number, Map<number, typeof postsByLang>>();

  for (const post of postsByLang) {
    const year = post.data.pubDate.getFullYear();
    const month = post.data.pubDate.getMonth() + 1;

    if (!archiveMap.has(year)) archiveMap.set(year, new Map());
    const yearMap = archiveMap.get(year)!;

    if (!yearMap.has(month)) yearMap.set(month, []);
    yearMap.get(month)!.push(post);
  }

  return {
    archiveMap,
    years: [...archiveMap.keys()].sort((a, b) => b - a)
  };
}

const postsByLang = {
  ko: filterPostsByLang(posts, "ko"),
  en: filterPostsByLang(posts, "en")
};

const archiveByLang = BLOG_LANGS.reduce((acc, lang) => {
  acc[lang] = buildArchive(postsByLang[lang]);
  return acc;
}, {} as Record<BlogLang, ReturnType<typeof buildArchive>>);

const monthNames = {
  ko: ["", "1월", "2월", "3월", "4월", "5월", "6월", "7월", "8월", "9월", "10월", "11월", "12월"],
  en: ["", "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
} satisfies Record<BlogLang, string[]>;

// Build game data
const gameDataByLang = BLOG_LANGS.reduce((acc, lang) => {
  const { archiveMap, years } = archiveByLang[lang];
  const buildings: { year: number; month: number; label: string; posts: { title: string; id: string; category: string }[] }[] = [];

  for (const year of years) {
    const yearMap = archiveMap.get(year)!;
    const months = [...yearMap.keys()].sort((a, b) => a - b);
    for (const month of months) {
      const monthPosts = yearMap.get(month)!;
      buildings.push({
        year,
        month,
        label: `${year} ${monthNames[lang][month]}`,
        posts: monthPosts.map(p => ({
          title: p.data.title,
          id: p.id,
          category: p.data.category || ""
        }))
      });
    }
  }

  acc[lang] = buildings;
  return acc;
}, {} as Record<BlogLang, any[]>);
---

<BaseLayout title="Archive" description="Monthly post archives.">
  <Header />
  <BackButton href="/" />

  <main class="archive-shell app-shell">
    <!-- View toggle -->
    <div class="archive-toggle">
      <button class="archive-toggle__btn archive-toggle__btn--active" data-archive-mode="list">
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M3 4h18M3 12h18M3 20h18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
        <span data-ui-lang="ko">목록</span>
        <span data-ui-lang="en">List</span>
      </button>
      <button class="archive-toggle__btn" data-archive-mode="game">
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span data-ui-lang="ko">탐험</span>
        <span data-ui-lang="en">Explore</span>
      </button>
    </div>

    <!-- List view -->
    <section class="app-panel archive-list-view" data-archive-view="list">
      {BLOG_LANGS.map((lang) => {
        const langPosts = postsByLang[lang];
        const { archiveMap, years } = archiveByLang[lang];

        return (
          <div data-ui-lang={lang}>
            <div class="section-heading">
              <p class="eyebrow">{lang === "en" ? "Archive" : "아카이브"}</p>
              <h1>{lang === "en" ? "Monthly Archive" : "월별 아카이브"}</h1>
              <p>
                {lang === "en"
                  ? `${langPosts.length} posts across ${years.length} years`
                  : `총 ${langPosts.length}개의 글 / ${years.length}개 연도`}
              </p>
            </div>

            {years.map((year) => {
              const yearMap = archiveMap.get(year)!;
              const months = [...yearMap.keys()].sort((a, b) => b - a);

              return (
                <div class="year-block">
                  <h2 class="year-label">{year}</h2>
                  {months.map((month) => {
                    const monthPosts = yearMap.get(month)!;
                    return (
                      <div class="month-block">
                        <h3 class="month-label">
                          <span class="month-name">{monthNames[lang][month]}</span>
                          <span class="month-count">{monthPosts.length}</span>
                        </h3>
                        <ul class="archive-posts">
                          {monthPosts.map((post) => (
                            <li class="archive-post">
                              <time class="archive-post__date">{formatDate(post.data.pubDate, lang)}</time>
                              <a href={`/posts/${post.id}/`} class="archive-post__title">
                                {post.data.title}
                              </a>
                              {post.data.category && (
                                <span class="archive-post__cat">{post.data.category}</span>
                              )}
                            </li>
                          ))}
                        </ul>
                      </div>
                    );
                  })}
                </div>
              );
            })}
          </div>
        );
      })}
    </section>

    <!-- Game view -->
    <section class="app-panel archive-game-view" data-archive-view="game" style="display:none">
      <div id="archive-game-container"></div>
      <div class="archive-game-hint">
        <kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd>
        <span data-ui-lang="ko">이동 / 건물에 다가가면 포스팅이 보입니다</span>
        <span data-ui-lang="en">Move / Approach buildings to see posts</span>
      </div>
    </section>

    <!-- Post popup -->
    <div id="archive-popup" class="archive-popup" style="display:none">
      <div class="archive-popup__inner">
        <span class="archive-popup__cat" id="archive-popup-cat"></span>
        <h3 id="archive-popup-title"></h3>
        <a id="archive-popup-link" href="/" class="archive-popup__link">
          <span data-ui-lang="ko">읽으러 가기 →</span>
          <span data-ui-lang="en">Read post →</span>
        </a>
      </div>
    </div>
  </main>

  <Footer />

  <script
    id="archive-game-data"
    type="application/json"
    set:html={JSON.stringify(gameDataByLang)}
  />

  <script is:inline src="https://cdn.jsdelivr.net/npm/phaser@3.80.1/dist/phaser.min.js"></script>

  <script is:inline>
  (function () {
    var dataEl = document.getElementById("archive-game-data");
    if (!dataEl) return;
    var allData = JSON.parse(dataEl.textContent || "{}");
    var game = null;

    function getLang() {
      return document.documentElement.dataset.blogLang === "en" ? "en" : "ko";
    }

    // ── Toggle ──
    document.addEventListener("click", function (e) {
      var btn = e.target.closest("[data-archive-mode]");
      if (!btn) return;
      var mode = btn.dataset.archiveMode;
      document.querySelectorAll("[data-archive-mode]").forEach(function (b) {
        b.classList.toggle("archive-toggle__btn--active", b.dataset.archiveMode === mode);
      });
      document.querySelectorAll("[data-archive-view]").forEach(function (v) {
        v.style.display = v.dataset.archiveView === mode ? "" : "none";
      });
      if (mode === "game") {
        setTimeout(initGame, 50);
      }
    });

    function initGame() {
      var container = document.getElementById("archive-game-container");
      if (!container) return;
      if (game) { game.destroy(true); game = null; }
      container.innerHTML = "";

      var rect = container.getBoundingClientRect();
      var w = Math.floor(rect.width) || 800;
      var h = Math.max(550, Math.min(750, window.innerHeight * 0.68));

      game = new Phaser.Game({
        type: Phaser.CANVAS,
        parent: "archive-game-container",
        width: w,
        height: h,
        transparent: true,
        physics: { default: "arcade", arcade: { debug: false } },
        scene: { preload: preloadScene, create: createScene, update: updateScene }
      });
    }

    // ── Game state ──
    var player, cursors, keys;
    var buildings = [];
    var postBoxes = [];
    var activeBuilding = null;
    var nearPost = null;
    var playerGfx, playerLabel;
    var cam;
    var TILE = 64;
    var BUILDING_W = 180;
    var BUILDING_H = 140;
    var GAP_X = 220;
    var GAP_Y = 200;
    var COLS = 3;

    function preloadScene() {}

    function createScene() {
      var scene = this;
      var data = allData[getLang()] || [];
      if (data.length === 0) return;

      var worldW = COLS * GAP_X + 300;
      var rows = Math.ceil(data.length / COLS);
      var worldH = rows * GAP_Y + 400;

      scene.cameras.main.setBounds(0, 0, worldW, worldH);
      scene.physics.world.setBounds(0, 0, worldW, worldH);

      // Ground tiles
      var groundGfx = scene.add.graphics();
      groundGfx.fillStyle(0x0a1210, 1);
      groundGfx.fillRect(0, 0, worldW, worldH);

      // Grid lines
      for (var gx = 0; gx < worldW; gx += TILE) {
        groundGfx.lineStyle(1, 0x00ff41, 0.04);
        groundGfx.lineBetween(gx, 0, gx, worldH);
      }
      for (var gy = 0; gy < worldH; gy += TILE) {
        groundGfx.lineStyle(1, 0x00ff41, 0.04);
        groundGfx.lineBetween(0, gy, worldW, gy);
      }

      // Buildings
      buildings = [];
      postBoxes = [];

      for (var i = 0; i < data.length; i++) {
        var col = i % COLS;
        var row = Math.floor(i / COLS);
        var bx = 150 + col * GAP_X;
        var by = 150 + row * GAP_Y;
        var bData = data[i];

        // Building body
        var bg = scene.add.graphics();
        bg.fillStyle(0x0d1f15, 1);
        bg.fillRoundedRect(bx, by, BUILDING_W, BUILDING_H, 8);
        bg.lineStyle(1.5, 0x00cc33, 0.5);
        bg.strokeRoundedRect(bx, by, BUILDING_W, BUILDING_H, 8);

        // Roof accent
        bg.fillStyle(0x00ff41, 0.08);
        bg.fillRoundedRect(bx, by, BUILDING_W, 28, { tl: 8, tr: 8, bl: 0, br: 0 });

        // Door
        var doorX = bx + BUILDING_W / 2 - 12;
        var doorY = by + BUILDING_H - 30;
        bg.fillStyle(0x00ff41, 0.15);
        bg.fillRect(doorX, doorY, 24, 30);
        bg.lineStyle(1, 0x00ff41, 0.3);
        bg.strokeRect(doorX, doorY, 24, 30);

        // Label
        var labelText = scene.add.text(bx + BUILDING_W / 2, by + 14, bData.label, {
          fontFamily: "'A2z', sans-serif",
          fontSize: "13px",
          fontStyle: "bold",
          color: "#00ff41",
          align: "center"
        }).setOrigin(0.5);

        // Post count
        var countText = scene.add.text(bx + BUILDING_W / 2, by + BUILDING_H / 2 + 5, bData.posts.length + (getLang() === "en" ? " posts" : "개"), {
          fontFamily: "'A2z', sans-serif",
          fontSize: "11px",
          color: "#97a2ad",
          align: "center"
        }).setOrigin(0.5);

        // Post boxes (hidden initially)
        var pBoxes = [];
        for (var j = 0; j < bData.posts.length; j++) {
          var px = bx + 15;
          var py = by + 38 + j * 24;

          var boxGfx = scene.add.graphics();
          boxGfx.fillStyle(0x00ff41, 0.1);
          boxGfx.fillRoundedRect(px, py, BUILDING_W - 30, 20, 4);
          boxGfx.lineStyle(1, 0x00ff41, 0.25);
          boxGfx.strokeRoundedRect(px, py, BUILDING_W - 30, 20, 4);
          boxGfx.setVisible(false);

          var boxText = scene.add.text(px + 6, py + 3, bData.posts[j].title, {
            fontFamily: "'A2z', sans-serif",
            fontSize: "10px",
            color: "#b8ffb6",
            align: "left"
          }).setOrigin(0, 0);
          boxText.setVisible(false);
          boxText.setCrop(0, 0, BUILDING_W - 42, 18);

          pBoxes.push({
            gfx: boxGfx,
            text: boxText,
            x: px,
            y: py,
            w: BUILDING_W - 30,
            h: 20,
            postData: bData.posts[j]
          });
        }

        postBoxes.push(pBoxes);

        buildings.push({
          x: bx,
          y: by,
          w: BUILDING_W,
          h: BUILDING_H,
          data: bData,
          bg: bg,
          label: labelText,
          count: countText,
          postBoxesIdx: i,
          open: false
        });
      }

      // Player
      var startX = 150 + Math.floor(COLS / 2) * GAP_X + BUILDING_W / 2;
      var startY = 100;

      playerGfx = scene.add.graphics();
      drawPlayer(playerGfx, 0x00ff41);

      playerLabel = scene.add.text(0, -20, getLang() === "en" ? "You" : "나", {
        fontFamily: "'A2z', sans-serif",
        fontSize: "9px",
        color: "#7cff7a",
        align: "center"
      }).setOrigin(0.5);

      var playerContainer = scene.add.container(startX, startY, [playerGfx, playerLabel]);
      scene.physics.add.existing(playerContainer);
      playerContainer.body.setCollideWorldBounds(true);
      playerContainer.body.setSize(20, 20);
      playerContainer.body.setOffset(-10, -10);
      player = playerContainer;

      // Camera
      cam = scene.cameras.main;
      cam.startFollow(player, true, 0.08, 0.08);
      cam.setZoom(1);

      // Controls
      cursors = scene.input.keyboard.createCursorKeys();
      keys = scene.input.keyboard.addKeys("W,A,S,D");

      // Click handler for post boxes
      scene.input.on("pointerdown", function (pointer) {
        if (!activeBuilding) return;
        var worldPoint = cam.getWorldPoint(pointer.x, pointer.y);
        var pBoxes = postBoxes[activeBuilding.postBoxesIdx];
        for (var k = 0; k < pBoxes.length; k++) {
          var pb = pBoxes[k];
          if (pb.gfx.visible &&
              worldPoint.x >= pb.x && worldPoint.x <= pb.x + pb.w &&
              worldPoint.y >= pb.y && worldPoint.y <= pb.y + pb.h) {
            window.location.href = "/posts/" + pb.postData.id + "/";
            return;
          }
        }
      });
    }

    function drawPlayer(gfx, color) {
      // Body
      gfx.fillStyle(color, 0.8);
      gfx.fillCircle(0, 0, 10);
      // Inner
      gfx.fillStyle(0x001800, 0.6);
      gfx.fillCircle(0, 0, 6);
      // Eyes
      gfx.fillStyle(color, 1);
      gfx.fillCircle(-3, -2, 2);
      gfx.fillCircle(3, -2, 2);
      // Glow
      gfx.lineStyle(1.5, color, 0.4);
      gfx.strokeCircle(0, 0, 13);
    }

    function updateScene() {
      if (!player) return;

      var speed = 200;
      var vx = 0, vy = 0;

      if (keys.A.isDown || cursors.left.isDown) vx = -speed;
      else if (keys.D.isDown || cursors.right.isDown) vx = speed;
      if (keys.W.isDown || cursors.up.isDown) vy = -speed;
      else if (keys.S.isDown || cursors.down.isDown) vy = speed;

      // Diagonal normalization
      if (vx !== 0 && vy !== 0) {
        vx *= 0.707;
        vy *= 0.707;
      }

      player.body.setVelocity(vx, vy);

      // Check proximity to buildings
      var px = player.x;
      var py = player.y;
      var popup = document.getElementById("archive-popup");
      var closestBuilding = null;
      var closestDist = Infinity;

      for (var i = 0; i < buildings.length; i++) {
        var b = buildings[i];
        var cx = b.x + b.w / 2;
        var cy = b.y + b.h / 2;
        var dx = px - cx;
        var dy = py - cy;
        var dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < 140) {
          if (dist < closestDist) {
            closestDist = dist;
            closestBuilding = b;
          }
        }
      }

      // Open/close buildings
      for (var i = 0; i < buildings.length; i++) {
        var b = buildings[i];
        var shouldOpen = b === closestBuilding;
        if (shouldOpen && !b.open) {
          b.open = true;
          b.count.setVisible(false);
          var pBoxes = postBoxes[b.postBoxesIdx];
          for (var j = 0; j < pBoxes.length; j++) {
            pBoxes[j].gfx.setVisible(true);
            pBoxes[j].text.setVisible(true);
          }
          // Highlight building
          b.bg.clear();
          b.bg.fillStyle(0x0d2f1a, 1);
          b.bg.fillRoundedRect(b.x, b.y, b.w, b.h, 8);
          b.bg.lineStyle(2, 0x00ff41, 0.7);
          b.bg.strokeRoundedRect(b.x, b.y, b.w, b.h, 8);
          b.bg.fillStyle(0x00ff41, 0.15);
          b.bg.fillRoundedRect(b.x, b.y, b.w, 28, { tl: 8, tr: 8, bl: 0, br: 0 });
          var doorX = b.x + b.w / 2 - 12;
          var doorY = b.y + b.h - 30;
          b.bg.fillStyle(0x00ff41, 0.25);
          b.bg.fillRect(doorX, doorY, 24, 30);
          b.bg.lineStyle(1, 0x00ff41, 0.5);
          b.bg.strokeRect(doorX, doorY, 24, 30);
        } else if (!shouldOpen && b.open) {
          b.open = false;
          b.count.setVisible(true);
          var pBoxes = postBoxes[b.postBoxesIdx];
          for (var j = 0; j < pBoxes.length; j++) {
            pBoxes[j].gfx.setVisible(false);
            pBoxes[j].text.setVisible(false);
          }
          // Reset building
          b.bg.clear();
          b.bg.fillStyle(0x0d1f15, 1);
          b.bg.fillRoundedRect(b.x, b.y, b.w, b.h, 8);
          b.bg.lineStyle(1.5, 0x00cc33, 0.5);
          b.bg.strokeRoundedRect(b.x, b.y, b.w, b.h, 8);
          b.bg.fillStyle(0x00ff41, 0.08);
          b.bg.fillRoundedRect(b.x, b.y, b.w, 28, { tl: 8, tr: 8, bl: 0, br: 0 });
          var doorX = b.x + b.w / 2 - 12;
          var doorY = b.y + b.h - 30;
          b.bg.fillStyle(0x00ff41, 0.15);
          b.bg.fillRect(doorX, doorY, 24, 30);
          b.bg.lineStyle(1, 0x00ff41, 0.3);
          b.bg.strokeRect(doorX, doorY, 24, 30);
        }
      }

      activeBuilding = closestBuilding;

      // Check proximity to post boxes for popup
      var foundPost = null;
      if (activeBuilding) {
        var pBoxes = postBoxes[activeBuilding.postBoxesIdx];
        for (var k = 0; k < pBoxes.length; k++) {
          var pb = pBoxes[k];
          var bcx = pb.x + pb.w / 2;
          var bcy = pb.y + pb.h / 2;
          var ddx = px - bcx;
          var ddy = py - bcy;
          if (Math.sqrt(ddx * ddx + ddy * ddy) < 50) {
            foundPost = pb.postData;
            break;
          }
        }
      }

      if (foundPost && foundPost !== nearPost) {
        nearPost = foundPost;
        var titleEl = document.getElementById("archive-popup-title");
        var catEl = document.getElementById("archive-popup-cat");
        var linkEl = document.getElementById("archive-popup-link");
        if (titleEl) titleEl.textContent = foundPost.title;
        if (catEl) catEl.textContent = foundPost.category || "";
        if (linkEl) linkEl.href = "/posts/" + foundPost.id + "/";
        if (popup) popup.style.display = "flex";
      } else if (!foundPost && nearPost) {
        nearPost = null;
        if (popup) popup.style.display = "none";
      }

      // Canvas cursor
      if (this.game && this.game.canvas) {
        var hovering = false;
        if (activeBuilding) {
          var pBoxes = postBoxes[activeBuilding.postBoxesIdx];
          var pointer = this.input.activePointer;
          var wp = cam.getWorldPoint(pointer.x, pointer.y);
          for (var k = 0; k < pBoxes.length; k++) {
            var pb = pBoxes[k];
            if (pb.gfx.visible && wp.x >= pb.x && wp.x <= pb.x + pb.w && wp.y >= pb.y && wp.y <= pb.y + pb.h) {
              hovering = true;
              break;
            }
          }
        }
        this.game.canvas.style.cursor = hovering ? "pointer" : "default";
      }
    }

    // Cleanup
    document.addEventListener("astro:before-swap", function () {
      if (game) { game.destroy(true); game = null; }
    });

    document.addEventListener("astro:page-load", function () {
      var container = document.getElementById("archive-game-container");
      var gameView = document.querySelector('[data-archive-view="game"]');
      if (container && gameView && gameView.style.display !== "none") {
        setTimeout(initGame, 50);
      }
    });
  })();
  </script>
</BaseLayout>

<style>
  .archive-shell {
    width: min(1400px, calc(100vw - 1.5rem));
    margin: 0 auto;
  }

  /* ── Toggle ── */
  .archive-toggle {
    display: flex;
    gap: 0.4rem;
    justify-content: flex-end;
    margin-bottom: 0;
  }

  .archive-toggle__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.12);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 150ms ease;
  }

  .archive-toggle__btn:hover {
    border-color: rgba(124, 255, 122, 0.3);
    color: var(--accent);
  }

  .archive-toggle__btn--active {
    border-color: rgba(124, 255, 122, 0.35);
    background: rgba(124, 255, 122, 0.1);
    color: var(--accent);
  }

  /* ── List view ── */
  .year-block { margin-bottom: 2.5rem; }

  .year-label {
    font-size: 1.4rem;
    font-weight: 900;
    font-family: var(--font-code);
    color: var(--accent);
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    letter-spacing: -0.02em;
  }

  .month-block {
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
  }

  .month-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 0 0.6rem;
  }

  .month-name {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .month-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.3rem;
    height: 1.3rem;
    padding: 0 0.3rem;
    border-radius: 999px;
