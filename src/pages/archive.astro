---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BackButton from "../components/BackButton.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  BLOG_LANGS,
  type BlogLang,
  filterPostsByLang,
  formatDate,
  getPublishedPosts
} from "../lib/blog";

const posts = await getPublishedPosts();

function buildArchive(postsByLang: Awaited<ReturnType<typeof getPublishedPosts>>) {
  const archiveMap = new Map<number, Map<number, typeof postsByLang>>();

  for (const post of postsByLang) {
    const year = post.data.pubDate.getFullYear();
    const month = post.data.pubDate.getMonth() + 1;

    if (!archiveMap.has(year)) archiveMap.set(year, new Map());
    const yearMap = archiveMap.get(year)!;

    if (!yearMap.has(month)) yearMap.set(month, []);
    yearMap.get(month)!.push(post);
  }

  return {
    archiveMap,
    years: [...archiveMap.keys()].sort((a, b) => b - a)
  };
}

const postsByLang = {
  ko: filterPostsByLang(posts, "ko"),
  en: filterPostsByLang(posts, "en")
};

const archiveByLang = BLOG_LANGS.reduce((acc, lang) => {
  acc[lang] = buildArchive(postsByLang[lang]);
  return acc;
}, {} as Record<BlogLang, ReturnType<typeof buildArchive>>);

const monthNames = {
  ko: ["", "1월", "2월", "3월", "4월", "5월", "6월", "7월", "8월", "9월", "10월", "11월", "12월"],
  en: ["", "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
} satisfies Record<BlogLang, string[]>;

// Build game data
const gameDataByLang = BLOG_LANGS.reduce((acc, lang) => {
  const { archiveMap, years } = archiveByLang[lang];
  const buildings: { year: number; month: number; label: string; posts: { title: string; id: string; category: string }[] }[] = [];

  for (const year of years) {
    const yearMap = archiveMap.get(year)!;
    const months = [...yearMap.keys()].sort((a, b) => a - b);
    for (const month of months) {
      const monthPosts = yearMap.get(month)!;
      buildings.push({
        year,
        month,
        label: `${year} ${monthNames[lang][month]}`,
        posts: monthPosts.map(p => ({
          title: p.data.title,
          id: p.id,
          category: p.data.category || ""
        }))
      });
    }
  }

  acc[lang] = buildings;
  return acc;
}, {} as Record<BlogLang, any[]>);
---

<BaseLayout title="Archive" description="Monthly post archives.">
  <Header />
  <BackButton href="/" />

  <main class="archive-shell app-shell">
    <!-- View toggle -->
    <div class="archive-toggle">
      <button class="archive-toggle__btn archive-toggle__btn--active" data-archive-mode="list">
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M3 4h18M3 12h18M3 20h18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>
        <span data-ui-lang="ko">목록</span>
        <span data-ui-lang="en">List</span>
      </button>
      <button class="archive-toggle__btn" data-archive-mode="game">
        <svg viewBox="0 0 24 24" width="16" height="16"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span data-ui-lang="ko">탐험</span>
        <span data-ui-lang="en">Explore</span>
      </button>
    </div>

    <!-- List view -->
    <section class="app-panel archive-list-view" data-archive-view="list">
      {BLOG_LANGS.map((lang) => {
        const langPosts = postsByLang[lang];
        const { archiveMap, years } = archiveByLang[lang];

        return (
          <div data-ui-lang={lang}>
            <div class="section-heading">
              <p class="eyebrow">{lang === "en" ? "Archive" : "아카이브"}</p>
              <h1>{lang === "en" ? "Monthly Archive" : "월별 아카이브"}</h1>
              <p>
                {lang === "en"
                  ? `${langPosts.length} posts across ${years.length} years`
                  : `총 ${langPosts.length}개의 글 / ${years.length}개 연도`}
              </p>
            </div>

            {years.map((year) => {
              const yearMap = archiveMap.get(year)!;
              const months = [...yearMap.keys()].sort((a, b) => b - a);

              return (
                <div class="year-block">
                  <h2 class="year-label">{year}</h2>
                  {months.map((month) => {
                    const monthPosts = yearMap.get(month)!;
                    return (
                      <div class="month-block">
                        <h3 class="month-label">
                          <span class="month-name">{monthNames[lang][month]}</span>
                          <span class="month-count">{monthPosts.length}</span>
                        </h3>
                        <ul class="archive-posts">
                          {monthPosts.map((post) => (
                            <li class="archive-post">
                              <time class="archive-post__date">{formatDate(post.data.pubDate, lang)}</time>
                              <a href={`/posts/${post.id}/`} class="archive-post__title">
                                {post.data.title}
                              </a>
                              {post.data.category && (
                                <span class="archive-post__cat">{post.data.category}</span>
                              )}
                            </li>
                          ))}
                        </ul>
                      </div>
                    );
                  })}
                </div>
              );
            })}
          </div>
        );
      })}
    </section>

    <!-- Game view -->
    <section class="app-panel archive-game-view" data-archive-view="game" style="display:none">
      <div id="archive-game-container"></div>
      <div class="archive-game-hint">
        <kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd>
        <span data-ui-lang="ko">이동 / 건물에 다가가면 포스팅이 보입니다</span>
        <span data-ui-lang="en">Move / Approach buildings to see posts</span>
      </div>
    </section>

    <!-- Post popup -->
    <div id="archive-popup" class="archive-popup" style="display:none">
      <div class="archive-popup__inner">
        <span class="archive-popup__cat" id="archive-popup-cat"></span>
        <h3 id="archive-popup-title"></h3>
        <a id="archive-popup-link" href="/" class="archive-popup__link">
          <span data-ui-lang="ko">읽으러 가기 →</span>
          <span data-ui-lang="en">Read post →</span>
        </a>
      </div>
    </div>
  </main>

  <Footer />

  <script
    id="archive-game-data"
    type="application/json"
    set:html={JSON.stringify(gameDataByLang)}
  />

  <script is:inline src="https://cdn.jsdelivr.net/npm/phaser@3.80.1/dist/phaser.min.js"></script>

  <script is:inline>
  (function () {
    var dataEl = document.getElementById("archive-game-data");
    if (!dataEl) return;
    var allData = JSON.parse(dataEl.textContent || "{}");
    var game = null;

    function getLang() {
      return document.documentElement.dataset.blogLang === "en" ? "en" : "ko";
    }

    // ── Toggle ──
    document.addEventListener("click", function (e) {
      var btn = e.target.closest("[data-archive-mode]");
      if (!btn) return;
      var mode = btn.dataset.archiveMode;
      document.querySelectorAll("[data-archive-mode]").forEach(function (b) {
        b.classList.toggle("archive-toggle__btn--active", b.dataset.archiveMode === mode);
      });
      document.querySelectorAll("[data-archive-view]").forEach(function (v) {
        v.style.display = v.dataset.archiveView === mode ? "" : "none";
      });
      if (mode === "game") { setTimeout(initGame, 50); }
    });

    function initGame() {
      var container = document.getElementById("archive-game-container");
      if (!container) return;
      if (game) { game.destroy(true); game = null; }
      container.innerHTML = "";

      var rect = container.getBoundingClientRect();
      var w = Math.floor(rect.width) || 900;
      var h = Math.max(600, Math.min(800, window.innerHeight * 0.72));

      game = new Phaser.Game({
        type: Phaser.CANVAS,
        parent: "archive-game-container",
        width: w, height: h,
        transparent: true,
        physics: { default: "arcade", arcade: { debug: false } },
        scene: { create: createScene, update: updateScene }
      });
    }

    var player, cursors, keys, cam;
    var buildings = [], postBoxes = [];
    var activeBuilding = null, nearPost = null;
    var BW = 320, BH = 60, BOX_H = 36, BOX_GAP = 6, ROOF = 44;
    var GAP_X = 380, GAP_Y = 80, COLS = 2, PAD = 120;

    function createScene() {
      var scene = this;
      var data = allData[getLang()] || [];
      if (data.length === 0) return;

      // Calculate building heights dynamically
      var maxPosts = 1;
      for (var i = 0; i < data.length; i++) {
        if (data[i].posts.length > maxPosts) maxPosts = data[i].posts.length;
      }

      // Layout: calculate per-building heights
      var bHeights = [];
      for (var i = 0; i < data.length; i++) {
        bHeights.push(ROOF + data[i].posts.length * (BOX_H + BOX_GAP) + 20);
      }

      // Calculate row heights (max of each row)
      var rows = Math.ceil(data.length / COLS);
      var rowHeights = [];
      for (var r = 0; r < rows; r++) {
        var maxH = 0;
        for (var c = 0; c < COLS; c++) {
          var idx = r * COLS + c;
          if (idx < data.length && bHeights[idx] > maxH) maxH = bHeights[idx];
        }
        rowHeights.push(maxH);
      }

      var worldW = COLS * GAP_X + PAD * 2;
      var worldH = PAD * 2 + 80;
      for (var r = 0; r < rows; r++) worldH += rowHeights[r] + GAP_Y;

      scene.cameras.main.setBounds(0, 0, worldW, worldH);
      scene.physics.world.setBounds(0, 0, worldW, worldH);

      // Ground
      var ground = scene.add.graphics();
      ground.fillStyle(0x060e0a, 1);
      ground.fillRect(0, 0, worldW, worldH);

      // Subtle grid
      for (var gx = 0; gx < worldW; gx += 48) {
        ground.lineStyle(1, 0x00ff41, 0.025);
        ground.lineBetween(gx, 0, gx, worldH);
      }
      for (var gy = 0; gy < worldH; gy += 48) {
        ground.lineStyle(1, 0x00ff41, 0.025);
        ground.lineBetween(0, gy, worldW, gy);
      }

      // Road between columns
      var roadX = PAD + BW + (GAP_X - BW) / 2 - 20;
      ground.fillStyle(0x0a1a10, 1);
      ground.fillRect(roadX, 0, 40, worldH);
      ground.lineStyle(1, 0x00ff41, 0.06);
      for (var ry = 0; ry < worldH; ry += 30) {
        ground.lineBetween(roadX + 20, ry, roadX + 20, ry + 15);
      }

      buildings = [];
      postBoxes = [];

      var curY = PAD + 60;
      for (var r = 0; r < rows; r++) {
        for (var c = 0; c < COLS; c++) {
          var idx = r * COLS + c;
          if (idx >= data.length) continue;

          var bData = data[idx];
          var bx = PAD + c * GAP_X;
          var by = curY;
          var bh = bHeights[idx];

          var bg = scene.add.graphics();
          drawBuilding(bg, bx, by, BW, bh, false);

          // Roof label
          var labelText = scene.add.text(bx + BW / 2, by + ROOF / 2, bData.label, {
            fontFamily: "'A2z', monospace",
            fontSize: "16px",
            fontStyle: "bold",
            color: "#00ff41",
            align: "center"
          }).setOrigin(0.5).setDepth(2);

          // Post count (shown when closed)
          var countStr = bData.posts.length + (getLang() === "en" ? " posts" : "개의 글");
          var countText = scene.add.text(bx + BW / 2, by + ROOF + 16, countStr, {
            fontFamily: "'A2z', sans-serif",
            fontSize: "13px",
            color: "#5a8a5a",
            align: "center"
          }).setOrigin(0.5).setDepth(2);

          // Post boxes
          var pBoxes = [];
          for (var j = 0; j < bData.posts.length; j++) {
            var px = bx + 14;
            var py = by + ROOF + 8 + j * (BOX_H + BOX_GAP);
            var pw = BW - 28;

            var boxGfx = scene.add.graphics();
            boxGfx.fillStyle(0x0a1f12, 1);
            boxGfx.fillRoundedRect(px, py, pw, BOX_H, 6);
            boxGfx.lineStyle(1, 0x00cc33, 0.3);
            boxGfx.strokeRoundedRect(px, py, pw, BOX_H, 6);
            boxGfx.setVisible(false).setDepth(3);

            // Category badge
            var catStr = bData.posts[j].category || "";
            var catText = scene.add.text(px + 10, py + 6, catStr.toUpperCase(), {
              fontFamily: "'A2z', sans-serif",
              fontSize: "8px",
              fontStyle: "bold",
              color: "#00aa33",
              letterSpacing: 1
            }).setVisible(false).setDepth(4);

            var titleText = scene.add.text(px + 10, py + 17, bData.posts[j].title, {
              fontFamily: "'A2z', sans-serif",
              fontSize: "12px",
              fontStyle: "bold",
              color: "#d0ffd0",
              wordWrap: { width: pw - 20 }
            }).setVisible(false).setDepth(4);
            // Crop to box
            titleText.setCrop(0, 0, pw - 20, 18);

            pBoxes.push({
              gfx: boxGfx, catText: catText, titleText: titleText,
              x: px, y: py, w: pw, h: BOX_H,
              postData: bData.posts[j]
            });
          }

          postBoxes.push(pBoxes);
          buildings.push({
            x: bx, y: by, w: BW, h: bh,
            data: bData, bg: bg,
            label: labelText, count: countText,
            postBoxesIdx: idx, open: false
          });
        }
        curY += rowHeights[r] + GAP_Y;
      }

      // ── Player ──
      var startX = worldW / 2;
      var startY = PAD;

      var playerGfx = scene.add.graphics();
      // Shadow
      playerGfx.fillStyle(0x000000, 0.3);
      playerGfx.fillEllipse(0, 8, 22, 8);
      // Body
      playerGfx.fillStyle(0x00ff41, 0.9);
      playerGfx.fillRoundedRect(-8, -12, 16, 20, 4);
      // Head
      playerGfx.fillStyle(0x00ff41, 1);
      playerGfx.fillCircle(0, -16, 8);
      // Eyes
      playerGfx.fillStyle(0x001200, 1);
      playerGfx.fillCircle(-3, -17, 2);
      playerGfx.fillCircle(3, -17, 2);
      // Eye highlights
      playerGfx.fillStyle(0xffffff, 0.8);
      playerGfx.fillCircle(-2, -18, 0.8);
      playerGfx.fillCircle(4, -18, 0.8);

      var playerContainer = scene.add.container(startX, startY, [playerGfx]);
      playerContainer.setDepth(10);
      scene.physics.add.existing(playerContainer);
      playerContainer.body.setCollideWorldBounds(true);
      playerContainer.body.setSize(16, 16);
      playerContainer.body.setOffset(-8, -8);
      player = playerContainer;

      cam = scene.cameras.main;
      cam.startFollow(player, true, 0.1, 0.1);

      cursors = scene.input.keyboard.createCursorKeys();
      keys = scene.input.keyboard.addKeys("W,A,S,D");

      // Click post boxes
      scene.input.on("pointerdown", function (pointer) {
        if (!activeBuilding) return;
        var wp = cam.getWorldPoint(pointer.x, pointer.y);
        var pBoxes = postBoxes[activeBuilding.postBoxesIdx];
        for (var k = 0; k < pBoxes.length; k++) {
          var pb = pBoxes[k];
          if (pb.gfx.visible && wp.x >= pb.x && wp.x <= pb.x + pb.w && wp.y >= pb.y && wp.y <= pb.y + pb.h) {
            window.location.href = "/posts/" + pb.postData.id + "/";
            return;
          }
        }
      });
    }

    function drawBuilding(gfx, x, y, w, h, active) {
      gfx.clear();
      // Shadow
      gfx.fillStyle(0x000000, 0.25);
      gfx.fillRoundedRect(x + 4, y + 4, w, h, 10);
      // Main body
      gfx.fillStyle(active ? 0x0f2a18 : 0x0a1a10, 1);
      gfx.fillRoundedRect(x, y, w, h, 10);
      // Border
      gfx.lineStyle(active ? 2 : 1.2, active ? 0x00ff41 : 0x00aa33, active ? 0.8 : 0.4);
      gfx.strokeRoundedRect(x, y, w, h, 10);
      // Roof bar
      gfx.fillStyle(0x00ff41, active ? 0.2 : 0.08);
      gfx.fillRoundedRect(x, y, w, ROOF, { tl: 10, tr: 10, bl: 0, br: 0 });
      // Roof bottom line
      gfx.lineStyle(1, 0x00ff41, active ? 0.3 : 0.1);
      gfx.lineBetween(x + 8, y + ROOF, x + w - 8, y + ROOF);
      // Corner decorations
      var cs = 6;
      gfx.lineStyle(1.5, 0x00ff41, active ? 0.5 : 0.15);
      // top-left
      gfx.lineBetween(x + 3, y + cs + 10, x + 3, y + 14);
      gfx.lineBetween(x + 3, y + 14, x + cs + 3, y + 14);
      // top-right
      gfx.lineBetween(x + w - 3, y + cs + 10, x + w - 3, y + 14);
      gfx.lineBetween(x + w - 3, y + 14, x + w - cs - 3, y + 14);
      // bottom-left
      gfx.lineBetween(x + 3, y + h - cs - 4, x + 3, y + h - 4);
      gfx.lineBetween(x + 3, y + h - 4, x + cs + 3, y + h - 4);
      // bottom-right
      gfx.lineBetween(x + w - 3, y + h - cs - 4, x + w - 3, y + h - 4);
      gfx.lineBetween(x + w - 3, y + h - 4, x + w - cs - 3, y + h - 4);
      if (active) {
        // Glow effect
        gfx.lineStyle(4, 0x00ff41, 0.06);
        gfx.strokeRoundedRect(x - 3, y - 3, w + 6, h + 6, 12);
      }
    }

    function updateScene() {
      if (!player) return;

      var speed = 220;
      var vx = 0, vy = 0;
      if (keys.A.isDown || cursors.left.isDown) vx = -speed;
      else if (keys.D.isDown || cursors.right.isDown) vx = speed;
      if (keys.W.isDown || cursors.up.isDown) vy = -speed;
      else if (keys.S.isDown || cursors.down.isDown) vy = speed;
      if (vx !== 0 && vy !== 0) { vx *= 0.707; vy *= 0.707; }
      player.body.setVelocity(vx, vy);

      var px = player.x, py = player.y;
      var popup = document.getElementById("archive-popup");
      var closestBuilding = null;
      var closestDist = Infinity;

      for (var i = 0; i < buildings.length; i++) {
        var b = buildings[i];
        // Check if player is near building
        var cx = b.x + b.w / 2;
        var cy = b.y + b.h / 2;
        var dx = px - cx, dy = py - cy;
        var dist = Math.sqrt(dx * dx + dy * dy);
        var threshold = Math.max(b.w, b.h) * 0.7;

        if (dist < threshold && dist < closestDist) {
          closestDist = dist;
          closestBuilding = b;
        }
      }

      for (var i = 0; i < buildings.length; i++) {
        var b = buildings[i];
        var shouldOpen = b === closestBuilding;
        if (shouldOpen && !b.open) {
          b.open = true;
          b.count.setVisible(false);
          drawBuilding(b.bg, b.x, b.y, b.w, b.h, true);
          var pBoxes = postBoxes[b.postBoxesIdx];
          for (var j = 0; j < pBoxes.length; j++) {
            pBoxes[j].gfx.setVisible(true);
            pBoxes[j].catText.setVisible(true);
            pBoxes[j].titleText.setVisible(true);
          }
        } else if (!shouldOpen && b.open) {
          b.open = false;
          b.count.setVisible(true);
          drawBuilding(b.bg, b.x, b.y, b.w, b.h, false);
          var pBoxes = postBoxes[b.postBoxesIdx];
          for (var j = 0; j < pBoxes.length; j++) {
            pBoxes[j].gfx.setVisible(false);
            pBoxes[j].catText.setVisible(false);
            pBoxes[j].titleText.setVisible(false);
          }
        }
      }
      activeBuilding = closestBuilding;

      // Popup for nearest post
      var foundPost = null;
      if (activeBuilding) {
        var pBoxes = postBoxes[activeBuilding.postBoxesIdx];
        var bestDist = Infinity;
        for (var k = 0; k < pBoxes.length; k++) {
          var pb = pBoxes[k];
          var bcx = pb.x + pb.w / 2, bcy = pb.y + pb.h / 2;
          var d = Math.sqrt((px - bcx) * (px - bcx) + (py - bcy) * (py - bcy));
          if (d < 80 && d < bestDist) { bestDist = d; foundPost = pb.postData; }
        }
      }

      if (foundPost && foundPost !== nearPost) {
        nearPost = foundPost;
        var titleEl = document.getElementById("archive-popup-title");
        var catEl = document.getElementById("archive-popup-cat");
        var linkEl = document.getElementById("archive-popup-link");
        if (titleEl) titleEl.textContent = foundPost.title;
        if (catEl) { catEl.textContent = foundPost.category || ""; catEl.style.display = foundPost.category ? "" : "none"; }
        if (linkEl) linkEl.href = "/posts/" + foundPost.id + "/";
        if (popup) popup.style.display = "flex";
      } else if (!foundPost && nearPost) {
        nearPost = null;
        if (popup) popup.style.display = "none";
      }

      // Cursor
      if (this.game && this.game.canvas) {
        var hovering = false;
        if (activeBuilding) {
          var ptr = this.input.activePointer;
          var wp = cam.getWorldPoint(ptr.x, ptr.y);
          var pBoxes = postBoxes[activeBuilding.postBoxesIdx];
          for (var k = 0; k < pBoxes.length; k++) {
            var pb = pBoxes[k];
            if (pb.gfx.visible && wp.x >= pb.x && wp.x <= pb.x + pb.w && wp.y >= pb.y && wp.y <= pb.y + pb.h) { hovering = true; break; }
          }
        }
        this.game.canvas.style.cursor = hovering ? "pointer" : "default";
      }
    }

    document.addEventListener("astro:before-swap", function () {
      if (game) { game.destroy(true); game = null; }
    });
    document.addEventListener("astro:page-load", function () {
      var c = document.getElementById("archive-game-container");
      var gv = document.querySelector('[data-archive-view="game"]');
      if (c && gv && gv.style.display !== "none") setTimeout(initGame, 50);
    });
  })();
  </script>
</BaseLayout>

<style>
  .archive-shell {
    width: min(1400px, calc(100vw - 1.5rem));
    margin: 0 auto;
  }

  /* ── Toggle ── */
  .archive-toggle {
    display: flex;
    gap: 0.4rem;
    justify-content: flex-end;
    margin-bottom: 0;
  }

  .archive-toggle__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.12);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 150ms ease;
  }

  .archive-toggle__btn:hover {
    border-color: rgba(124, 255, 122, 0.3);
    color: var(--accent);
  }

  .archive-toggle__btn--active {
