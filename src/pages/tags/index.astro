---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  BLOG_LANGS,
  type BlogLang,
  filterPostsByLang,
  getPublishedPosts
} from "../../lib/blog";

const posts = await getPublishedPosts();

const postsByLang = {
  ko: filterPostsByLang(posts, "ko"),
  en: filterPostsByLang(posts, "en")
};

const tagsByLang = BLOG_LANGS.reduce((acc, lang) => {
  const tagMap = new Map<string, number>();

  for (const post of postsByLang[lang]) {
    for (const tag of post.data.tags) {
      tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
    }
  }

  acc[lang] = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
  return acc;
}, {} as Record<BlogLang, [string, number][]>);

const maxCountByLang = BLOG_LANGS.reduce((acc, lang) => {
  acc[lang] = Math.max(...tagsByLang[lang].map(([, count]) => count), 1);
  return acc;
}, {} as Record<BlogLang, number>);
---

<BaseLayout title="Tags" description="Browse tags by language.">
  <Header />

  <main class="shell app-shell">
    <section class="app-panel">
      {BLOG_LANGS.map((lang) => {
        const tags = tagsByLang[lang];

        return (
          <div data-ui-lang={lang}>
            <div class="section-heading">
              <p class="eyebrow">{lang === "en" ? "Tags" : "태그"}</p>
              <h1>{lang === "en" ? "Tags" : "태그 목록"}</h1>
              <p>
                {lang === "en"
                  ? `${tags.length} tags, ${postsByLang[lang].length} posts`
                  : `총 ${tags.length}개의 태그, ${postsByLang[lang].length}개의 글`}
              </p>
            </div>

            {tags.length === 0 ? (
              <p class="empty">{lang === "en" ? "No tags yet." : "아직 태그가 없습니다."}</p>
            ) : (
              <ul class="tag-cloud" aria-label={lang === "en" ? "Tag cloud" : "태그 클라우드"}>
                {tags.map(([tag, count]) => {
                  const size = 0.8 + (count / maxCountByLang[lang]) * 0.8;
                  return (
                    <li>
                      <a href={`/tags/${encodeURIComponent(tag)}/`} style={`font-size: ${size}rem`}>
                        {tag}
                        <span class="tag-count">{count}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            )}
          </div>
        );
      })}
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .tag-cloud {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 0.9rem;
    line-height: 1.4;
  }

  .tag-cloud a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--accent-soft);
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.03em;
    transition: border-color 150ms, background 150ms, transform 150ms;
  }

  .tag-cloud a:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    transform: translateY(-2px);
  }

  .tag-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.2rem;
    height: 1.2rem;
    padding: 0 0.25rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--muted);
    font-size: 0.65rem;
    font-weight: 700;
  }

  .empty {
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
