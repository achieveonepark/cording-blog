---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import BackButton from "../../components/BackButton.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  BLOG_LANGS,
  type BlogLang,
  filterPostsByLang,
  getPublishedPosts
} from "../../lib/blog";

const posts = await getPublishedPosts();

const postsByLang = {
  ko: filterPostsByLang(posts, "ko"),
  en: filterPostsByLang(posts, "en")
};

const tagsByLang = BLOG_LANGS.reduce((acc, lang) => {
  const tagMap = new Map<string, number>();

  for (const post of postsByLang[lang]) {
    for (const tag of post.data.tags) {
      tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
    }
  }

  acc[lang] = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
  return acc;
}, {} as Record<BlogLang, [string, number][]>);
---

<BaseLayout title="Tags" description="Browse tags by language.">
  <Header />
  <BackButton href="/" />

  <main class="tag-game-shell app-shell">
    <section class="app-panel tag-game-panel">
      <div class="section-heading">
        <p class="eyebrow">
          <span data-ui-lang="ko">태그</span>
          <span data-ui-lang="en">Tags</span>
        </p>
        <h1>
          <span data-ui-lang="ko">태그 목록</span>
          <span data-ui-lang="en">Tags</span>
        </h1>
        <p>
          <span data-ui-lang="ko">공을 클릭하면 해당 태그의 글로 이동합니다.</span>
          <span data-ui-lang="en">Click a ball to browse posts by tag.</span>
        </p>
      </div>

      <div id="tag-game-container"></div>

      <p class="tag-hint">
        <kbd>Ctrl</kbd>
        <span data-ui-lang="ko">키를 누르면 바람이 붑니다</span>
        <span data-ui-lang="en">Press to blow wind</span>
      </p>
    </section>
  </main>

  <Footer />

  <script
    id="tag-data"
    type="application/json"
    set:html={JSON.stringify({ ko: tagsByLang.ko, en: tagsByLang.en })}
  />

  <script is:inline src="https://cdn.jsdelivr.net/npm/phaser@3.80.1/dist/phaser.min.js"></script>

  <script is:inline>
  (function () {
    var tagDataEl = document.getElementById("tag-data");
    if (!tagDataEl) return;
    var allTagData = JSON.parse(tagDataEl.textContent || "{}");
    var game = null;
    var sceneBalls = [];
    var sceneRef = null;

    function getCurrentLang() {
      return document.documentElement.dataset.blogLang === "en" ? "en" : "ko";
    }

    function getTagData() {
      return allTagData[getCurrentLang()] || [];
    }

    function createGame() {
      if (typeof Phaser === "undefined") return;

      var container = document.getElementById("tag-game-container");
      if (!container) return;

      if (game) {
        game.destroy(true);
        game = null;
        sceneBalls = [];
        sceneRef = null;
      }

      // clear container
      container.innerHTML = "";

      var w = container.offsetWidth || container.parentElement.offsetWidth || Math.floor(window.innerWidth * 0.9);
      if (w < 100) w = Math.floor(window.innerWidth * 0.9);
      var h = Math.max(550, Math.min(800, window.innerHeight * 0.72));

      game = new Phaser.Game({
        type: Phaser.CANVAS,
        parent: "tag-game-container",
        width: w,
        height: h,
        transparent: true,
        physics: {
          default: "matter",
          matter: { gravity: { x: 0, y: 0.6 }, debug: false }
        },
        scene: { create: onCreateScene }
      });
    }

    function onCreateScene() {
      sceneRef = this;
      var scene = this;
      var tags = getTagData();
      if (tags.length === 0) return;

      var w = scene.scale.width;
      var h = scene.scale.height;

      var maxCount = 1;
      for (var i = 0; i < tags.length; i++) {
        if (tags[i][1] > maxCount) maxCount = tags[i][1];
      }

      // Walls
      var wallOpts = { isStatic: true, restitution: 0.5, friction: 0.05 };
      scene.matter.add.rectangle(w / 2, h + 25, w + 100, 50, wallOpts);
      scene.matter.add.rectangle(w / 2, -25, w + 100, 50, wallOpts);
      scene.matter.add.rectangle(-25, h / 2, 50, h + 100, wallOpts);
      scene.matter.add.rectangle(w + 25, h / 2, 50, h + 100, wallOpts);

      var minR = 36;
      var maxR = 90;
      sceneBalls = [];

      var colors = [
        0x00ff41, 0x00cc33, 0x33ff66, 0x66ff99,
        0x00dd55, 0x22ee44, 0x44ff77, 0x11cc55,
        0x00bb44, 0x55ff88
      ];

      for (var i = 0; i < tags.length; i++) {
        var tag = tags[i][0];
        var count = tags[i][1];
        var ratio = count / maxCount;
        var r = minR + ratio * (maxR - minR);

        var x = Phaser.Math.Between(r + 20, w - r - 20);
        var y = Phaser.Math.Between(r + 20, h / 2);
        var color = colors[i % colors.length];

        var ball = scene.matter.add.circle(x, y, r, {
          restitution: 0.65,
          friction: 0.02,
          frictionAir: 0.008,
          density: 0.002,
          label: "tag-ball"
        });

        scene.matter.body.setVelocity(ball, {
          x: Phaser.Math.Between(-3, 3),
          y: Phaser.Math.Between(-2, 2)
        });

        var gfx = scene.add.graphics();
        gfx.fillStyle(color, 0.12);
        gfx.fillCircle(0, 0, r + 6);
        gfx.lineStyle(1.5, color, 0.5);
        gfx.strokeCircle(0, 0, r);
        gfx.fillStyle(color, 0.15);
        gfx.fillCircle(0, 0, r);
        gfx.fillStyle(0xffffff, 0.06);
        gfx.fillCircle(-r * 0.2, -r * 0.25, r * 0.5);

        var fontSize = Math.max(10, Math.min(16, r * 0.38));
        var countSize = Math.max(8, fontSize - 3);

        var label = scene.add.text(0, -countSize * 0.4, tag, {
          fontFamily: "'A2z', sans-serif",
          fontSize: fontSize + "px",
          fontStyle: "bold",
          color: "#" + color.toString(16).padStart(6, "0"),
          align: "center",
          wordWrap: { width: r * 1.6 }
        }).setOrigin(0.5);

        var countLabel = scene.add.text(0, label.y + fontSize * 0.8 + 2, String(count), {
          fontFamily: "'A2z', sans-serif",
          fontSize: countSize + "px",
          color: "#97a2ad",
          align: "center"
        }).setOrigin(0.5);

        var containerObj = scene.add.container(x, y, [gfx, label, countLabel]);

        sceneBalls.push({
          body: ball,
          container: containerObj,
          radius: r,
          tag: tag,
          color: color
        });
      }

      // Update positions
      scene.events.on("update", function () {
        for (var i = 0; i < sceneBalls.length; i++) {
          var b = sceneBalls[i];
          b.container.setPosition(b.body.position.x, b.body.position.y);
          b.container.setRotation(b.body.angle);
        }
      });

      // Click
      scene.input.on("pointerdown", function (pointer) {
        for (var i = 0; i < sceneBalls.length; i++) {
          var b = sceneBalls[i];
          var dx = pointer.x - b.body.position.x;
          var dy = pointer.y - b.body.position.y;
          if (Math.sqrt(dx * dx + dy * dy) < b.radius) {
            var flash = scene.add.graphics();
            flash.fillStyle(b.color, 0.35);
            flash.fillCircle(0, 0, b.radius + 8);
            flash.setPosition(b.body.position.x, b.body.position.y);
            scene.tweens.add({
              targets: flash, alpha: 0, scaleX: 1.4, scaleY: 1.4,
              duration: 300, onComplete: function () { flash.destroy(); }
            });
            var encodedTag = encodeURIComponent(b.tag);
            setTimeout(function () {
              window.location.href = "/tags/" + encodedTag + "/";
            }, 200);
            return;
          }
        }
      });

      // Hover cursor
      scene.input.on("pointermove", function (pointer) {
        var hovering = false;
        for (var i = 0; i < sceneBalls.length; i++) {
          var b = sceneBalls[i];
          var dx = pointer.x - b.body.position.x;
          var dy = pointer.y - b.body.position.y;
          if (Math.sqrt(dx * dx + dy * dy) < b.radius) { hovering = true; break; }
        }
        scene.game.canvas.style.cursor = hovering ? "pointer" : "default";
      });

      // Drag to push
      var isDragging = false;
      scene.input.on("pointerdown", function () { isDragging = true; });
      scene.input.on("pointerup", function () { isDragging = false; });
      scene.input.on("pointermove", function (pointer) {
        if (!isDragging) return;
        for (var i = 0; i < sceneBalls.length; i++) {
          var b = sceneBalls[i];
          var dx = pointer.x - b.body.position.x;
          var dy = pointer.y - b.body.position.y;
          if (Math.sqrt(dx * dx + dy * dy) < b.radius + 20) {
            scene.matter.body.applyForce(b.body, b.body.position, {
              x: (pointer.x - pointer.prevPosition.x) * 0.003,
              y: (pointer.y - pointer.prevPosition.y) * 0.003
            });
          }
        }
      });
    }

    // Wind on Ctrl key
    function applyWind() {
      if (!sceneRef || sceneBalls.length === 0) return;
      for (var i = 0; i < sceneBalls.length; i++) {
        var b = sceneBalls[i];
        var forceX = (Math.random() - 0.5) * 0.25;
        var forceY = -(Math.random() * 0.2 + 0.15);
        sceneRef.matter.body.applyForce(b.body, b.body.position, { x: forceX, y: forceY });
      }
    }

    document.addEventListener("keydown", function (e) {
      if (e.key === "Control" && !e.repeat) {
        applyWind();
      }
    });

    // Init - wait for Phaser to load, then create game
    var initAttempts = 0;
    function tryInit() {
      var container = document.getElementById("tag-game-container");
      if (!container) return;

      if (typeof Phaser === "undefined") {
        initAttempts++;
        if (initAttempts < 50) {
          setTimeout(tryInit, 100);
        }
        return;
      }

      if (container.offsetWidth < 100) {
        initAttempts++;
        if (initAttempts < 50) {
          setTimeout(tryInit, 100);
        }
        return;
      }

      createGame();
    }

    tryInit();

    // Language change
    document.addEventListener("blog-language-sync", function () {
      setTimeout(createGame, 50);
    });

    // Resize
    var resizeTimer;
    window.addEventListener("resize", function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(createGame, 300);
    });

    // Astro page transitions
    document.addEventListener("astro:page-load", function () {
      initAttempts = 0;
      setTimeout(tryInit, 50);
    });

    document.addEventListener("astro:before-swap", function () {
      if (game) {
        game.destroy(true);
        game = null;
        sceneBalls = [];
        sceneRef = null;
      }
    });
  })();
  </script>
</BaseLayout>

<style>
  .tag-game-shell {
    width: min(1400px, calc(100vw - 1.5rem));
    margin: 0 auto;
  }

  .tag-game-panel {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    box-sizing: border-box;
  }

  #tag-game-container {
    width: 100%;
    max-width: 100%;
    min-height: 500px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(124, 255, 122, 0.08);
    overflow: hidden;
    margin-top: 1rem;
    box-sizing: border-box;
  }

  #tag-game-container canvas {
    display: block;
    width: 100% !important;
  }

  .tag-hint {
    margin-top: 0.8rem;
    font-size: 0.72rem;
    color: var(--muted);
    opacity: 0.6;
    text-align: center;
  }

  .tag-hint kbd {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    border: 1px solid rgba(124, 255, 122, 0.2);
    background: rgba(124, 255, 122, 0.08);
    color: var(--accent);
    font-family: var(--font-code);
    font-size: 0.68rem;
    font-weight: 700;
    margin-right: 0.3rem;
  }
</style>
