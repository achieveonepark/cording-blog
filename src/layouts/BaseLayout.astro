---
import { ClientRouter } from "astro:transitions";
import { site } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = site.title,
  description = site.description,
  image
} = Astro.props;

const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url);
const ogImage = image
  ? (image.startsWith("http") ? image : new URL(image, site.url).toString())
  : `${site.url}/og-default.png`;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";
---

<!doctype html>
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05080c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS`} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{pageTitle}</title>

    <!-- 테마 초기화 (FOUC 방지) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem("theme");
        const preferred = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
        document.documentElement.dataset.theme = stored || preferred;
      })();
    </script>

    <!-- Google Analytics GA4 -->
    {gaId && (
      <>
        <script is:inline define:vars={{ gaId }} async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, { send_page_view: false });
        </script>
      </>
    )}

    <ClientRouter />
  </head>
  <body class="matrix-theme">
    <canvas class="matrix-canvas" data-matrix-canvas aria-hidden="true" transition:persist></canvas>
    <div class="scanlines" aria-hidden="true" transition:persist></div>
    <div class="page-shell">
      <slot />
    </div>

    <!-- 테마 토글 버튼 -->
    <button id="theme-toggle" aria-label="테마 전환" title="라이트/다크 모드 전환">
      <svg id="theme-icon-dark" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
        <circle cx="12" cy="12" r="5" fill="none" stroke="currentColor" stroke-width="1.8"/>
        <line x1="12" y1="2" x2="12" y2="4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="12" y1="20" x2="12" y2="22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="2" y1="12" x2="4" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="20" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
      <svg id="theme-icon-light" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" style="display:none">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- 관리자 플로팅 버튼 -->
    <div id="fab-group" style="display:none">
      <a id="fab-settings" href="/admin/settings" aria-label="설정" title="설정">
        <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
          <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.8"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" fill="none" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        <span>설정</span>
      </a>
      <a id="fab-new-post" href="/admin/new-post" aria-label="새 글 쓰기" title="새 글 쓰기">
        <svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
          <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
        <span>글쓰기</span>
      </a>
    </div>

    <script>
      const OWNER = "achieveonepark";
      const fabGroup = document.getElementById("fab-group");
      const token = localStorage.getItem("gh_token");
      if (token && fabGroup) {
        fetch("https://api.github.com/user", {
          headers: { Authorization: `Bearer ${token}` },
        })
          .then((r) => r.json())
          .then((u) => {
            if (u.login === OWNER) fabGroup.style.display = "flex";
          })
          .catch(() => {});
      }

      // 테마 토글
      function syncThemeIcons(theme: string) {
        const darkIcon  = document.getElementById("theme-icon-dark");
        const lightIcon = document.getElementById("theme-icon-light");
        if (!darkIcon || !lightIcon) return;
        if (theme === "light") {
          darkIcon.style.display  = "none";
          lightIcon.style.display = "";
        } else {
          darkIcon.style.display  = "";
          lightIcon.style.display = "none";
        }
      }

      function applyTheme(theme: string) {
        document.documentElement.dataset.theme = theme;
        localStorage.setItem("theme", theme);
        syncThemeIcons(theme);
      }

      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const current = document.documentElement.dataset.theme ?? "dark";
        applyTheme(current === "dark" ? "light" : "dark");
      });

      // 스크롤 위치 저장/복원
      const SCROLL_NS = "scroll:";

      document.addEventListener("astro:before-swap", () => {
        sessionStorage.setItem(SCROLL_NS + location.pathname, String(window.scrollY));
      });

      document.addEventListener("astro:page-load", () => {
        // 브라우저 뒤로가기/앞으로가기일 때만 복원
        const nav = (performance.getEntriesByType("navigation")[0] as PerformanceNavigationTiming | undefined);
        const isBackForward = nav?.type === "back_forward";
        const saved = sessionStorage.getItem(SCROLL_NS + location.pathname);

        if (isBackForward && saved) {
          requestAnimationFrame(() => window.scrollTo({ top: parseInt(saved, 10), behavior: "instant" }));
        }
      });

      // Astro 페이지 전환 후에도 아이콘 동기화
      document.addEventListener("astro:page-load", () => {
        syncThemeIcons(document.documentElement.dataset.theme ?? "dark");

        // GA4 SPA 페이지뷰
        if (typeof window.gtag === "function") {
          window.gtag("event", "page_view", {
            page_path: window.location.pathname,
            page_title: document.title,
          });
        }
      });
    </script>

    <style>
      #theme-toggle {
        position: fixed;
        bottom: 2rem;
        left: 2rem;
        z-index: 100;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.4rem;
        height: 2.4rem;
        border-radius: 50%;
        border: 1px solid var(--border);
        background: var(--panel);
        color: var(--muted);
        cursor: pointer;
        backdrop-filter: blur(12px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
        transition: border-color 180ms, background 180ms, color 180ms, transform 180ms;
      }

      #theme-toggle:hover {
        color: var(--accent);
        border-color: var(--accent);
        transform: scale(1.08);
      }

      #fab-group {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 100;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.6rem;
      }

      #fab-group a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.1rem;
        border-radius: 999px;
        border: 1px solid rgba(124, 255, 122, 0.3);
        background: rgba(10, 15, 19, 0.88);
        backdrop-filter: blur(12px);
        color: #7cff7a;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-decoration: none;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
        transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
      }

      #fab-settings {
        color: rgba(124, 255, 122, 0.55) !important;
        border-color: rgba(124, 255, 122, 0.15) !important;
        font-size: 0.76rem !important;
      }

      #fab-group a:hover {
        background: rgba(124, 255, 122, 0.1);
        border-color: rgba(124, 255, 122, 0.55);
        color: #7cff7a !important;
        transform: translateY(-2px);
      }

      /* ── 스캔라인 ─────────────────────────────────────────── */
      .scanlines {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        background: repeating-linear-gradient(
          to bottom,
          transparent 0px,
          transparent 3px,
          rgba(0, 0, 0, 0.1) 3px,
          rgba(0, 0, 0, 0.1) 4px
        );
      }

      @media (prefers-reduced-motion: reduce) {
        .scanlines { display: none; }
      }
    </style>

    <script is:inline>
      const canvas = document.querySelector("[data-matrix-canvas]");

      // transition:persist로 canvas가 유지되므로 최초 1회만 초기화
      if (canvas instanceof HTMLCanvasElement && !canvas.dataset.initialized) {
        canvas.dataset.initialized = "true";
        const context = canvas.getContext("2d");

        if (context) {
          const motionPreference = window.matchMedia("(prefers-reduced-motion: reduce)");
          const glyphs = ["0", "1"];
          const monoStack = '"SFMono-Regular", Consolas, "Liberation Mono", monospace';

          let width = 0;
          let height = 0;
          let cellSize = 18;
          let animationFrame = 0;
          let lastTimestamp = 0;
          let columns = [];

          const randomGlyph = () => glyphs[Math.floor(Math.random() * glyphs.length)];

          const createColumn = (index) => ({
            x: index * cellSize + Math.random() * cellSize * 0.35,
            y: height + Math.random() * height * 1.35,
            speed: 54 + Math.random() * 132,
            length: 8 + Math.floor(Math.random() * 18),
            brightness: 0.35 + Math.random() * 0.65
          });

          const resetColumn = (column, index) => {
            column.x = index * cellSize + Math.random() * cellSize * 0.35;
            column.y = height + Math.random() * height * 0.75;
            column.speed = 54 + Math.random() * 132;
            column.length = 8 + Math.floor(Math.random() * 18);
            column.brightness = 0.35 + Math.random() * 0.65;
          };

          const paintBackdrop = () => {
            context.clearRect(0, 0, width, height);
            context.fillStyle = "#05080c";
            context.fillRect(0, 0, width, height);
          };

          const resizeCanvas = () => {
            const dpr = Math.min(window.devicePixelRatio || 1, 2);
            width = window.innerWidth;
            height = window.innerHeight;
            cellSize = width < 540 ? 14 : width < 900 ? 16 : 18;

            canvas.width = Math.floor(width * dpr);
            canvas.height = Math.floor(height * dpr);
            canvas.style.width = `${width}px`;
            canvas.style.height = `${height}px`;

            context.setTransform(dpr, 0, 0, dpr, 0, 0);
            context.font = `${cellSize}px ${monoStack}`;
            context.textBaseline = "top";

            const columnCount = Math.ceil(width / cellSize);
            columns = Array.from({ length: columnCount }, (_, index) => createColumn(index));
            if (motionPreference.matches) {
              drawStaticFrame();
            } else {
              paintBackdrop();
            }
          };

          const drawStaticFrame = () => {
            paintBackdrop();

            const count = Math.max(36, Math.floor((width * height) / 18000));

            for (let index = 0; index < count; index += 1) {
              const x = Math.random() * width;
              const y = Math.random() * height;
              const alpha = 0.18 + Math.random() * 0.28;

              context.fillStyle = `rgba(124, 255, 122, ${alpha})`;
              context.fillText(randomGlyph(), x, y);
            }
          };

          const stopAnimation = () => {
            if (animationFrame) {
              window.cancelAnimationFrame(animationFrame);
              animationFrame = 0;
            }
          };

          const frame = (timestamp) => {
            if (document.hidden) {
              stopAnimation();
              return;
            }

            const delta = lastTimestamp
              ? Math.min((timestamp - lastTimestamp) / 1000, 0.05)
              : 0.016;

            lastTimestamp = timestamp;

            context.fillStyle = "rgba(5, 8, 12, 0.22)";
            context.fillRect(0, 0, width, height);

            columns.forEach((column, index) => {
              column.y -= column.speed * delta;

              if (column.y + column.length * cellSize < -cellSize) {
                resetColumn(column, index);
              }

              for (let step = 0; step < column.length; step += 1) {
                const y = column.y + step * cellSize;

                if (y < -cellSize || y > height + cellSize) {
                  continue;
                }

                const isHead = step === 0;
                const opacity = isHead
                  ? Math.min(1, column.brightness * 0.95 + 0.15)
                  : (1 - step / column.length) * column.brightness * 0.78;

                context.fillStyle = isHead
                  ? `rgba(214, 255, 214, ${opacity})`
                  : `rgba(124, 255, 122, ${opacity})`;

                context.fillText(randomGlyph(), column.x, y);
              }
            });

            animationFrame = window.requestAnimationFrame(frame);
          };

          const startAnimation = () => {
            stopAnimation();
            lastTimestamp = 0;

            if (motionPreference.matches) {
              drawStaticFrame();
              return;
            }

            paintBackdrop();
            animationFrame = window.requestAnimationFrame(frame);
          };

          resizeCanvas();
          startAnimation();

          window.addEventListener("resize", resizeCanvas, { passive: true });
          document.addEventListener("visibilitychange", () => {
            if (document.hidden) {
              stopAnimation();
            } else {
              startAnimation();
            }
          });

          motionPreference.addEventListener("change", startAnimation);
        }
      }
    </script>
  </body>
</html>
