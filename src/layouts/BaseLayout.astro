---
import { ClientRouter } from "astro:transitions";
import { site } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = site.title,
  description = site.description,
  image
} = Astro.props;

const pageTitle = title === site.title ? title : `${title} | ${site.title}`;
const canonicalUrl = new URL(Astro.url.pathname, site.url);
const ogImage = image
  ? (image.startsWith("http") ? image : new URL(image, site.url).toString())
  : `${site.url}/og-default.png`;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? "";
---

<!doctype html>
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#05080c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS`} href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{pageTitle}</title>

    <!-- Google Analytics GA4 -->
    {gaId && (
      <>
        <script is:inline define:vars={{ gaId }} async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId, { send_page_view: false });
        </script>
      </>
    )}

    <ClientRouter />
  </head>
  <body class="matrix-theme">
    <canvas class="matrix-canvas" data-matrix-canvas aria-hidden="true" transition:persist></canvas>
    <div class="scanlines" aria-hidden="true" transition:persist></div>
    <div class="page-shell">
      <slot />
    </div>

    <!-- 관리자 플로팅 버튼 -->
    <div id="fab-group" style="display:none">
      <a id="fab-settings" href="/admin/settings" aria-label="설정" title="설정">
        <svg viewBox="0 0 24 24" aria-hidden="true" width="16" height="16">
          <circle cx="12" cy="12" r="3" fill="none" stroke="currentColor" stroke-width="1.8"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" fill="none" stroke="currentColor" stroke-width="1.8"/>
        </svg>
        <span>설정</span>
      </a>
      <a id="fab-new-post" href="/admin/new-post" aria-label="새 글 쓰기" title="새 글 쓰기">
        <svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
          <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
          <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
        <span>글쓰기</span>
      </a>
    </div>

    <script>
      const OWNER = "achieveonepark";
      const fabGroup = document.getElementById("fab-group");
      const token = localStorage.getItem("gh_token");
      if (token && fabGroup) {
        fetch("https://api.github.com/user", {
          headers: { Authorization: `Bearer ${token}` },
        })
          .then((r) => r.json())
          .then((u) => {
            if (u.login === OWNER) fabGroup.style.display = "flex";
          })
          .catch(() => {});
      }

      // 스크롤 위치 저장/복원
      const SCROLL_NS = "scroll:";

      document.addEventListener("astro:before-swap", () => {
        sessionStorage.setItem(SCROLL_NS + location.pathname, String(window.scrollY));
      });

      document.addEventListener("astro:page-load", () => {
        // 브라우저 뒤로가기/앞으로가기일 때만 복원
        const nav = (performance.getEntriesByType("navigation")[0] as PerformanceNavigationTiming | undefined);
        const isBackForward = nav?.type === "back_forward";
        const saved = sessionStorage.getItem(SCROLL_NS + location.pathname);

        if (isBackForward && saved) {
          requestAnimationFrame(() => window.scrollTo({ top: parseInt(saved, 10), behavior: "instant" }));
        }
      });

      document.addEventListener("astro:page-load", () => {
        // GA4 SPA 페이지뷰
        if (typeof window.gtag === "function") {
          window.gtag("event", "page_view", {
            page_path: window.location.pathname,
            page_title: document.title,
          });
        }
      });
    </script>

    <!-- 언어 필터링 (리스팅 페이지의 post-card를 lang 기준으로 필터) -->
    <script is:inline>
      function filterByLang() {
        var lang = localStorage.getItem('blog_lang') || 'ko';
        var cards = document.querySelectorAll('.post-card[data-lang]');
        cards.forEach(function(card) {
          var show = card.dataset.lang === lang;
          card.style.display = show ? '' : 'none';
        });
      }
      // 페이지 로드 시 필터
      filterByLang();
      // 언어 변경 이벤트 수신
      if (!window.__langFilterInit) {
        window.__langFilterInit = true;
        window.addEventListener('lang-change', filterByLang);
      }
    </script>

    <style>
      #fab-group {
        position: fixed;
        bottom: 2rem;
        right: 2rem;
        z-index: 100;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.6rem;
      }

      #fab-group a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.1rem;
        border-radius: 999px;
        border: 1px solid rgba(124, 255, 122, 0.3);
        background: rgba(10, 15, 19, 0.88);
        backdrop-filter: blur(12px);
        color: #7cff7a;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-decoration: none;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
        transition: background 180ms ease, border-color 180ms ease, transform 180ms ease;
      }

      #fab-settings {
        color: rgba(124, 255, 122, 0.55) !important;
        border-color: rgba(124, 255, 122, 0.15) !important;
        font-size: 0.76rem !important;
      }

      #fab-group a:hover {
        background: rgba(124, 255, 122, 0.1);
        border-color: rgba(124, 255, 122, 0.55);
        color: #7cff7a !important;
        transform: translateY(-2px);
      }

      /* ── 스캔라인 ─────────────────────────────────────────── */
      .scanlines {
        position: fixed;
        inset: 0;
        z-index: 9998;
        pointer-events: none;
        background: repeating-linear-gradient(
          to bottom,
          transparent 0px,
          transparent 3px,
          rgba(0, 0, 0, 0.1) 3px,
          rgba(0, 0, 0, 0.1) 4px
        );
      }

      @media (prefers-reduced-motion: reduce) {
        .scanlines { display: none; }
      }
    </style>

    <script is:inline>
      (function() {
        var canvas = document.querySelector("[data-matrix-canvas]");
        if (!(canvas instanceof HTMLCanvasElement)) return;

        // 이미 초기화된 경우 — 애니메이션이 멈췄으면 재시작
        if (canvas.dataset.initialized === "true") {
          if (window.__matrixRestart) window.__matrixRestart();
          return;
        }

        canvas.dataset.initialized = "true";
        var context = canvas.getContext("2d");
        if (!context) return;

        var motionPreference = window.matchMedia("(prefers-reduced-motion: reduce)");
        var glyphs = ["0", "1"];
        var monoStack = '"SFMono-Regular", Consolas, "Liberation Mono", monospace';

        var width = 0, height = 0, cellSize = 18;
        var animationFrame = 0, lastTimestamp = 0;
        var columns = [];

        var randomGlyph = function() { return glyphs[Math.floor(Math.random() * glyphs.length)]; };

        var createColumn = function(index) {
          return {
            x: index * cellSize + Math.random() * cellSize * 0.35,
            y: height + Math.random() * height * 1.35,
            speed: 54 + Math.random() * 132,
            length: 8 + Math.floor(Math.random() * 18),
            brightness: 0.35 + Math.random() * 0.65
          };
        };

        var resetColumn = function(column, index) {
          column.x = index * cellSize + Math.random() * cellSize * 0.35;
          column.y = height + Math.random() * height * 0.75;
          column.speed = 54 + Math.random() * 132;
          column.length = 8 + Math.floor(Math.random() * 18);
          column.brightness = 0.35 + Math.random() * 0.65;
        };

        var paintBackdrop = function() {
          context.clearRect(0, 0, width, height);
          context.fillStyle = "#05080c";
          context.fillRect(0, 0, width, height);
        };

        var resizeCanvas = function() {
          var dpr = Math.min(window.devicePixelRatio || 1, 2);
          width = window.innerWidth;
          height = window.innerHeight;
          cellSize = width < 540 ? 14 : width < 900 ? 16 : 18;

          canvas.width = Math.floor(width * dpr);
          canvas.height = Math.floor(height * dpr);
          canvas.style.width = width + "px";
          canvas.style.height = height + "px";

          context.setTransform(dpr, 0, 0, dpr, 0, 0);
          context.font = cellSize + "px " + monoStack;
          context.textBaseline = "top";

          var columnCount = Math.ceil(width / cellSize);
          columns = Array.from({ length: columnCount }, function(_, i) { return createColumn(i); });
          if (motionPreference.matches) { drawStaticFrame(); } else { paintBackdrop(); }
        };

        var drawStaticFrame = function() {
          paintBackdrop();
          var count = Math.max(36, Math.floor((width * height) / 18000));
          for (var i = 0; i < count; i++) {
            var x = Math.random() * width;
            var y = Math.random() * height;
            var alpha = 0.18 + Math.random() * 0.28;
            context.fillStyle = "rgba(124, 255, 122, " + alpha + ")";
            context.fillText(randomGlyph(), x, y);
          }
        };

        var stopAnimation = function() {
          if (animationFrame) { window.cancelAnimationFrame(animationFrame); animationFrame = 0; }
        };

        var frame = function(timestamp) {
          if (document.hidden) { stopAnimation(); return; }

          var delta = lastTimestamp ? Math.min((timestamp - lastTimestamp) / 1000, 0.05) : 0.016;
          lastTimestamp = timestamp;

          context.fillStyle = "rgba(5, 8, 12, 0.22)";
          context.fillRect(0, 0, width, height);

          columns.forEach(function(column, index) {
            column.y -= column.speed * delta;
            if (column.y + column.length * cellSize < -cellSize) { resetColumn(column, index); }

            for (var step = 0; step < column.length; step++) {
              var y = column.y + step * cellSize;
              if (y < -cellSize || y > height + cellSize) continue;

              var isHead = step === 0;
              var opacity = isHead
                ? Math.min(1, column.brightness * 0.95 + 0.15)
                : (1 - step / column.length) * column.brightness * 0.78;

              context.fillStyle = isHead
                ? "rgba(214, 255, 214, " + opacity + ")"
                : "rgba(124, 255, 122, " + opacity + ")";

              context.fillText(randomGlyph(), column.x, y);
            }
          });

          animationFrame = window.requestAnimationFrame(frame);
        };

        var startAnimation = function() {
          stopAnimation();
          lastTimestamp = 0;
          if (motionPreference.matches) { drawStaticFrame(); return; }
          paintBackdrop();
          animationFrame = window.requestAnimationFrame(frame);
        };

        // 전역에 재시작 함수 노출 (페이지 전환 후 재시작용)
        window.__matrixRestart = function() {
          if (!animationFrame && !document.hidden) startAnimation();
        };

        resizeCanvas();
        startAnimation();

        window.addEventListener("resize", resizeCanvas, { passive: true });
        document.addEventListener("visibilitychange", function() {
          if (document.hidden) stopAnimation(); else startAnimation();
        });
        motionPreference.addEventListener("change", startAnimation);
      })();
    </script>
  </body>
</html>
