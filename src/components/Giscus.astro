---
// Giscus 댓글 위젯
const repoId     = import.meta.env.PUBLIC_GISCUS_REPO_ID      ?? "";
const category   = import.meta.env.PUBLIC_GISCUS_CATEGORY     ?? "Comments";
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID  ?? "";
const configured = repoId && categoryId;

interface Props {
  lang?: "ko" | "en";
}

const { lang = "ko" } = Astro.props as Props;
const uiLang = lang === "en" ? "en" : "ko";
---

<section class="comments">
  <p class="comments__label">{uiLang === "en" ? "Comments" : "댓글"}</p>
  {configured ? (
    <div
      class="giscus-wrap"
      id="giscus-wrap"
      data-repo-id={repoId}
      data-category={category}
      data-category-id={categoryId}
      data-lang={uiLang}
    ></div>
  ) : (
    <p class="comments__notice">
      {uiLang === "en" ? (
        <>
          To enable comments, add Giscus settings to <code>.env</code>.<br />
          Get your repo-id and category-id from <a href="https://giscus.app" target="_blank" rel="noopener">giscus.app</a>.
        </>
      ) : (
        <>
          댓글을 활성화하려면 <code>.env</code>에 Giscus 설정이 필요합니다.<br />
          <a href="https://giscus.app" target="_blank" rel="noopener">giscus.app</a>에서 repo-id와 category-id를 발급받으세요.
        </>
      )}
    </p>
  )}
</section>

<script>
  let giscusCreated = false;
  let currentLang = "";
  let currentTerm = "";

  function getGiscusLang(wrap: HTMLElement) {
    const explicitLang = wrap.dataset.lang;
    if (explicitLang === "en" || explicitLang === "ko") {
      return explicitLang;
    }

    const savedLang =
      document.documentElement.dataset.blogLang ||
      localStorage.getItem("blog_lang") ||
      "ko";

    return savedLang === "en" ? "en" : "ko";
  }

  function loadGiscus() {
    const wrap = document.getElementById("giscus-wrap") as HTMLElement | null;
    const term = window.location.pathname;

    // 포스트 페이지가 아니면 초기화 상태 리셋
    if (!wrap) {
      giscusCreated = false;
      currentLang = "";
      currentTerm = "";
      return;
    }

    const lang = getGiscusLang(wrap);

    if (giscusCreated) {
      const iframe = document.querySelector("iframe.giscus-frame") as HTMLIFrameElement | null;
      if (iframe?.contentWindow && currentLang === lang) {
        // 이미 로드됐으면 postMessage로 현재 경로 전달
        if (currentTerm !== term) {
          iframe.contentWindow.postMessage(
            { giscus: { setConfig: { term } } },
            "https://giscus.app"
          );
          currentTerm = term;
        }
        return;
      }

      wrap.replaceChildren();
      giscusCreated = false;
    }

    // 최초 1회: 스크립트 생성
    giscusCreated = true;
    currentLang = lang;
    currentTerm = term;
    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo",              "achieveonepark/cording-blog");
    script.setAttribute("data-repo-id",           wrap.dataset.repoId     ?? "");
    script.setAttribute("data-category",          wrap.dataset.category   ?? "Comments");
    script.setAttribute("data-category-id",       wrap.dataset.categoryId ?? "");
    script.setAttribute("data-mapping",           "pathname");
    script.setAttribute("data-strict",            "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata",     "0");
    script.setAttribute("data-input-position",    "top");
    script.setAttribute("data-theme",             "https://blog.somiri.dev/giscus-theme.css");
    script.setAttribute("data-lang",              lang);
    script.setAttribute("crossorigin",            "anonymous");
    script.async = true;
    wrap.appendChild(script);
  }

  document.addEventListener("astro:after-swap", loadGiscus);
  document.addEventListener("astro:page-load",  loadGiscus);
</script>

<style>
  .comments {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
  }

  .comments__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(124, 255, 122, 0.5);
    margin: 0 0 1rem;
  }

  .comments__notice {
    font-size: 0.83rem;
    color: rgba(150, 180, 150, 0.6);
    line-height: 1.6;
  }

  .comments__notice a { color: rgba(124, 255, 122, 0.7); }

  .comments__notice code {
    background: rgba(124, 255, 122, 0.08);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .giscus-wrap :global(.giscus-frame) { width: 100%; }
</style>
