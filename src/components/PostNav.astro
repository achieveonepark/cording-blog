---
import type { CollectionEntry } from "astro:content";
import { getPostLang } from "../lib/blog";

interface Props {
  currentPost: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { currentPost, allPosts } = Astro.props;
const currentLang = getPostLang(currentPost);

const sameLangPosts = allPosts.filter((p) => getPostLang(p) === currentLang);
const currentIndex = sameLangPosts.findIndex((p) => p.id === currentPost.id);

// allPosts is sorted newest-first: prev (older) = index+1, next (newer) = index-1
const prev = currentIndex < sameLangPosts.length - 1 ? sameLangPosts[currentIndex + 1] : null;
const next = currentIndex > 0 ? sameLangPosts[currentIndex - 1] : null;

if (!prev && !next) return;
---

<nav class="post-nav" aria-label={currentLang === "en" ? "Post navigation" : "글 네비게이션"}>
  <div class="post-nav__links">
    {prev && (
      <a href={`/posts/${prev.id}/`} class="post-nav__item post-nav__item--prev">
        <span class="post-nav__dir">{currentLang === "en" ? "← Older" : "← 이전 글"}</span>
        <span class="post-nav__title">{prev.data.title}</span>
      </a>
    )}
    {next && (
      <a href={`/posts/${next.id}/`} class="post-nav__item post-nav__item--next">
        <span class="post-nav__dir">{currentLang === "en" ? "Newer →" : "다음 글 →"}</span>
        <span class="post-nav__title">{next.data.title}</span>
      </a>
    )}
  </div>
</nav>

<style>
  .post-nav {
    margin: 2rem 0;
  }

  .post-nav__links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .post-nav__item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    background: var(--panel);
    text-decoration: none;
    transition: border-color 150ms, background 150ms;
  }

  .post-nav__item:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .post-nav__item--next {
    text-align: right;
    grid-column: 2;
  }

  .post-nav__item--prev:only-child {
    grid-column: 1;
  }

  .post-nav__item--next:only-child {
    grid-column: 2;
  }

  .post-nav__dir {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-nav__title {
    font-size: 0.82rem;
    color: var(--text);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 560px) {
    .post-nav__links {
      grid-template-columns: 1fr;
    }

    .post-nav__item--next,
    .post-nav__item--next:only-child {
      grid-column: 1;
    }
  }
</style>
