---
const year = new Date().getFullYear();
---

<footer class="site-footer shell">
  <p class="footer-copyright">
    <span data-ui-lang="ko">© {year} achieveonepark. All rights reserved.</span>
    <span data-ui-lang="en">© {year} achieveonepark. All rights reserved.</span>
  </p>
  <a href="/privacy" class="footer-privacy">
    <span data-ui-lang="ko">개인정보처리방침</span>
    <span data-ui-lang="en">Privacy Policy</span>
  </a>
</footer>

<style>
  .site-footer {
    text-align: center;
  }

  .footer-copyright {
    margin: 0;
  }

  .footer-privacy {
    display: inline-block;
    margin-top: 0.35rem;
    color: var(--muted);
    opacity: 0.5;
    text-decoration: none;
    font-size: 0.68rem;
  }

  .footer-privacy:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
</style>
