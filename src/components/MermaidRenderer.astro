<script>
  import mermaid from "mermaid";

  function getMermaidConfig() {
    return {
      startOnLoad: false,
      securityLevel: "loose",
      theme: "base",
      themeVariables: {
        darkMode: true,
        fontFamily: "\"A2z\", -apple-system, system-ui, \"Segoe UI\", sans-serif",
        fontSize: "15px",
        background: "#05080c",
        primaryColor: "#101814",
        primaryTextColor: "#f3fff2",
        primaryBorderColor: "#7cff7a",
        secondaryColor: "#0b120e",
        secondaryTextColor: "#e7ffe5",
        secondaryBorderColor: "#67e866",
        tertiaryColor: "#08100b",
        tertiaryTextColor: "#dbffd8",
        tertiaryBorderColor: "#4ecb57",
        lineColor: "#93ff90",
        textColor: "#f3fff2",
        mainBkg: "#101814",
        clusterBkg: "#08100b",
        clusterBorder: "#58d861",
        edgeLabelBackground: "#08100b",
        titleColor: "#c6ffc3",
        noteBkgColor: "#101814",
        noteBorderColor: "#7cff7a",
        noteTextColor: "#f0ffef",
        actorBkg: "#101814",
        actorBorder: "#7cff7a",
        actorTextColor: "#f3fff2",
        labelBoxBkgColor: "#101814",
        labelBoxBorderColor: "#7cff7a",
        labelTextColor: "#f3fff2",
        activationBorderColor: "#7cff7a",
        activationBkgColor: "#16311d",
        sequenceNumberColor: "#05080c"
      },
      flowchart: {
        htmlLabels: true,
        useMaxWidth: false,
        curve: "basis",
        nodeSpacing: 54,
        rankSpacing: 68,
        padding: 14
      }
    };
  }

  function getZoomUiLabel() {
    return document.documentElement.dataset.blogLang === "en" ? "Click to enlarge diagram" : "클릭해서 크게 보기";
  }

  function ensureMermaidZoomDialog() {
    const existing = document.getElementById("mermaid-zoom-overlay");
    if (existing instanceof HTMLElement) return existing;

    const overlay = document.createElement("div");
    overlay.id = "mermaid-zoom-overlay";
    overlay.className = "mermaid-zoom";
    overlay.hidden = true;
    overlay.innerHTML = `
      <div class="mermaid-zoom__backdrop" data-close="true"></div>
      <div class="mermaid-zoom__panel" role="dialog" aria-modal="true">
        <button class="mermaid-zoom__close" type="button" aria-label="Close diagram">×</button>
        <div class="mermaid-zoom__body"></div>
      </div>
    `;

    const close = () => {
      overlay.hidden = true;
      overlay.querySelector(".mermaid-zoom__body")?.replaceChildren();
      document.body.classList.remove("mermaid-zoom-open");
    };

    overlay.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.dataset.close === "true" || target.classList.contains("mermaid-zoom__close")) {
        close();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !overlay.hidden) {
        close();
      }
    });

    document.body.appendChild(overlay);
    return overlay;
  }

  function getSvgSize(svg) {
    if (svg.viewBox?.baseVal?.width && svg.viewBox?.baseVal?.height) {
      return {
        width: svg.viewBox.baseVal.width,
        height: svg.viewBox.baseVal.height,
      };
    }

    const widthAttr = Number.parseFloat(svg.getAttribute("width") ?? "");
    const heightAttr = Number.parseFloat(svg.getAttribute("height") ?? "");
    if (Number.isFinite(widthAttr) && Number.isFinite(heightAttr) && widthAttr > 0 && heightAttr > 0) {
      return { width: widthAttr, height: heightAttr };
    }

    const box = svg.getBBox();
    return {
      width: box.width || 1,
      height: box.height || 1,
    };
  }

  function fitZoomDiagram(svg, container) {
    if (!(svg instanceof SVGElement) || !(container instanceof HTMLElement)) return;

    const { width, height } = getSvgSize(svg);
    const availableWidth = Math.max(container.clientWidth - 8, 1);
    const availableHeight = Math.max(container.clientHeight - 8, 1);
    const scale = Math.min(availableWidth / width, availableHeight / height);

    svg.setAttribute("preserveAspectRatio", "xMidYMid meet");
    svg.style.width = `${Math.max(width * scale, 1)}px`;
    svg.style.height = `${Math.max(height * scale, 1)}px`;
    svg.style.maxWidth = "none";
    svg.style.maxHeight = "none";
  }

  function bindZoomableDiagrams() {
    const overlay = ensureMermaidZoomDialog();
    const body = overlay.querySelector(".mermaid-zoom__body");
    const close = overlay.querySelector(".mermaid-zoom__close");
    if (!(body instanceof HTMLElement) || !(close instanceof HTMLButtonElement)) return;

    let activeSvg = null;

    const syncActiveDiagram = () => {
      if (activeSvg instanceof SVGElement) {
        fitZoomDiagram(activeSvg, body);
      }
    };

    document.querySelectorAll("pre.mermaid[data-processed='true']").forEach((diagram) => {
      if (!(diagram instanceof HTMLElement) || diagram.dataset.zoomBound === "true") return;

      diagram.dataset.zoomBound = "true";
      diagram.tabIndex = 0;
      diagram.setAttribute("role", "button");
      diagram.setAttribute("aria-label", getZoomUiLabel());

      const openZoom = () => {
        const svg = diagram.querySelector("svg");
        if (!(svg instanceof SVGElement)) return;

        const clonedSvg = svg.cloneNode(true);
        if (!(clonedSvg instanceof SVGElement)) return;

        activeSvg = clonedSvg;
        body.replaceChildren(clonedSvg);
        overlay.hidden = false;
        document.body.classList.add("mermaid-zoom-open");
        requestAnimationFrame(syncActiveDiagram);
        close.focus();
      };

      diagram.addEventListener("click", openZoom);
      diagram.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openZoom();
        }
      });
    });

    if (overlay.dataset.zoomResizeBound !== "true") {
      overlay.dataset.zoomResizeBound = "true";
      window.addEventListener("resize", syncActiveDiagram, { passive: true });
    }
  }

  function normalizeHighlightedMermaidBlocks() {
    const highlightedBlocks = document.querySelectorAll("pre[data-language='mermaid']");

    highlightedBlocks.forEach((block) => {
      if (!(block instanceof HTMLElement) || block.dataset.mermaidNormalized === "true") return;

      const source = block.textContent?.trim();
      if (!source) return;

      const mermaidBlock = document.createElement("pre");
      mermaidBlock.className = "mermaid";
      mermaidBlock.dataset.mermaidNormalized = "true";
      mermaidBlock.textContent = source;

      block.replaceWith(mermaidBlock);
    });
  }

  async function renderMermaidDiagrams() {
    normalizeHighlightedMermaidBlocks();
    const diagrams = document.querySelectorAll("pre.mermaid");

    if (diagrams.length) {
      mermaid.initialize(getMermaidConfig());

      try {
        await mermaid.run({
          querySelector: "pre.mermaid:not([data-processed='true'])",
          suppressErrors: false,
        });
      } catch (error) {
        console.error("Failed to render Mermaid diagrams", error);
      }
    }

    bindZoomableDiagrams();
  }

  renderMermaidDiagrams();
  document.addEventListener("astro:page-load", renderMermaidDiagrams);
</script>

