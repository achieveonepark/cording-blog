    padding: 1rem;
    border-radius: 24px;
    border: 1px solid rgba(124, 255, 122, 0.18);
    background:
      radial-gradient(circle at top left, rgba(124, 255, 122, 0.1), transparent 34%),
      linear-gradient(180deg, rgba(11, 17, 13, 0.98), rgba(6, 10, 8, 0.99));
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
    display: flex;
    flex-direction: column;
  }

  .mermaid-zoom__close {
    position: absolute;
