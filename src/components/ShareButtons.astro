---
interface Props {
  title: string;
  url: string;
  image?: string;
  lang?: "ko" | "en";
}

const { title, url, image = "", lang = "ko" } = Astro.props;
const kakaoKey = import.meta.env.PUBLIC_KAKAO_APP_KEY ?? "";

const twitterUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
---

<div class="share">
  <p class="share__label">{lang === "en" ? "Share" : "공유하기"}</p>
  <div class="share__btns">
    {kakaoKey && (
      <button
        class="share-btn share-btn--kakao"
        id="kakao-share-btn"
        aria-label={lang === "en" ? "Share on KakaoTalk" : "카카오톡으로 공유"}
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.617 1.586 4.916 4 6.285V21l3.714-2.214C10.447 18.927 11.21 19 12 19c5.523 0 10-3.477 10-7.5S17.523 3 12 3z"/>
        </svg>
        {lang === "en" ? "KakaoTalk" : "카카오톡"}
      </button>
    )}

    <button
      class="share-btn share-btn--copy"
      id="copy-link-btn"
      aria-label={lang === "en" ? "Copy link" : "링크 복사"}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2"/>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
      <span id="copy-label">{lang === "en" ? "Copy link" : "링크 복사"}</span>
    </button>

    <a
      class="share-btn share-btn--twitter"
      href={twitterUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={lang === "en" ? "Share on X" : "X로 공유"}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      X
    </a>

    <a
      class="share-btn share-btn--facebook"
      href={facebookUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={lang === "en" ? "Share on Facebook" : "페이스북으로 공유"}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      Facebook
    </a>

    <a
      class="share-btn share-btn--linkedin"
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={lang === "en" ? "Share on LinkedIn" : "링크드인으로 공유"}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>
  </div>
</div>

<script define:vars={{ url, title, image, kakaoKey, lang }}>
  // ── KakaoTalk ────────────────────────────────────────────
  if (kakaoKey) {
    const script = document.createElement("script");
    script.src = "https://t1.kakaocdn.net/kakao_js_sdk/2.7.4/kakao.min.js";
    script.onload = () => {
      if (!window.Kakao.isInitialized()) window.Kakao.init(kakaoKey);
    };
    document.head.appendChild(script);

    document.getElementById("kakao-share-btn")?.addEventListener("click", () => {
      if (!window.Kakao?.Share) return;
      const content = {
        title,
        link: { mobileWebUrl: url, webUrl: url },
      };
      if (image) content.imageUrl = image;
      window.Kakao.Share.sendDefault({ objectType: "feed", content });
    });
  }

  // ── 링크 복사 ─────────────────────────────────────────────
  const copyBtn = document.getElementById("copy-link-btn");
  const copyLabel = document.getElementById("copy-label");

  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(url);
      if (copyLabel) {
        copyLabel.textContent = lang === "en" ? "Copied!" : "복사됨!";
        setTimeout(() => {
          copyLabel.textContent = lang === "en" ? "Copy link" : "링크 복사";
        }, 2000);
      }
    } catch {
      prompt(lang === "en" ? "Copy this URL:" : "URL을 복사하세요:", url);
    }
  });
</script>

<style>
  .share {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 1rem 0;
  }

  .share__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(124, 255, 122, 0.45);
    margin: 0;
  }

  .share__btns {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.18);
    background: transparent;
    color: rgba(200, 230, 200, 0.7);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 150ms, background 150ms, color 150ms;
    font-family: inherit;
  }

  .share-btn:hover {
    border-color: rgba(124, 255, 122, 0.4);
    background: rgba(124, 255, 122, 0.07);
    color: #7cff7a;
  }

  .share-btn--kakao {
    border-color: rgba(254, 229, 0, 0.3);
    color: rgba(254, 229, 0, 0.75);
  }

  .share-btn--kakao:hover {
    border-color: rgba(254, 229, 0, 0.6);
    background: rgba(254, 229, 0, 0.07);
    color: #fee500;
  }

  .share-btn--twitter {
    border-color: rgba(200, 230, 200, 0.2);
    color: rgba(200, 230, 200, 0.7);
  }

  .share-btn--twitter:hover {
    border-color: rgba(200, 230, 200, 0.45);
    background: rgba(200, 230, 200, 0.07);
    color: #e7e9ea;
  }

  .share-btn--facebook {
    border-color: rgba(24, 119, 242, 0.3);
    color: rgba(24, 119, 242, 0.75);
  }

  .share-btn--facebook:hover {
    border-color: rgba(24, 119, 242, 0.6);
    background: rgba(24, 119, 242, 0.07);
    color: #1877f2;
  }

  .share-btn--linkedin {
    border-color: rgba(10, 102, 194, 0.3);
    color: rgba(10, 102, 194, 0.75);
  }

  .share-btn--linkedin:hover {
    border-color: rgba(10, 102, 194, 0.6);
    background: rgba(10, 102, 194, 0.07);
    color: #0a66c2;
  }
</style>
