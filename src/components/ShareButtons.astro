---
interface Props {
  title: string;
  url: string;
  image?: string;
}

const { title, url, image = "" } = Astro.props;
const kakaoKey = import.meta.env.PUBLIC_KAKAO_APP_KEY ?? "";
---

<div class="share">
  <p class="share__label">공유하기</p>
  <div class="share__btns">
    {kakaoKey && (
      <button class="share-btn share-btn--kakao" id="kakao-share-btn" aria-label="카카오톡으로 공유">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.617 1.586 4.916 4 6.285V21l3.714-2.214C10.447 18.927 11.21 19 12 19c5.523 0 10-3.477 10-7.5S17.523 3 12 3z"/>
        </svg>
        카카오톡
      </button>
    )}

    <button class="share-btn share-btn--copy" id="copy-link-btn" aria-label="링크 복사">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2"/>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
      <span id="copy-label">링크 복사</span>
    </button>
  </div>
</div>

<script define:vars={{ url, title, image, kakaoKey }}>
  // ── KakaoTalk ────────────────────────────────────────────
  if (kakaoKey) {
    const script = document.createElement("script");
    script.src = "https://t1.kakaocdn.net/kakao_js_sdk/2.7.4/kakao.min.js";
    script.onload = () => {
      if (!window.Kakao.isInitialized()) window.Kakao.init(kakaoKey);
    };
    document.head.appendChild(script);

    document.getElementById("kakao-share-btn")?.addEventListener("click", () => {
      if (!window.Kakao?.Share) return;
      const content = {
        title,
        link: { mobileWebUrl: url, webUrl: url },
      };
      if (image) content.imageUrl = image;
      window.Kakao.Share.sendDefault({ objectType: "feed", content });
    });
  }

  // ── 링크 복사 ─────────────────────────────────────────────
  const copyBtn = document.getElementById("copy-link-btn");
  const copyLabel = document.getElementById("copy-label");

  copyBtn?.addEventListener("click", async () => {
    try {
      await navigator.clipboard.writeText(url);
      if (copyLabel) {
        copyLabel.textContent = "복사됨!";
        setTimeout(() => { copyLabel.textContent = "링크 복사"; }, 2000);
      }
    } catch {
      prompt("URL을 복사하세요:", url);
    }
  });
</script>

<style>
  .share {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 1rem 0;
    border-top: 1px solid rgba(124, 255, 122, 0.08);
    border-bottom: 1px solid rgba(124, 255, 122, 0.08);
  }

  .share__label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(124, 255, 122, 0.45);
    margin: 0;
  }

  .share__btns {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.18);
    background: transparent;
    color: rgba(200, 230, 200, 0.7);
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 150ms, background 150ms, color 150ms;
    font-family: inherit;
  }

  .share-btn:hover {
    border-color: rgba(124, 255, 122, 0.4);
    background: rgba(124, 255, 122, 0.07);
    color: #7cff7a;
  }

  .share-btn--kakao {
    border-color: rgba(254, 229, 0, 0.3);
    color: rgba(254, 229, 0, 0.75);
  }

  .share-btn--kakao:hover {
    border-color: rgba(254, 229, 0, 0.6);
    background: rgba(254, 229, 0, 0.07);
    color: #fee500;
  }
</style>
