---
import type { CollectionEntry } from "astro:content";
import { getPostLang } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const lang = getPostLang(post);
---

<article class="post-card" data-category={post.data.category ?? ""} data-lang={lang}>
  <div class="post-card__media">
    {post.data.thumbnail ? (
      <a href={`/posts/${post.id}/`} class="post-card__thumb-link" aria-hidden="true" tabindex="-1">
        <img class="post-card__thumb" src={post.data.thumbnail} alt="" loading="lazy" />
      </a>
    ) : (
      <div class="post-card__thumb-link post-card__thumb-link--empty" aria-hidden="true"></div>
    )}
  </div>

  <div class="post-card__body">
    <h2>
      <a href={`/posts/${post.id}/`}>{post.data.title}</a>
    </h2>

    {post.data.description && <p class="post-card__description">{post.data.description}</p>}

    {post.data.tags.length > 0 && (
      <ul class="tag-list" aria-label={lang === "en" ? "Post tags" : "글 태그"}>
        {post.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
  </div>
</article>

<style>
  .post-card__media {
    width: var(--post-card-thumb-width);
    height: var(--post-card-thumb-height);
    min-width: 0;
    flex: none;
  }

  .post-card__thumb-link {
    display: block;
    overflow: hidden;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-md);
    background: rgba(10, 15, 19, 0.92);
  }

  .post-card__thumb-link--empty {
    border: 1px dashed rgba(124, 255, 122, 0.12);
    background:
      linear-gradient(135deg, rgba(124, 255, 122, 0.08), transparent 70%),
      rgba(10, 15, 19, 0.78);
  }

  .post-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease, filter 400ms ease;
    filter: brightness(0.85) saturate(0.9);
  }

  .post-card:hover .post-card__thumb {
    transform: scale(1.04);
    filter: brightness(0.95) saturate(1);
  }

  .post-card__body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.65rem;
  }

  .post-card__body h2 {
    margin: 0;
  }

  .post-card__description {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    line-height: 1.6;
  }

  .post-card__body .tag-list {
    margin-top: 0;
  }

  @media (max-width: 720px) {
    .post-card__media {
      width: var(--post-card-thumb-width-mobile);
      height: var(--post-card-thumb-height-mobile);
    }

    .post-card__body {
      gap: 0.45rem;
    }
  }
</style>
