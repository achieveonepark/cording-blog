---
import type { CollectionEntry } from "astro:content";
import { formatDate, getReadingTime } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
---

<article class:list={["post-card", { "post-card--featured": featured }]} data-category={post.data.category ?? ""}>
  {post.data.thumbnail && (
    <a href={`/posts/${post.id}/`} class="post-card__thumb-link">
      <img class="post-card__thumb" src={post.data.thumbnail} alt="" loading="lazy" />
    </a>
  )}

  <div class="post-card__meta">
    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
    <span>{getReadingTime(post)}</span>
    {post.data.category && <span class="post-category">{post.data.category}</span>}
  </div>

  <h2>
    <a href={`/posts/${post.id}/`}>{post.data.title}</a>
  </h2>

  <p>{post.data.description}</p>

  {post.data.tags.length > 0 && (
    <ul class="tag-list" aria-label="Post tags">
      {post.data.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
</article>

<style>
  .post-card__thumb-link {
    display: block;
    margin: -1.25rem -1.25rem 1rem;
    overflow: hidden;
    border-radius: 6px 6px 0 0;
  }

  .post-card__thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    transition: transform 300ms ease;
  }

  .post-card:hover .post-card__thumb {
    transform: scale(1.03);
  }

  .post-category {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: rgba(124, 255, 122, 0.1);
    border: 1px solid rgba(124, 255, 122, 0.2);
    color: #7cff7a;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
