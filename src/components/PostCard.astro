---
import type { CollectionEntry } from "astro:content";
import { getPostLang } from "../lib/blog";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const lang = getPostLang(post);
const category = post.data.category ?? "";

const categoryIcons: Record<string, string> = {
  "Troubleshooting": `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>`,
  "R&D": `<path d="M9 3v11M5 14h8a4 4 0 0 1 0 8H5V3z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="17" cy="7" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="17" y1="5.5" x2="17" y2="8.5" stroke="currentColor" stroke-width="1.2"/><line x1="15.5" y1="7" x2="18.5" y2="7" stroke="currentColor" stroke-width="1.2"/>`,
  "Thinking": `<path d="M12 2a7 7 0 0 0-4 12.73V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.27A7 7 0 0 0 12 2z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="9" y1="21" x2="15" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  "AI": `<rect x="4" y="4" width="16" height="16" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="9" cy="10" r="1.5" fill="currentColor"/><circle cx="15" cy="10" r="1.5" fill="currentColor"/><path d="M9 15h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="12" y1="2" x2="12" y2="4" stroke="currentColor" stroke-width="1.5"/><line x1="4" y1="12" x2="2" y2="12" stroke="currentColor" stroke-width="1.5"/><line x1="22" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="1.5"/>`,
  "Design Pattern": `<rect x="3" y="3" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/>`,
  "Unity Package": `<path d="M16.5 9.4l-9-5.19M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><polyline points="3.27 6.96 12 12.01 20.73 6.96" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="12" y1="22.08" x2="12" y2="12" stroke="currentColor" stroke-width="1.5"/>`,
};

const fallbackIcon = `<circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`;

const iconSvg = categoryIcons[category] ?? fallbackIcon;
---

<article class="post-card" data-category={category} data-lang={lang}>
  <div class="post-card__media">
    {post.data.thumbnail ? (
      <a href={`/posts/${post.id}/`} class="post-card__thumb-link" aria-hidden="true" tabindex="-1">
        <img class="post-card__thumb" src={post.data.thumbnail} alt="" loading="lazy" />
      </a>
    ) : (
      <div class="post-card__thumb-link post-card__thumb-link--empty" aria-hidden="true">
        <svg class="post-card__category-icon" viewBox="0 0 24 24" fill="none" set:html={iconSvg} />
        <span class="post-card__category-label">{category}</span>
      </div>
    )}
  </div>

  <div class="post-card__body">
    <h2>
      <a href={`/posts/${post.id}/`}>{post.data.title}</a>
    </h2>

    {post.data.description && <p class="post-card__description">{post.data.description}</p>}

    {post.data.tags.length > 0 && (
      <ul class="tag-list" aria-label={lang === "en" ? "Post tags" : "글 태그"}>
        {post.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
  </div>
</article>

<style>
  .post-card__media {
    width: var(--post-card-thumb-width);
    height: var(--post-card-thumb-height);
    min-width: 0;
    flex: none;
  }

  .post-card__thumb-link {
    display: block;
    overflow: hidden;
    width: 100%;
    height: 100%;
    border-radius: var(--radius-md);
    background: rgba(10, 15, 19, 0.92);
  }

  .post-card__thumb-link--empty {
    border: 1px solid rgba(124, 255, 122, 0.1);
    background:
      radial-gradient(circle at 30% 40%, rgba(124, 255, 122, 0.07), transparent 60%),
      rgba(10, 15, 19, 0.85);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
  }

  .post-card__category-icon {
    width: 28px;
    height: 28px;
    color: rgba(124, 255, 122, 0.4);
  }

  .post-card__category-label {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(124, 255, 122, 0.3);
    text-transform: uppercase;
  }

  .post-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 400ms ease, filter 400ms ease;
    filter: brightness(0.85) saturate(0.9);
  }

  .post-card:hover .post-card__thumb {
    transform: scale(1.04);
    filter: brightness(0.95) saturate(1);
  }

  .post-card__body {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.65rem;
  }

  .post-card__body h2 {
    margin: 0;
  }

  .post-card__description {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    line-height: 1.6;
  }

  .post-card__body .tag-list {
    margin-top: 0;
  }

  @media (max-width: 720px) {
    .post-card__media {
      width: var(--post-card-thumb-width-mobile);
      height: var(--post-card-thumb-height-mobile);
    }

    .post-card__body {
      gap: 0.45rem;
    }
  }
</style>
