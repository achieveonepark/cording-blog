---
import type { CollectionEntry } from "astro:content";
import { formatDate, getPostLang } from "../lib/blog";

interface Props {
  currentPost: CollectionEntry<"blog">;
  allPosts: CollectionEntry<"blog">[];
}

const { currentPost, allPosts } = Astro.props;
const currentLang = getPostLang(currentPost);

function score(post: CollectionEntry<"blog">) {
  let s = 0;
  if (post.data.category && post.data.category === currentPost.data.category) s += 3;
  const sharedTags = post.data.tags.filter((t) => currentPost.data.tags.includes(t));
  s += sharedTags.length;
  return s;
}

const related = allPosts
  .filter((p) => p.id !== currentPost.id && getPostLang(p) === currentLang)
  .map((p) => ({ post: p, score: score(p) }))
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(({ post }) => post);
---

{related.length > 0 && (
  <section class="related">
    <p class="related__label">{currentLang === "en" ? "Related Posts" : "관련 글"}</p>
    <ul class="related__list">
      {related.map((post) => (
        <li>
          <a href={`/posts/${post.id}/`} class="related__item">
            <span class="related__title">{post.data.title}</span>
            <span class="related__meta">
              {post.data.category && <span class="related__cat">{post.data.category}</span>}
              <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, currentLang)}</time>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .related {
    margin-top: 2rem;
  }

  .related__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(124, 255, 122, 0.5);
    margin: 0 0 0.75rem;
  }

  .related__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .related__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.6rem 0.85rem;
    border-radius: 6px;
    border: 1px solid rgba(124, 255, 122, 0.1);
    background: rgba(124, 255, 122, 0.02);
    text-decoration: none;
    transition: border-color 150ms, background 150ms;
    flex-wrap: wrap;
  }

  .related__item:hover {
    border-color: rgba(124, 255, 122, 0.3);
    background: rgba(124, 255, 122, 0.05);
  }

  .related__title {
    font-size: 0.88rem;
    color: rgba(220, 245, 220, 0.85);
    font-weight: 500;
    transition: color 150ms;
  }

  .related__item:hover .related__title {
    color: #7cff7a;
  }

  .related__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .related__cat {
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: rgba(124, 255, 122, 0.08);
    border: 1px solid rgba(124, 255, 122, 0.15);
    color: rgba(124, 255, 122, 0.6);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  time {
    font-size: 0.75rem;
    color: rgba(150, 180, 150, 0.5);
  }
</style>
