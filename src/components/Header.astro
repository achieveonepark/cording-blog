---
import { externalLinks, navigation, site } from "../config/site";

const pathname = Astro.url.pathname;
const clientId = import.meta.env.PUBLIC_GITHUB_CLIENT_ID ?? "";
---

<header class="site-header">
  <div class="site-header__inner shell">
    <a href="/" class="brand-link" aria-label={`${site.title} 홈`}>
      <strong>{site.title}</strong>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <div class="site-nav__group site-nav__group--primary">
        {navigation.map((item) => {
          const isActive = item.href === "/"
            ? pathname === item.href
            : pathname.startsWith(item.href);

          return (
            <a href={item.href} aria-current={isActive ? "page" : undefined}>
              {item.label}
            </a>
          );
        })}

        <!-- 인라인 검색 -->
        <div class="header-search" id="header-search">
          <button id="search-trigger" class="site-nav__icon-link" aria-label="검색" title="검색">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
              <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.8"/>
              <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            </svg>
          </button>

          <div id="search-bar" class="header-search__bar" hidden>
            <span class="header-search__prompt" aria-hidden="true">&gt;</span>
            <input
              id="search-input"
              class="header-search__input"
              type="search"
              placeholder="검색..."
              autocomplete="off"
              aria-label="검색어 입력"
            />
            <button id="search-close" class="header-search__close" aria-label="닫기">
              <svg viewBox="0 0 24 24" aria-hidden="true" width="14" height="14">
                <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="site-nav__group site-nav__group--apps">
        {externalLinks.map((item) => (
          <a
            class="site-nav__icon-link"
            href={item.href}
            target="_blank"
            rel="noreferrer"
            aria-label={item.label}
            title={item.label}
          >
            {item.kind === "github" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
                <path fill="currentColor" d="M12 2C6.48 2 2 6.59 2 12.25c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.5 0-.24-.01-1.04-.01-1.88-2.78.62-3.37-1.21-3.37-1.21-.45-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.63.07-.63 1 .08 1.53 1.05 1.53 1.05.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.38-2.22-.26-4.55-1.15-4.55-5.1 0-1.13.39-2.05 1.03-2.77-.1-.26-.45-1.31.1-2.74 0 0 .84-.28 2.75 1.06A9.3 9.3 0 0 1 12 7.1c.85 0 1.71.12 2.51.36 1.91-1.34 2.75-1.06 2.75-1.06.55 1.43.2 2.48.1 2.74.64.72 1.03 1.64 1.03 2.77 0 3.96-2.34 4.84-4.57 5.09.36.32.68.95.68 1.91 0 1.38-.01 2.49-.01 2.83 0 .28.18.61.69.5A10.23 10.23 0 0 0 22 12.25C22 6.59 17.52 2 12 2Z"/>
              </svg>
            )}
            {item.kind === "os" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
                <rect x="3.5" y="4.5" width="17" height="13" rx="2.5" fill="none" stroke="currentColor" stroke-width="1.8"/>
                <path d="M8 20h8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M12 17.5V20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M3.5 8.5h17" fill="none" stroke="currentColor" stroke-width="1.8"/>
              </svg>
            )}
            {item.kind === "library" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
                <path d="M5 5.5h3v13H5zM10 4.5h4v14h-4zM16 6.5h3v12h-3z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                <path d="M4 19.5h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              </svg>
            )}
          </a>
        ))}
      </div>

      <div class="site-nav__group site-nav__group--rss">
        <a class="site-nav__icon-link" href="/rss.xml" aria-label="RSS" title="RSS">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
            <circle cx="6.5" cy="17.5" r="1.8" fill="currentColor"/>
            <path d="M4.7 10.6a8.7 8.7 0 0 1 8.7 8.7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
            <path d="M4.7 5a14.3 14.3 0 0 1 14.3 14.3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </a>
      </div>

      <div class="site-nav__group site-nav__group--admin">
        <button id="nav-login-btn" class="site-nav__icon-link" aria-label="GitHub 로그인" title="GitHub 로그인" style="display:none">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
            <circle cx="12" cy="8" r="3.5" fill="none" stroke="currentColor" stroke-width="1.8"/>
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
        <button id="nav-logout-btn" class="site-nav__icon-link" aria-label="로그아웃" title="로그아웃" style="display:none">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="16 17 21 12 16 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="21" y1="12" x2="9" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- 검색 결과 드롭다운 (header 바깥, fixed 포지션) -->
<div id="search-dropdown" class="search-dropdown" hidden role="listbox" aria-label="검색 결과"></div>

<script define:vars={{ clientId }}>
  const OWNER = "achieveonepark";
  const CALLBACK = `${window.location.origin}/admin/callback`;
  const loginBtn = document.getElementById("nav-login-btn");
  const logoutBtn = document.getElementById("nav-logout-btn");

  function showLogin() { loginBtn.style.display = ""; logoutBtn.style.display = "none"; }
  function showOwner() { loginBtn.style.display = "none"; logoutBtn.style.display = ""; }

  loginBtn.addEventListener("click", () => {
    const url = `https://github.com/login/oauth/authorize?client_id=${clientId}&scope=public_repo&redirect_uri=${encodeURIComponent(CALLBACK)}`;
    const w = 520, h = 680;
    const left = Math.round(window.screenX + (window.outerWidth - w) / 2);
    const top = Math.round(window.screenY + (window.outerHeight - h) / 2);
    window.open(url, "github-oauth", `width=${w},height=${h},left=${left},top=${top},toolbar=0,scrollbars=1,status=0`);
    window.addEventListener("message", (e) => {
      if (e.origin !== window.location.origin || e.data?.type !== "oauth-success") return;
      localStorage.setItem("gh_token", e.data.token);
      window.location.reload();
    }, { once: true });
  });

  logoutBtn.addEventListener("click", () => {
    localStorage.removeItem("gh_token");
    window.location.reload();
  });

  (async () => {
    const token = localStorage.getItem("gh_token");
    if (!token) { showLogin(); return; }
    try {
      const res = await fetch("https://api.github.com/user", { headers: { Authorization: `Bearer ${token}` } });
      const user = await res.json();
      if (user.login === OWNER) showOwner();
      else { localStorage.removeItem("gh_token"); showLogin(); }
    } catch { showLogin(); }
  })();

  // ── 인라인 검색 ──────────────────────────────────────────
  const trigger    = document.getElementById("search-trigger");
  const searchBar  = document.getElementById("search-bar");
  const searchInput = document.getElementById("search-input");
  const closeBtn   = document.getElementById("search-close");
  const dropdown   = document.getElementById("search-dropdown");
  const headerEl   = document.querySelector(".site-header");

  let pagefindModule = null;
  let debounceTimer  = null;

  function positionDropdown() {
    const rect = headerEl.getBoundingClientRect();
    dropdown.style.top = `${rect.bottom}px`;
  }

  function openSearch() {
    trigger.hidden = true;
    searchBar.removeAttribute("hidden");
    positionDropdown();
    searchInput.focus();
  }

  function closeSearch() {
    trigger.hidden = false;
    searchBar.setAttribute("hidden", "");
    dropdown.setAttribute("hidden", "");
    dropdown.innerHTML = "";
    searchInput.value = "";
  }

  function renderResults(results) {
    if (!results.length) {
      dropdown.innerHTML = `<p class="search-dropdown__empty">검색 결과가 없어요.</p>`;
      dropdown.removeAttribute("hidden");
      return;
    }
    dropdown.innerHTML = results.map(r => `
      <a class="search-dropdown__item" href="${r.url}">
        <span class="search-dropdown__title">${r.meta?.title ?? r.url}</span>
        <span class="search-dropdown__excerpt">${r.excerpt ?? ""}</span>
      </a>
    `).join("");
    dropdown.removeAttribute("hidden");
  }

  async function doSearch(query) {
    if (!query.trim()) { dropdown.setAttribute("hidden", ""); return; }

    try {
      if (!pagefindModule) {
        pagefindModule = await import("/pagefind/pagefind.js");
        await pagefindModule.init();
      }
      const result = await pagefindModule.search(query);
      const items = await Promise.all(result.results.slice(0, 6).map(r => r.data()));
      renderResults(items);
    } catch {
      dropdown.innerHTML = `<p class="search-dropdown__empty">검색은 빌드 후 사용할 수 있어요.</p>`;
      dropdown.removeAttribute("hidden");
    }
  }

  trigger.addEventListener("click", openSearch);
  closeBtn.addEventListener("click", closeSearch);

  searchInput.addEventListener("input", () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(searchInput.value), 220);
  });

  searchInput.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeSearch();
  });

  // 드롭다운 바깥 클릭 시 닫기
  document.addEventListener("click", (e) => {
    if (!document.getElementById("header-search").contains(e.target) && !dropdown.contains(e.target)) {
      closeSearch();
    }
  });

  window.addEventListener("resize", () => { if (!searchBar.hidden) positionDropdown(); });
</script>

<style>
  /* ── 인라인 검색 바 ─────────────────────────────────────── */
  .header-search {
    display: flex;
    align-items: center;
  }

  .header-search__bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0 0.55rem 0 0.65rem;
    height: 2.35rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(124, 255, 122, 0.22);
    background: rgba(20, 24, 31, 0.85);
    backdrop-filter: blur(8px);
  }

  .header-search__prompt {
    font-size: 0.82rem;
    font-family: var(--font-code);
    color: #7cff7a;
    user-select: none;
    flex: none;
  }

  .header-search__input {
    width: 180px;
    background: transparent;
    border: none;
    outline: none;
    color: #d6ffd6;
    font-size: 0.78rem;
    font-family: var(--font-ui);
    letter-spacing: 0.02em;
  }

  .header-search__input::placeholder {
    color: rgba(160, 200, 160, 0.4);
  }

  .header-search__input::-webkit-search-cancel-button {
    display: none;
  }

  .header-search__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: rgba(180, 210, 180, 0.5);
    cursor: pointer;
    flex: none;
    transition: color 150ms, background 150ms;
  }

  .header-search__close:hover {
    color: #7cff7a;
    background: rgba(124, 255, 122, 0.08);
  }

  /* ── 검색 결과 드롭다운 ──────────────────────────────────── */
  .search-dropdown {
    position: fixed;
    left: 50%;
    transform: translateX(-50%);
    width: min(560px, calc(100vw - 2rem));
    max-height: 60vh;
    overflow-y: auto;
    background: rgba(10, 14, 19, 0.97);
    border: 1px solid rgba(124, 255, 122, 0.18);
    border-top: none;
    border-radius: 0 0 10px 10px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.6);
    z-index: 200;
    padding: 0.5rem;
  }

  .search-dropdown[hidden] { display: none; }

  .search-dropdown__item {
    display: block;
    padding: 0.7rem 0.85rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 140ms;
  }

  .search-dropdown__item:hover {
    background: rgba(124, 255, 122, 0.06);
  }

  .search-dropdown__title {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: #c8e8c8;
    font-family: var(--font-ui);
    margin-bottom: 0.2rem;
  }

  .search-dropdown__excerpt {
    display: block;
    font-size: 0.76rem;
    color: rgba(160, 200, 160, 0.6);
    font-family: var(--font-ui);
    line-height: 1.5;
  }

  .search-dropdown__excerpt mark {
    background: rgba(124, 255, 122, 0.2);
    color: #7cff7a;
    border-radius: 2px;
  }

  .search-dropdown__empty {
    padding: 0.75rem 0.85rem;
    font-size: 0.82rem;
    color: rgba(150, 180, 150, 0.6);
    font-family: var(--font-ui);
    margin: 0;
  }

  /* ── 기존 아이콘 버튼 스타일 ────────────────────────────── */
  .site-nav button.site-nav__icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    min-height: 2.35rem;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.08);
    background: rgba(20, 24, 31, 0.72);
    color: var(--muted);
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .site-nav button.site-nav__icon-link:hover {
    color: var(--text);
    border-color: rgba(124, 255, 122, 0.22);
    background: rgba(27, 34, 41, 0.9);
    transform: translateY(-1px);
  }

  @media (max-width: 640px) {
    .header-search__input {
      width: 120px;
    }
  }
</style>
