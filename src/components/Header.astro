---
import { externalLinks, navigation, site } from "../config/site";

const pathname = Astro.url.pathname;
const clientId = import.meta.env.PUBLIC_GITHUB_CLIENT_ID ?? "";
---

<header class="site-header">
  <div class="site-header__inner shell">
    <a href="/" class="brand-link" aria-label={`${site.title} 홈`}>
      <strong>{site.title}</strong>
    </a>

    <nav class="site-nav" aria-label="Primary navigation">
      <div class="site-nav__group site-nav__group--primary">
        {navigation.map((item) => {
          const isActive = item.href === "/"
            ? pathname === item.href
            : pathname.startsWith(item.href);

          return (
            <a href={item.href} aria-current={isActive ? "page" : undefined}>
              {item.label}
            </a>
          );
        })}
        <button id="search-open-btn" class="site-nav__text-btn" aria-label="검색">
          Search
        </button>
      </div>

      <div class="site-nav__group site-nav__group--apps">
        {externalLinks.map((item) => (
          <a
            class="site-nav__icon-link"
            href={item.href}
            target="_blank"
            rel="noreferrer"
            aria-label={item.label}
            title={item.label}
          >
            {item.kind === "github" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
                <path
                  fill="currentColor"
                  d="M12 2C6.48 2 2 6.59 2 12.25c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.5 0-.24-.01-1.04-.01-1.88-2.78.62-3.37-1.21-3.37-1.21-.45-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.63.07-.63 1 .08 1.53 1.05 1.53 1.05.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.38-2.22-.26-4.55-1.15-4.55-5.1 0-1.13.39-2.05 1.03-2.77-.1-.26-.45-1.31.1-2.74 0 0 .84-.28 2.75 1.06A9.3 9.3 0 0 1 12 7.1c.85 0 1.71.12 2.51.36 1.91-1.34 2.75-1.06 2.75-1.06.55 1.43.2 2.48.1 2.74.64.72 1.03 1.64 1.03 2.77 0 3.96-2.34 4.84-4.57 5.09.36.32.68.95.68 1.91 0 1.38-.01 2.49-.01 2.83 0 .28.18.61.69.5A10.23 10.23 0 0 0 22 12.25C22 6.59 17.52 2 12 2Z"
                />
              </svg>
            )}

            {item.kind === "os" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
                <rect x="3.5" y="4.5" width="17" height="13" rx="2.5" fill="none" stroke="currentColor" stroke-width="1.8" />
                <path d="M8 20h8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <path d="M12 17.5V20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                <path d="M3.5 8.5h17" fill="none" stroke="currentColor" stroke-width="1.8" />
              </svg>
            )}

            {item.kind === "library" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
                <path d="M5 5.5h3v13H5zM10 4.5h4v14h-4zM16 6.5h3v12h-3z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                <path d="M4 19.5h16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
              </svg>
            )}
          </a>
        ))}
      </div>

      <div class="site-nav__group site-nav__group--rss">
        <a class="site-nav__icon-link" href="/rss.xml" aria-label="RSS" title="RSS">
          <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
            <circle cx="6.5" cy="17.5" r="1.8" fill="currentColor" />
            <path d="M4.7 10.6a8.7 8.7 0 0 1 8.7 8.7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            <path d="M4.7 5a14.3 14.3 0 0 1 14.3 14.3" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </a>
      </div>

      <div class="site-nav__group site-nav__group--admin">
        <!-- 로그인 버튼 -->
        <button
          id="nav-login-btn"
          class="site-nav__icon-link"
          aria-label="GitHub 로그인"
          title="GitHub 로그인"
          style="display:none"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
            <circle cx="12" cy="8" r="3.5" fill="none" stroke="currentColor" stroke-width="1.8" />
            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>

        <!-- 로그아웃 버튼 -->
        <button
          id="nav-logout-btn"
          class="site-nav__icon-link"
          aria-label="로그아웃"
          title="로그아웃"
          style="display:none"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="nav-icon">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            <polyline points="16 17 21 12 16 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
            <line x1="21" y1="12" x2="9" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </nav>
  </div>
</header>

<!-- 검색 모달 -->
<div id="search-modal" role="dialog" aria-modal="true" aria-label="검색" hidden>
  <div class="search-modal__backdrop" id="search-modal-backdrop"></div>
  <div class="search-modal__panel">
    <div class="search-modal__header">
      <span class="search-modal__title">Search</span>
      <button class="search-modal__close" id="search-modal-close" aria-label="닫기">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="search-modal-ui"></div>
  </div>
</div>

<script define:vars={{ clientId }}>
  const OWNER = "achieveonepark";
  const CALLBACK = `${window.location.origin}/admin/callback`;

  const loginBtn = document.getElementById("nav-login-btn");
  const logoutBtn = document.getElementById("nav-logout-btn");

  function showLogin() {
    loginBtn.style.display = "";
    logoutBtn.style.display = "none";
  }

  function showOwner() {
    loginBtn.style.display = "none";
    logoutBtn.style.display = "";
  }

  loginBtn.addEventListener("click", () => {
    const url =
      `https://github.com/login/oauth/authorize` +
      `?client_id=${clientId}` +
      `&scope=public_repo` +
      `&redirect_uri=${encodeURIComponent(CALLBACK)}`;

    const w = 520, h = 680;
    const left = Math.round(window.screenX + (window.outerWidth - w) / 2);
    const top = Math.round(window.screenY + (window.outerHeight - h) / 2);
    window.open(url, "github-oauth", `width=${w},height=${h},left=${left},top=${top},toolbar=0,scrollbars=1,status=0`);

    window.addEventListener("message", (e) => {
      if (e.origin !== window.location.origin || e.data?.type !== "oauth-success") return;
      localStorage.setItem("gh_token", e.data.token);
      window.location.reload();
    }, { once: true });
  });

  logoutBtn.addEventListener("click", () => {
    localStorage.removeItem("gh_token");
    window.location.reload();
  });

  (async () => {
    const token = localStorage.getItem("gh_token");
    if (!token) { showLogin(); return; }

    try {
      const res = await fetch("https://api.github.com/user", {
        headers: { Authorization: `Bearer ${token}` },
      });
      const user = await res.json();
      if (user.login === OWNER) showOwner();
      else { localStorage.removeItem("gh_token"); showLogin(); }
    } catch {
      showLogin();
    }
  })();

  // ── 검색 모달 ─────────────────────────────────────────────
  const modal = document.getElementById("search-modal");
  let pagefindReady = false;

  function openSearch() {
    modal.removeAttribute("hidden");
    document.body.style.overflow = "hidden";

    if (!pagefindReady) {
      pagefindReady = true;

      const css = document.createElement("link");
      css.rel = "stylesheet";
      css.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(css);

      const script = document.createElement("script");
      script.src = "/pagefind/pagefind-ui.js";
      script.onload = () => {
        if (typeof PagefindUI !== "undefined") {
          new PagefindUI({
            element: "#search-modal-ui",
            showImages: false,
            showEmptyFilters: false,
            resetStyles: false,
            translations: {
              placeholder: "검색어를 입력하세요...",
              zero_results: "검색 결과가 없어요.",
            },
          });
        } else {
          document.getElementById("search-modal-ui").innerHTML =
            '<p style="color:rgba(150,180,150,0.6);font-size:0.85rem;padding:1rem 0">검색은 빌드 후 사용할 수 있어요. (<code>npm run build</code>)</p>';
        }
        setTimeout(() => {
          document.querySelector(".pagefind-ui__search-input")?.focus();
        }, 80);
      };
      document.head.appendChild(script);
    } else {
      setTimeout(() => {
        document.querySelector(".pagefind-ui__search-input")?.focus();
      }, 50);
    }
  }

  function closeSearch() {
    modal.setAttribute("hidden", "");
    document.body.style.overflow = "";
  }

  document.getElementById("search-open-btn")?.addEventListener("click", openSearch);
  document.getElementById("search-modal-close")?.addEventListener("click", closeSearch);
  document.getElementById("search-modal-backdrop")?.addEventListener("click", closeSearch);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.hasAttribute("hidden")) closeSearch();
  });
</script>

<style>
  .site-nav__text-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-sm, 6px);
    border: 1px solid rgba(124, 255, 122, 0.08);
    background: rgba(20, 24, 31, 0.72);
    color: var(--muted);
    font-size: 0.76rem;
    letter-spacing: 0.06em;
    font-family: var(--font-ui);
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .site-nav__text-btn:hover {
    color: var(--text);
    border-color: rgba(124, 255, 122, 0.22);
    background: rgba(27, 34, 41, 0.9);
    transform: translateY(-1px);
  }

  .site-nav button.site-nav__icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.35rem;
    min-height: 2.35rem;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(124, 255, 122, 0.08);
    background: rgba(20, 24, 31, 0.72);
    color: var(--muted);
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .site-nav button.site-nav__icon-link:hover {
    color: var(--text);
    border-color: rgba(124, 255, 122, 0.22);
    background: rgba(27, 34, 41, 0.9);
    transform: translateY(-1px);
  }

  /* ── 검색 모달 ───────────────────────────────────────────── */
  #search-modal {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 6rem;
  }

  #search-modal[hidden] {
    display: none;
  }

  .search-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(5, 8, 12, 0.82);
    backdrop-filter: blur(4px);
  }

  .search-modal__panel {
    position: relative;
    z-index: 1;
    width: min(680px, calc(100vw - 2rem));
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    background: rgba(10, 14, 19, 0.97);
    border: 1px solid rgba(124, 255, 122, 0.18);
    border-radius: 10px;
    padding: 1.25rem 1.5rem 1.5rem;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7);
  }

  .search-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .search-modal__title {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(124, 255, 122, 0.45);
  }

  .search-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid rgba(124, 255, 122, 0.12);
    background: transparent;
    color: rgba(180, 210, 180, 0.6);
    cursor: pointer;
    transition: border-color 150ms, color 150ms, background 150ms;
  }

  .search-modal__close:hover {
    border-color: rgba(124, 255, 122, 0.35);
    color: #7cff7a;
    background: rgba(124, 255, 122, 0.06);
  }
</style>

<!-- Pagefind 전역 스타일 (모달 내부용) -->
<style is:global>
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #7cff7a;
    --pagefind-ui-text: #d0e8d0;
    --pagefind-ui-background: rgba(0, 0, 0, 0.5);
    --pagefind-ui-border: rgba(124, 255, 122, 0.2);
    --pagefind-ui-tag: rgba(124, 255, 122, 0.1);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-ui);
  }

  .pagefind-ui,
  .pagefind-ui * {
    font-family: var(--font-ui) !important;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background: rgba(0, 0, 0, 0.55) !important;
    color: #d6ffd6 !important;
    border: 1px solid rgba(124, 255, 122, 0.25) !important;
    font-family: var(--font-ui) !important;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    outline: none !important;
    border-color: rgba(124, 255, 122, 0.6) !important;
  }

  .pagefind-ui .pagefind-ui__result {
    border-color: rgba(124, 255, 122, 0.12) !important;
    border-radius: 6px !important;
    padding: 1rem !important;
    background: rgba(124, 255, 122, 0.02) !important;
  }

  .pagefind-ui .pagefind-ui__result:hover {
    border-color: rgba(124, 255, 122, 0.3) !important;
    background: rgba(124, 255, 122, 0.05) !important;
  }

  .pagefind-ui .pagefind-ui__result-title a {
    color: #c8e8c8 !important;
    text-decoration: none !important;
  }

  .pagefind-ui .pagefind-ui__result-title a:hover {
    color: #7cff7a !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: rgba(160, 200, 160, 0.7) !important;
    font-size: 0.85rem !important;
  }

  .pagefind-ui mark {
    background: rgba(124, 255, 122, 0.2) !important;
    color: #7cff7a !important;
    border-radius: 2px !important;
  }

  .pagefind-ui .pagefind-ui__button {
    background: rgba(124, 255, 122, 0.1) !important;
    border: 1px solid rgba(124, 255, 122, 0.25) !important;
    color: rgba(124, 255, 122, 0.8) !important;
    border-radius: 6px !important;
    cursor: pointer !important;
  }

  .pagefind-ui .pagefind-ui__button:hover {
    background: rgba(124, 255, 122, 0.18) !important;
    color: #7cff7a !important;
  }

  .pagefind-ui .pagefind-ui__message {
    color: rgba(150, 180, 150, 0.6) !important;
    font-size: 0.85rem !important;
  }
</style>
