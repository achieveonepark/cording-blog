# GitHub OAuth App 에서 발급 (Settings > Developer settings > OAuth Apps > New OAuth App)
# Homepage URL      : https://blog.somiri.dev
# Callback URL      : https://blog.somiri.dev/admin/callback
PUBLIC_GITHUB_CLIENT_ID=your_github_oauth_app_client_id

# Cloudflare Worker 배포 후 생성된 Worker URL
# 예) https://oauth-proxy.yourname.workers.dev
PUBLIC_OAUTH_WORKER_URL=https://your-worker.your-subdomain.workers.dev
